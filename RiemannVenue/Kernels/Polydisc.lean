import RiemannVenue.Kernels.Hellinger
import Mathlib.MeasureTheory.Integral.Pi
import Mathlib.Data.Nat.Factorization.Basic
import Mathlib.Analysis.SpecialFunctions.Pow.NNReal

/-!
# The polydisc spectral face of the gcd kernel — finite-place Bochner measure

The essay's "finite-place divisibility spectrum", with the infinite prime torus
replaced by a finite polydisc. The positive-definiteness of `κ` (see
`RiemannVenue.Kernels.Kappa`) is the *input* to Bochner–Herglotz; this file
exhibits, at every finite set of places, the measure Bochner would produce: the
product Poisson measure `∏_i P_{a_i}(θ_i) dθ_i/2π` on the finite-dimensional
torus `(-π, π]^ι`, whose Fourier coefficients are exactly the kernel values.

* `integral_poissonKernel_mul_exp` — the local (one-circle) complex moment
  identity: for `0 < a < 1` and `k : ℤ`,
  `∫_{-π}^{π} P_a(θ) e^{-ikθ} dθ = 2π a^{|k|}`.
  This is the full two-sided Fourier transform of the Poisson density; the
  `k = 0` case is the normalization `integral_poissonKernel` of
  `RiemannVenue.Kernels.Hellinger`, and the oscillating cases are computed by
  the same dominated-convergence interchange applied to the cosine expansion
  `hasSum_poissonKernel_sub_one`, using the product-to-sum identity for
  cosines and the vanishing of `∫ cos(rθ)` over a full period for `r ≠ 0`.
* `integral_polydisc_poissonKernel_mul_exp` — **the Bochner spectral measure
  of the finite-place divisibility geometry, at finite prime sets**: over the
  box measure on the polydisc, the Fourier coefficient of the product Poisson
  density at the character `χ_k(θ) = e^{-i⟨k,θ⟩}` factors into local moments,
  `∫_{box} ∏_i P_{a_i}(θ_i) χ_k(θ) dθ = ∏_i 2π a_i^{|k_i|}`.
* `normalized_integral_polydisc_poissonKernel_mul_exp` — the same against the
  normalized (probability) box measure: the transform is `∏ a_i^{|k_i|}`,
  which at `a_p = p^{-σ}` is the essay's `κ` evaluated on the subgroup `⟨S⟩`
  of `ℚ₊^×` generated by the primes of `S`. The infinite tensor product over
  *all* primes — the honest prime-torus spectral measure — is **not**
  constructed here; that (a projective limit / Kakutani-type construction) is
  the frontier this file stops at.
* `prod_rpow_half_factorization_eq_gcd_div_sqrt` — the arithmetic dressing at
  `σ = 1/2`: for `m, n` supported on a prime set `S` and `a_p = p^{-1/2}`,
  `∏_{p ∈ S} a_p^{|v_p(m) - v_p(n)|} = gcd(m,n)/√(mn)`, i.e. the polydisc
  Fourier coefficient at the exponent vector `k_p = v_p(m) - v_p(n)` **is**
  the gcd kernel entry.
-/

namespace RiemannVenue.Kernels

open MeasureTheory

/-! ## One circle: the complex moment identity -/

/-- The Poisson kernel is even in `θ`: immediate from the real closed form,
since the denominator depends on `θ` only through `cos θ`. -/
theorem poissonKernel_even (a θ : ℝ) : poissonKernel a (-θ) = poissonKernel a θ := by
  rw [poissonKernel_eq, poissonKernel_eq, Real.cos_neg]

/-- Product-to-sum for cosines:
`cos x · cos y = (cos(x - y) + cos(x + y))/2`. -/
theorem cos_mul_cos (x y : ℝ) :
    Real.cos x * Real.cos y = (Real.cos (x - y) + Real.cos (x + y)) / 2 := by
  rw [Real.cos_sub, Real.cos_add]
  ring

/-- Over a full period, `cos (rθ)` integrates to `2π` for `r = 0` and to `0`
for every other integer frequency: the orthogonality relation that isolates a
single term of the Poisson expansion. -/
private theorem integral_cos_int_mul (r : ℤ) :
    (∫ θ in (-Real.pi)..Real.pi, Real.cos ((r : ℝ) * θ))
      = if r = 0 then 2 * Real.pi else 0 := by
  rcases eq_or_ne r 0 with hr | hr
  · subst hr
    rw [if_pos rfl]
    simp only [Int.cast_zero, zero_mul, Real.cos_zero]
    rw [intervalIntegral.integral_const, smul_eq_mul, mul_one]
    ring
  · have hc : (r : ℝ) ≠ 0 := Int.cast_ne_zero.mpr hr
    have hs1 : Real.sin ((r : ℝ) * Real.pi) = 0 := Real.sin_int_mul_pi r
    have hs2 : Real.sin ((r : ℝ) * -Real.pi) = 0 := by
      rw [mul_neg, Real.sin_neg, hs1, neg_zero]
    rw [if_neg hr, intervalIntegral.integral_comp_mul_left (fun x => Real.cos x) hc,
      integral_cos, hs1, hs2]
    simp

/-- **The cosine moments of the Poisson kernel**:
`∫_{-π}^{π} P_a(θ) cos(mθ) dθ = 2π a^m`. The `m = 0` case is the
normalization `integral_poissonKernel`; for `m ≥ 1` the dominated-convergence
interchange over the expansion `P_a = 1 + ∑ 2a^{n+1} cos((n+1)θ)` leaves,
after product-to-sum, exactly the resonant term `n + 1 = m`. -/
private theorem integral_poissonKernel_mul_cos {a : ℝ} (ha₀ : 0 < a) (ha₁ : a < 1) (m : ℕ) :
    (∫ θ in (-Real.pi)..Real.pi, poissonKernel a θ * Real.cos ((m : ℝ) * θ))
      = 2 * Real.pi * a ^ m := by
  rcases Nat.eq_zero_or_pos m with hm | hm
  · subst hm
    simp only [Nat.cast_zero, zero_mul, Real.cos_zero, mul_one]
    rw [integral_poissonKernel ha₀ ha₁, pow_zero, mul_one]
  · have hsummable : Summable fun n : ℕ => 2 * a ^ (n + 1) :=
      ((summable_geometric_of_lt_one ha₀.le ha₁).mul_left (2 * a)).congr fun n => by
        rw [pow_succ]; ring
    -- the sum-integral interchange, by dominated convergence
    have key : HasSum
        (fun n : ℕ => ∫ θ in (-Real.pi)..Real.pi,
          2 * a ^ (n + 1) * Real.cos (((n : ℝ) + 1) * θ) * Real.cos ((m : ℝ) * θ))
        (∫ θ in (-Real.pi)..Real.pi, (poissonKernel a θ - 1) * Real.cos ((m : ℝ) * θ)) := by
      refine intervalIntegral.hasSum_integral_of_dominated_convergence
        (fun n _ => 2 * a ^ (n + 1)) (fun n => ?_) (fun n => ?_) ?_ ?_ ?_
      · exact ((continuous_const.mul (Real.continuous_cos.comp
          (continuous_const.mul continuous_id))).mul (Real.continuous_cos.comp
          (continuous_const.mul continuous_id))).aestronglyMeasurable
      · refine ae_of_all _ fun θ _ => ?_
        have h1 : |Real.cos (((n : ℝ) + 1) * θ)| ≤ 1 := Real.abs_cos_le_one _
        have h1' : |Real.cos ((m : ℝ) * θ)| ≤ 1 := Real.abs_cos_le_one _
        have h2 : (0 : ℝ) ≤ 2 * a ^ (n + 1) := by positivity
        rw [Real.norm_eq_abs, abs_mul, abs_mul, abs_of_nonneg h2]
        have hstep : 2 * a ^ (n + 1) * |Real.cos (((n : ℝ) + 1) * θ)| ≤ 2 * a ^ (n + 1) :=
          mul_le_of_le_one_right h2 h1
        have hstep2 : 2 * a ^ (n + 1) * |Real.cos (((n : ℝ) + 1) * θ)|
              * |Real.cos ((m : ℝ) * θ)|
            ≤ 2 * a ^ (n + 1) * |Real.cos (((n : ℝ) + 1) * θ)| :=
          mul_le_of_le_one_right (by positivity) h1'
        exact hstep2.trans hstep
      · exact ae_of_all _ fun θ _ => hsummable
      · exact intervalIntegrable_const
      · exact ae_of_all _ fun θ _ =>
          (hasSum_poissonKernel_sub_one ha₀ ha₁ θ).mul_right _
    -- each term integral: only the resonant frequency `n + 1 = m` survives
    have hterm : ∀ n : ℕ,
        (∫ θ in (-Real.pi)..Real.pi,
          2 * a ^ (n + 1) * Real.cos (((n : ℝ) + 1) * θ) * Real.cos ((m : ℝ) * θ))
        = if n + 1 = m then 2 * Real.pi * a ^ m else 0 := by
      intro n
      have hpt : ∀ θ : ℝ,
          2 * a ^ (n + 1) * Real.cos (((n : ℝ) + 1) * θ) * Real.cos ((m : ℝ) * θ)
          = a ^ (n + 1) * (Real.cos (((((n : ℤ) + 1 - (m : ℤ)) : ℤ) : ℝ) * θ)
              + Real.cos (((((n : ℤ) + 1 + (m : ℤ)) : ℤ) : ℝ) * θ)) := fun θ => by
        have hsub : ((n : ℝ) + 1) * θ - (m : ℝ) * θ
            = ((((n : ℤ) + 1 - (m : ℤ)) : ℤ) : ℝ) * θ := by
          push_cast; ring
        have hadd : ((n : ℝ) + 1) * θ + (m : ℝ) * θ
            = ((((n : ℤ) + 1 + (m : ℤ)) : ℤ) : ℝ) * θ := by
          push_cast; ring
        have h := cos_mul_cos (((n : ℝ) + 1) * θ) ((m : ℝ) * θ)
        rw [hsub, hadd] at h
        linear_combination (2 * a ^ (n + 1) : ℝ) * h
      have hi1 : IntervalIntegrable
          (fun θ => Real.cos (((((n : ℤ) + 1 - (m : ℤ)) : ℤ) : ℝ) * θ))
          volume (-Real.pi) Real.pi :=
        (Real.continuous_cos.comp (continuous_const.mul continuous_id)).intervalIntegrable _ _
      have hi2 : IntervalIntegrable
          (fun θ => Real.cos (((((n : ℤ) + 1 + (m : ℤ)) : ℤ) : ℝ) * θ))
          volume (-Real.pi) Real.pi :=
        (Real.continuous_cos.comp (continuous_const.mul continuous_id)).intervalIntegrable _ _
      simp only [hpt]
      rw [intervalIntegral.integral_const_mul, intervalIntegral.integral_add hi1 hi2,
        integral_cos_int_mul, integral_cos_int_mul]
      have hne : ¬((n : ℤ) + 1 + (m : ℤ) = 0) := by omega
      rw [if_neg hne, add_zero]
      by_cases hcase : (n : ℤ) + 1 - (m : ℤ) = 0
      · have hnm : n + 1 = m := by omega
        rw [if_pos hcase, if_pos hnm, ← hnm]
        ring
      · have hnm : ¬(n + 1 = m) := by omega
        rw [if_neg hcase, if_neg hnm, mul_zero]
    -- the single surviving term sums to `2π a^m`
    have hsum2 : HasSum (fun n : ℕ => if n + 1 = m then 2 * Real.pi * a ^ m else 0)
        (2 * Real.pi * a ^ m) := by
      have h := hasSum_single (f := fun n : ℕ => if n + 1 = m then 2 * Real.pi * a ^ m else 0)
        (m - 1) (fun n hn => if_neg (by omega))
      rwa [if_pos (by omega : m - 1 + 1 = m)] at h
    have hX : HasSum (fun n : ℕ => if n + 1 = m then 2 * Real.pi * a ^ m else 0)
        (∫ θ in (-Real.pi)..Real.pi, (poissonKernel a θ - 1) * Real.cos ((m : ℝ) * θ)) :=
      key.congr_fun fun n => (hterm n).symm
    have hval : (∫ θ in (-Real.pi)..Real.pi, (poissonKernel a θ - 1) * Real.cos ((m : ℝ) * θ))
        = 2 * Real.pi * a ^ m := hX.unique hsum2
    have hPc : Continuous fun θ => poissonKernel a θ * Real.cos ((m : ℝ) * θ) :=
      (continuous_poissonKernel ha₀ ha₁).mul
        (Real.continuous_cos.comp (continuous_const.mul continuous_id))
    have hcc : Continuous fun θ => Real.cos ((m : ℝ) * θ) :=
      Real.continuous_cos.comp (continuous_const.mul continuous_id)
    have hsplit : (∫ θ in (-Real.pi)..Real.pi, (poissonKernel a θ - 1) * Real.cos ((m : ℝ) * θ))
        = (∫ θ in (-Real.pi)..Real.pi, poissonKernel a θ * Real.cos ((m : ℝ) * θ))
          - ∫ θ in (-Real.pi)..Real.pi, Real.cos ((m : ℝ) * θ) := by
      rw [← intervalIntegral.integral_sub (hPc.intervalIntegrable _ _)
        (hcc.intervalIntegrable _ _)]
      congr 1
      funext θ
      ring
    have hcos0 : (∫ θ in (-Real.pi)..Real.pi, Real.cos ((m : ℝ) * θ)) = 0 := by
      have h := integral_cos_int_mul (m : ℤ)
      rw [if_neg (by omega : ¬((m : ℤ) = 0))] at h
      simpa using h
    rw [hsplit, hcos0, sub_zero] at hval
    exact hval

/-- The sine moments all vanish: `∫_{-π}^{π} P_a(θ) sin(cθ) dθ = 0`, because
the Poisson kernel is even and the sine factor is odd over the symmetric
interval. No hypotheses on `a` are needed. -/
theorem integral_poissonKernel_mul_sin (a c : ℝ) :
    (∫ θ in (-Real.pi)..Real.pi, poissonKernel a θ * Real.sin (c * θ)) = 0 := by
  have h1 : (∫ θ in (-Real.pi)..Real.pi, poissonKernel a (-θ) * Real.sin (c * -θ))
      = ∫ θ in (-Real.pi)..Real.pi, poissonKernel a θ * Real.sin (c * θ) := by
    rw [intervalIntegral.integral_comp_neg (fun θ => poissonKernel a θ * Real.sin (c * θ)),
      neg_neg]
  have h2 : (∫ θ in (-Real.pi)..Real.pi, poissonKernel a (-θ) * Real.sin (c * -θ))
      = -∫ θ in (-Real.pi)..Real.pi, poissonKernel a θ * Real.sin (c * θ) := by
    rw [← intervalIntegral.integral_neg]
    congr 1
    funext θ
    rw [poissonKernel_even, mul_neg, Real.sin_neg]
    ring
  have h := h1.symm.trans h2
  linarith

/-- **The complex moment identity on one circle**: for `0 < a < 1` and `k : ℤ`,
`∫_{-π}^{π} P_a(θ) e^{-ikθ} dθ = 2π a^{|k|}`.

This is the diagonal of the essay's local spectral computation: the Fourier
transform of the local Poisson density at the frequency `k` is the geometric
weight `a^{|k|}` — at a prime `p` with `a = p^{-σ}`, exactly the local factor
`p^{-σ|k|}` of the gcd kernel. The real part is
`integral_poissonKernel_mul_cos` (cosine is even, so only `|k|` matters); the
imaginary part vanishes by symmetry (`integral_poissonKernel_mul_sin`). -/
theorem integral_poissonKernel_mul_exp {a : ℝ} (ha₀ : 0 < a) (ha₁ : a < 1) (k : ℤ) :
    (∫ θ in (-Real.pi)..Real.pi,
        (poissonKernel a θ : ℂ) * Complex.exp (-((k : ℂ) * (θ : ℂ) * Complex.I)))
      = 2 * (Real.pi : ℂ) * (a : ℂ) ^ k.natAbs := by
  have hcos : ∀ θ : ℝ, Real.cos ((k : ℝ) * θ) = Real.cos ((k.natAbs : ℝ) * θ) := by
    intro θ
    have h2 : |(k : ℝ)| = (k.natAbs : ℝ) := by
      rw [← Int.cast_abs, ← Int.natCast_natAbs, Int.cast_natCast]
    rw [← h2]
    rcases abs_choice ((k : ℝ)) with h | h
    · rw [h]
    · rw [h, neg_mul, Real.cos_neg]
  have hpt : ∀ θ : ℝ,
      (poissonKernel a θ : ℂ) * Complex.exp (-((k : ℂ) * (θ : ℂ) * Complex.I))
      = ((poissonKernel a θ * Real.cos ((k.natAbs : ℝ) * θ) : ℝ) : ℂ)
        - ((poissonKernel a θ * Real.sin ((k : ℝ) * θ) : ℝ) : ℂ) * Complex.I := by
    intro θ
    have h1 : -((k : ℂ) * (θ : ℂ) * Complex.I) = ((-((k : ℝ) * θ) : ℝ) : ℂ) * Complex.I := by
      push_cast
      ring
    rw [h1, Complex.exp_mul_I, ← Complex.ofReal_cos, ← Complex.ofReal_sin,
      Real.cos_neg, Real.sin_neg, hcos θ]
    push_cast
    ring
  have hPc : Continuous fun θ => poissonKernel a θ * Real.cos ((k.natAbs : ℝ) * θ) :=
    (continuous_poissonKernel ha₀ ha₁).mul
      (Real.continuous_cos.comp (continuous_const.mul continuous_id))
  have hPs : Continuous fun θ => poissonKernel a θ * Real.sin ((k : ℝ) * θ) :=
    (continuous_poissonKernel ha₀ ha₁).mul
      (Real.continuous_sin.comp (continuous_const.mul continuous_id))
  have hI1 : IntervalIntegrable
      (fun θ => ((poissonKernel a θ * Real.cos ((k.natAbs : ℝ) * θ) : ℝ) : ℂ))
      volume (-Real.pi) Real.pi :=
    (Complex.continuous_ofReal.comp hPc).intervalIntegrable _ _
  have hI2 : IntervalIntegrable
      (fun θ => ((poissonKernel a θ * Real.sin ((k : ℝ) * θ) : ℝ) : ℂ) * Complex.I)
      volume (-Real.pi) Real.pi :=
    ((Complex.continuous_ofReal.comp hPs).mul continuous_const).intervalIntegrable _ _
  simp only [hpt]
  rw [intervalIntegral.integral_sub hI1 hI2, intervalIntegral.integral_mul_const,
    intervalIntegral.integral_ofReal, intervalIntegral.integral_ofReal,
    integral_poissonKernel_mul_cos ha₀ ha₁ k.natAbs, integral_poissonKernel_mul_sin]
  push_cast
  ring

/-! ## The polydisc: the finite-place spectral measure -/

/-- **The polydisc Fourier coefficient factors into local moments.** For a
finite index `ι` (the finite set of places), radii `a i ∈ (0,1)` and an
exponent vector `k : ι → ℤ`, the integral of
`∏ᵢ P_{aᵢ}(θᵢ) e^{-i kᵢ θᵢ}` over the box `∏ᵢ (-π, π]` (product of restricted
volumes) is `∏ᵢ 2π aᵢ^{|kᵢ|}`.

This is the Bochner spectral measure of the finite-place divisibility
geometry at a finite prime set: the character group of the polydisc torus is
`ℤ^ι` — the subgroup of `ℚ₊^×` generated by the chosen primes — and the
product Poisson measure's Fourier transform on it is the gcd kernel's `κ`
(up to the `2π` mass factors removed in the normalized corollary below). The
infinite tensor product over all primes is *not* constructed here. -/
theorem integral_polydisc_poissonKernel_mul_exp {ι : Type*} [Fintype ι]
    {a : ι → ℝ} (ha₀ : ∀ i, 0 < a i) (ha₁ : ∀ i, a i < 1) (k : ι → ℤ) :
    (∫ θ : ι → ℝ, ∏ i, ((poissonKernel (a i) (θ i) : ℂ)
        * Complex.exp (-((k i : ℂ) * (θ i : ℂ) * Complex.I)))
      ∂(Measure.pi fun _ => volume.restrict (Set.Ioc (-Real.pi) Real.pi)))
    = ∏ i, (2 * (Real.pi : ℂ) * (a i : ℂ) ^ (k i).natAbs) := by
  have hfub : (∫ θ : ι → ℝ, ∏ i, ((poissonKernel (a i) (θ i) : ℂ)
        * Complex.exp (-((k i : ℂ) * (θ i : ℂ) * Complex.I)))
      ∂(Measure.pi fun _ => volume.restrict (Set.Ioc (-Real.pi) Real.pi)))
      = ∏ i, ∫ t, ((poissonKernel (a i) t : ℂ)
          * Complex.exp (-((k i : ℂ) * (t : ℂ) * Complex.I)))
        ∂(volume.restrict (Set.Ioc (-Real.pi) Real.pi)) :=
    MeasureTheory.integral_fintype_prod_eq_prod
      (fun i t => (poissonKernel (a i) t : ℂ)
        * Complex.exp (-((k i : ℂ) * (t : ℂ) * Complex.I)))
  rw [hfub]
  refine Finset.prod_congr rfl fun i _ => ?_
  rw [← intervalIntegral.integral_of_le (by linarith [Real.pi_pos] : -Real.pi ≤ Real.pi)]
  exact integral_poissonKernel_mul_exp (ha₀ i) (ha₁ i) (k i)

/-- **The normalized polydisc transform is `κ` on the subgroup generated by
the chosen places**: against the probability measure `∏ᵢ P_{aᵢ}(θᵢ) dθᵢ/2π`
on the polydisc, the Fourier coefficient at `k` is `∏ᵢ aᵢ^{|kᵢ|}`. At
`a_p = p^{-σ}` this is `∏ p^{-σ|k_p|}`, the essay's positive-definite
function `κ` (at `σ = 1/2`: `gcd/√(mn)`, see
`prod_rpow_half_factorization_eq_gcd_div_sqrt`) restricted to the subgroup
`⟨S⟩ ≤ ℚ₊^×` of rationals supported on the finite prime set. -/
theorem normalized_integral_polydisc_poissonKernel_mul_exp {ι : Type*} [Fintype ι]
    {a : ι → ℝ} (ha₀ : ∀ i, 0 < a i) (ha₁ : ∀ i, a i < 1) (k : ι → ℤ) :
    (1 / (2 * (Real.pi : ℂ))) ^ Fintype.card ι
      * (∫ θ : ι → ℝ, ∏ i, ((poissonKernel (a i) (θ i) : ℂ)
          * Complex.exp (-((k i : ℂ) * (θ i : ℂ) * Complex.I)))
        ∂(Measure.pi fun _ => volume.restrict (Set.Ioc (-Real.pi) Real.pi)))
    = ∏ i, (a i : ℂ) ^ (k i).natAbs := by
  rw [integral_polydisc_poissonKernel_mul_exp ha₀ ha₁ k, Finset.prod_mul_distrib,
    Finset.prod_const, Finset.card_univ]
  have h2π : (2 * (Real.pi : ℂ)) ≠ 0 :=
    mul_ne_zero two_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_ne_zero)
  rw [one_div, inv_pow, inv_mul_cancel_left₀ (pow_ne_zero _ h2π)]

/-! ## The arithmetic dressing at `σ = 1/2` -/

/-- Reconstruction over a covering prime set: if all prime factors of `m` lie
in `S`, then `m = ∏_{p ∈ S} p^{v_p(m)}` (the extra factors are `p^0 = 1`). -/
theorem prod_pow_factorization_eq_self {S : Finset ℕ} {m : ℕ} (hm : m ≠ 0)
    (hmS : m.primeFactors ⊆ S) :
    (∏ p ∈ S, p ^ m.factorization p) = m := by
  have hsupp : m.factorization.support ⊆ S := by
    rw [Nat.support_factorization]
    exact hmS
  exact (Finsupp.prod_of_support_subset m.factorization hsupp (· ^ ·)
    (fun p _ => pow_zero p)).symm.trans (Nat.prod_factorization_pow_eq_self hm)

/-- The combinatorial core of the gcd-kernel identity, in `ℕ`:
`(∏_{p ∈ S} p^{|v_p(m) - v_p(n)|}) · gcd(m,n)² = m · n`, valid whenever the
prime factors of `m` and `n` lie in `S`. Multiplicative form of the exponent
identity `|x - y| + 2 min(x, y) = x + y`. -/
theorem prod_pow_natAbs_factorization_mul_gcd_sq {S : Finset ℕ} {m n : ℕ}
    (hm : m ≠ 0) (hn : n ≠ 0) (hmS : m.primeFactors ⊆ S) (hnS : n.primeFactors ⊆ S) :
    (∏ p ∈ S, p ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs)
      * Nat.gcd m n ^ 2 = m * n := by
  have hg0 : Nat.gcd m n ≠ 0 := fun h => hm (Nat.gcd_eq_zero_iff.mp h).1
  have hgS : (Nat.gcd m n).primeFactors ⊆ S := fun p hp =>
    hmS (Nat.primeFactors_mono (Nat.gcd_dvd_left m n) hm hp)
  have hgfac : (∏ p ∈ S, p ^ min (m.factorization p) (n.factorization p)) = Nat.gcd m n := by
    rw [← prod_pow_factorization_eq_self hg0 hgS]
    refine Finset.prod_congr rfl fun p _ => ?_
    rw [Nat.factorization_gcd hm hn, Finsupp.inf_apply]
  calc (∏ p ∈ S, p ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs)
        * Nat.gcd m n ^ 2
      = (∏ p ∈ S, p ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs)
        * (∏ p ∈ S, p ^ min (m.factorization p) (n.factorization p)) ^ 2 := by
        rw [hgfac]
    _ = ∏ p ∈ S, p ^ (((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs
          + min (m.factorization p) (n.factorization p) * 2) := by
        rw [← Finset.prod_pow, ← Finset.prod_mul_distrib]
        refine Finset.prod_congr rfl fun p _ => ?_
        rw [pow_add, pow_mul]
    _ = ∏ p ∈ S, p ^ (m.factorization p + n.factorization p) := by
        refine Finset.prod_congr rfl fun p _ => ?_
        congr 1
        omega
    _ = (∏ p ∈ S, p ^ m.factorization p) * ∏ p ∈ S, p ^ n.factorization p := by
        rw [← Finset.prod_mul_distrib]
        exact Finset.prod_congr rfl fun p _ => pow_add p _ _
    _ = m * n := by
        rw [prod_pow_factorization_eq_self hm hmS, prod_pow_factorization_eq_self hn hnS]

/-- **The polydisc Fourier coefficient IS the gcd kernel entry.** For a finite
set `S` of primes, naturals `m, n ≥ 1` whose prime factors lie in `S`, and
local radii `a_p = p^{-1/2}` (the essay's critical line `σ = 1/2`),

`∏_{p ∈ S} a_p^{|v_p(m) - v_p(n)|} = gcd(m,n) / √(m·n)`.

Together with `normalized_integral_polydisc_poissonKernel_mul_exp` at
`k_p = v_p(m) - v_p(n)`, this identifies the normalized polydisc integral of
the product Poisson density against the character of `m/n` with the entry
`gcd(m,n)/√(mn)` of the positive-definite gcd kernel: the finite-place
spectral measure represents the kernel on the subgroup `⟨S⟩` of `ℚ₊^×`. -/
theorem prod_rpow_half_factorization_eq_gcd_div_sqrt {S : Finset ℕ}
    (hS : ∀ p ∈ S, p.Prime) {m n : ℕ} (hm : m ≠ 0) (hn : n ≠ 0)
    (hmS : m.primeFactors ⊆ S) (hnS : n.primeFactors ⊆ S) :
    (∏ p ∈ S, ((p : ℝ) ^ (-(1 / 2) : ℝ))
        ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs)
      = (Nat.gcd m n : ℝ) / Real.sqrt ((m : ℝ) * (n : ℝ)) := by
  set N : ℕ := ∏ p ∈ S, p ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs
    with hN
  have hNpos : 0 < N := Finset.prod_pos fun p hp => pow_pos (hS p hp).pos _
  have hkey : N * Nat.gcd m n ^ 2 = m * n :=
    prod_pow_natAbs_factorization_mul_gcd_sq hm hn hmS hnS
  have hg0 : Nat.gcd m n ≠ 0 := fun h => hm (Nat.gcd_eq_zero_iff.mp h).1
  have hgr : (0 : ℝ) < (Nat.gcd m n : ℝ) := by
    exact_mod_cast Nat.pos_of_ne_zero hg0
  -- swap the exponents: (p^{-1/2})^e = (p^e)^{-1/2}
  have hswap : ∀ p ∈ S, ((p : ℝ) ^ (-(1 / 2) : ℝ))
        ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs
      = ((p : ℝ) ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs)
        ^ (-(1 / 2) : ℝ) := by
    intro p _
    have hp0 : (0 : ℝ) ≤ (p : ℝ) := Nat.cast_nonneg p
    rw [← Real.rpow_natCast ((p : ℝ) ^ (-(1 / 2) : ℝ))
        ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs,
      ← Real.rpow_mul hp0, mul_comm, Real.rpow_mul hp0, Real.rpow_natCast]
  rw [Finset.prod_congr rfl hswap,
    Real.finsetProd_rpow S _ (fun p _ => pow_nonneg (Nat.cast_nonneg p) _) _]
  have hprod : (∏ p ∈ S,
      (p : ℝ) ^ ((m.factorization p : ℤ) - (n.factorization p : ℤ)).natAbs) = (N : ℝ) := by
    rw [hN]
    push_cast
    rfl
  rw [hprod]
  -- `√(mn) = √N · gcd`, then compare
  have hmn : (m : ℝ) * (n : ℝ) = (N : ℝ) * (Nat.gcd m n : ℝ) ^ 2 := by
    exact_mod_cast hkey.symm
  have hsqrtN : (0 : ℝ) < Real.sqrt (N : ℝ) :=
    Real.sqrt_pos.mpr (by exact_mod_cast hNpos)
  rw [hmn, Real.sqrt_mul (Nat.cast_nonneg N), Real.sqrt_sq hgr.le,
    Real.rpow_neg (Nat.cast_nonneg N), ← Real.sqrt_eq_rpow]
  rw [mul_comm, ← div_div, div_self hgr.ne', one_div]

end RiemannVenue.Kernels
