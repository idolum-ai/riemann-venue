theorem computedPhasedBaseLowerThreeDirectGroup8_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectGroup8Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectGroup8Interval]

noncomputable def computedPhasedBaseLowerThreeDirectGroup8TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectGroup8Interval (by norm_num [computedPhasedBaseLowerThreeDirectGroup8Interval])
