      have hz : x - (computedPhasedBaseFullFiveInnerFourCompactCell1Shard11Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourCompactCell1Shard11PointInterval, computedPhasedBaseFullFiveInnerFourCompactCell1Shard11Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
