import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder9Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder9Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder9Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder9Shard3Cache

/-! # Exact global base-remainder cache, order 9 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder9Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder9Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder9Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder9Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder9Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder9Shards_0 :
    computedPhasedBaseGlobalRemainderOrder9Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder9Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder9Shards_1 :
    computedPhasedBaseGlobalRemainderOrder9Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder9Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder9Shards_2 :
    computedPhasedBaseGlobalRemainderOrder9Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder9Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder9Shards_3 :
    computedPhasedBaseGlobalRemainderOrder9Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder9Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder9ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 9 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder9Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder9ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder9ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder9Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder9Shard0Group = computedPhasedBaseGlobalRemainderOrder9Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder9Shards_0, computedPhasedBaseGlobalRemainderOrder9Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder9Shard1Group = computedPhasedBaseGlobalRemainderOrder9Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder9Shards_1, computedPhasedBaseGlobalRemainderOrder9Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder9Shard2Group = computedPhasedBaseGlobalRemainderOrder9Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder9Shards_2, computedPhasedBaseGlobalRemainderOrder9Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder9Shard3Group = computedPhasedBaseGlobalRemainderOrder9Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder9Shards_3, computedPhasedBaseGlobalRemainderOrder9Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder9Cache_eq :
    computedPhasedBaseGlobalRemainderOrder9Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 9 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder9Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder9ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder9ShardEvaluator = computedPhasedBaseGlobalRemainderOrder9Shards from funext computedPhasedBaseGlobalRemainderOrder9ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder9Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder9Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder9Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder9Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder9Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder9Shards_0, computedPhasedBaseGlobalRemainderOrder9Shards_1, computedPhasedBaseGlobalRemainderOrder9Shards_2, computedPhasedBaseGlobalRemainderOrder9Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder9Cache, computedPhasedBaseGlobalRemainderOrder9Shard0Cache, computedPhasedBaseGlobalRemainderOrder9Shard1Cache, computedPhasedBaseGlobalRemainderOrder9Shard2Cache, computedPhasedBaseGlobalRemainderOrder9Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
