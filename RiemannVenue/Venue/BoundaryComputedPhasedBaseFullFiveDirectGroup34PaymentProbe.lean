theorem computedPhasedBaseFullFiveDirectGroup34_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup34Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup34Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup34TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup34Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup34Interval])
