      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell4Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell4Shard8PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell4Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
