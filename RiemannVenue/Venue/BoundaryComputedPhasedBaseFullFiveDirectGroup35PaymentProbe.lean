theorem computedPhasedBaseFullFiveDirectGroup35_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup35Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup35Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup35TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup35Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup35Interval])
