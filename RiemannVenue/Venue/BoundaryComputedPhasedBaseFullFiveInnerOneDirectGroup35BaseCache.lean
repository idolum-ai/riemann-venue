      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell5Shard28Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell5Shard28PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell5Shard28Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
