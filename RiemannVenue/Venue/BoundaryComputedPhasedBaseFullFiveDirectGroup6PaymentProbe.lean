    computedPhasedBaseFullFiveDirectGroup6Interval.center = computedPhasedBaseFullFiveCompactCell1Shard0Interval.center := by
  norm_num [computedPhasedBaseFullFiveDirectGroup6Interval, computedPhasedBaseFullFiveCompactCell1Shard0Interval]

def computedPhasedBaseFullFiveDirectGroup6Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup6Jets
    computedPhasedBaseFullFiveDirectGroup6ForwardKernel computedPhasedBaseFullFiveDirectGroup6ReflectedKernel n

theorem computedPhasedBaseFullFiveDirectGroup6Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup6Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup6Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup6Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup6Jets
    computedPhasedBaseFullFiveDirectGroup6ForwardKernel computedPhasedBaseFullFiveDirectGroup6ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup6ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup6ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup6_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup6Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup6Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup6TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup6Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup6Interval])
    computedPhasedBaseFullFiveDirectGroup6Paired computedPhasedBaseFullFiveDirectGroup6Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup6_remainder hx)

def computedPhasedBaseFullFiveDirectGroup6TaylorCenterQ : ℚ × ℚ :=
