    computedPhasedBaseFullFiveDirectGroup26ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup26ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup26_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup26Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup26Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup26TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup26Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup26Interval])
    computedPhasedBaseFullFiveDirectGroup26Paired computedPhasedBaseFullFiveDirectGroup26Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup26_remainder hx)

def computedPhasedBaseFullFiveDirectGroup26TaylorCenterQ : ℚ × ℚ :=
