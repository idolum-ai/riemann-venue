theorem computedPhasedBaseFullFiveDirectGroup26Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup26Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup26Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup26Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup26Jets
