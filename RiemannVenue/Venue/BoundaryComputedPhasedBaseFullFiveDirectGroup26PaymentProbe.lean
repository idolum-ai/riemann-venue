  norm_num [computedPhasedBaseFullFiveDirectGroup26Interval, computedPhasedBaseFullFiveCompactCell4Shard5Interval]

def computedPhasedBaseFullFiveDirectGroup26Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup26Jets
