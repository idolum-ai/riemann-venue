/-- Singleton powers stay exact during the point-evaluator reduction. -/
@[simp] private theorem pointCachePowSingleton (x : ℚ) (n : ℕ) :
    RationalInterval.pow (RationalInterval.singleton x) n =
      RationalInterval.singleton (x ^ n) := by
  induction n with
  | zero => simp [RationalInterval.pow, RationalInterval.one,
      RationalInterval.singleton]
  | succ n ih =>
      rw [RationalInterval.pow, ih]
      simp [RationalInterval.mul, RationalInterval.singleton, pow_succ]

/-- Sparse integer-polynomial evaluation is exact on a singleton. -/
private theorem pointCacheSparseIntPolynomialSingleton
    (p : ℤ[X]) (x : ℚ) :
    RationalInterval.sparseIntPolynomial p (RationalInterval.singleton x) =
      RationalInterval.singleton
        (Polynomial.eval₂ (Int.castRingHom ℚ) x p) := by
  rw [RationalInterval.sparseIntPolynomial, RationalInterval.sparseSum]
  simp only [pointCachePowSingleton]
  simp [RationalInterval.mul, RationalInterval.singleton,
    Polynomial.eval₂_eq_sum, Polynomial.sum_def]

/-- Record-form companion after singleton constructors reduce. -/
@[simp] private theorem pointCacheSparseIntPolynomialZeroRadius
    (p : ℤ[X]) (x : ℚ) :
    RationalInterval.sparseIntPolynomial p ⟨x, 0⟩ =
      ⟨Polynomial.eval₂ (Int.castRingHom ℚ) x p, 0⟩ := by
  simpa [RationalInterval.singleton] using
    pointCacheSparseIntPolynomialSingleton p x

