def computedPhasedBaseFullFiveInnerFourDirectTailSigned (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerFourDirectTailGroup n b g

theorem computedPhasedBaseFullFiveInnerFourDirectTailSigned_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerFourDirectTailSigned n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerFourTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerFourDirectTailGroup_contains n b g

def computedPhasedBaseFullFiveInnerFourDirectTailSignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerFourTailPointInterval where
  signed := computedPhasedBaseFullFiveInnerFourDirectTailSigned
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerFourTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerFourTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourTailPointInterval, computedPhasedBaseFullFiveInnerFourTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerFourDirectTailSigned_contains n b

def computedPhasedBaseFullFiveInnerFourDirectTailBumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerFourTailPointInterval where
  bump := computedPhasedBaseFullFiveInnerFourDirectTailBump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerFourTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerFourTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourTailPointInterval, computedPhasedBaseFullFiveInnerFourTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerFourDirectTailBump_contains b n

