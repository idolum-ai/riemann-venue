def computedPhasedBaseFullFiveInnerFourDirectGroup25Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerFourDirectGroup25Group n b g

theorem computedPhasedBaseFullFiveInnerFourDirectGroup25Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerFourDirectGroup25Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerFourCompactCell4Shard2Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerFourDirectGroup25Group_contains n b g

def computedPhasedBaseFullFiveInnerFourDirectGroup25SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerFourCompactCell4Shard2PointInterval where
  signed := computedPhasedBaseFullFiveInnerFourDirectGroup25Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerFourCompactCell4Shard2Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerFourCompactCell4Shard2Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourCompactCell4Shard2PointInterval, computedPhasedBaseFullFiveInnerFourCompactCell4Shard2Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerFourDirectGroup25Signed_contains n b

def computedPhasedBaseFullFiveInnerFourDirectGroup25BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
