  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerFourCompactCell6Shard12Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerFourCompactCell6Shard12Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourCompactCell6Shard12PointInterval, computedPhasedBaseFullFiveInnerFourCompactCell6Shard12Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerFourDirectGroup38Signed_contains n b

