import RiemannVenue.Venue.BoundaryComputedPhasedBaseOuterCompactVariationCore

/-! # Global base-remainder cache, order 0, shard 2 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000
set_option maxHeartbeats 4000000

def computedPhasedBaseGlobalRemainderOrder0Shard2Group (g : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun k : Fin 5 ↦
    let outer : Fin 20 := finProdFinEquiv ((2 : Fin 4), g)
    let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
    RationalInterval.scale (computedPhasedBaseCoefficientQ j)
      (computedTransformAtomJetCellIntervalUpTo12
        32 4 32 16 0 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder0Shard2Groups : Fin 5 → RationalInterval := ![
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shard2Groups_0 :
    computedPhasedBaseGlobalRemainderOrder0Shard2Groups (0 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shard2Groups_1 :
    computedPhasedBaseGlobalRemainderOrder0Shard2Groups (1 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shard2Groups_2 :
    computedPhasedBaseGlobalRemainderOrder0Shard2Groups (2 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shard2Groups_3 :
    computedPhasedBaseGlobalRemainderOrder0Shard2Groups (3 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shard2Groups_4 :
    computedPhasedBaseGlobalRemainderOrder0Shard2Groups (4 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

def computedPhasedBaseGlobalRemainderOrder0Shard2Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder0Shard2Group_eq (g : Fin 5) :
    computedPhasedBaseGlobalRemainderOrder0Shard2Group g = computedPhasedBaseGlobalRemainderOrder0Shard2Groups g := by
  fin_cases g <;>
    norm_num (config := { maxSteps := 4000000 })
      [computedPhasedBaseGlobalRemainderOrder0Shard2Group, computedPhasedBaseGlobalRemainderOrder0Shard2Groups, computedPhasedBaseGlobalWindow,
        computedTransformAtomJetCellIntervalUpTo12,
        computedTransformCosineJetCellInterval,
        computedTransformAtomTrigCellInterval,
        rationalCosineJetInterval,
        computedTransformBumpJetCellIntervalUpTo12,
        computedTransformBumpCoordinateInterval,
        computedTransformBumpGlobalBoundUpTo12,
        explicitBumpGapInterval,
        computedPhasedBaseCoefficientQ,
        computedPhasedFrequencyQ, computedPhasedTranslationQ,
        rationalTrigInterval, RationalTrigInterval.expand,
        RationalTrigInterval.reconstruct, RationalTrigInterval.taylor,
        RationalTrigInterval.double, rationalCisTaylor,
        rationalCisMonomial, RationalComplex.mulArgI,
        RationalComplex.add, RationalComplex.scale,
        RationalComplex.zero, RationalComplex.one,
        rationalExpRemainder,
        RationalInterval.expand, RationalInterval.finSum,
        RationalInterval.scale, RationalInterval.pow,
        RationalInterval.mul, RationalInterval.sub,
        RationalInterval.add, RationalInterval.neg,
        RationalInterval.one, RationalInterval.zero,
        RationalInterval.singleton, RationalInterval.lower,
        RationalInterval.upper, finProdFinEquiv, Nat.choose]

theorem computedPhasedBaseGlobalRemainderOrder0Shard2Cache_eq :
    computedPhasedBaseGlobalRemainderOrder0Shard2Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder0Shard2Group := by
  rw [show computedPhasedBaseGlobalRemainderOrder0Shard2Group = computedPhasedBaseGlobalRemainderOrder0Shard2Groups from funext computedPhasedBaseGlobalRemainderOrder0Shard2Group_eq]
  change computedPhasedBaseGlobalRemainderOrder0Shard2Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shard2Groups (0 : Fin 5))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shard2Groups (1 : Fin 5))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shard2Groups (2 : Fin 5))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shard2Groups (3 : Fin 5))
            (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shard2Groups (4 : Fin 5))
              RationalInterval.zero))))
  rw [computedPhasedBaseGlobalRemainderOrder0Shard2Groups_0, computedPhasedBaseGlobalRemainderOrder0Shard2Groups_1, computedPhasedBaseGlobalRemainderOrder0Shard2Groups_2, computedPhasedBaseGlobalRemainderOrder0Shard2Groups_3, computedPhasedBaseGlobalRemainderOrder0Shard2Groups_4]
  norm_num (config := { maxSteps := 4000000 })
    [computedPhasedBaseGlobalRemainderOrder0Shard2Cache, RationalInterval.add,
      RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
