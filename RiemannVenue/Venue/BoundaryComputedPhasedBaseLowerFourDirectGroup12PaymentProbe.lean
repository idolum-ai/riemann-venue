theorem computedPhasedBaseLowerFourDirectGroup12Paired_contains (n : Fin 12) :
    (computedPhasedBaseLowerFourDirectGroup12Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerFourDirectGroup12Interval.center : ℝ)) := by
  rw [computedPhasedBaseLowerFourDirectGroup12Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseLowerFourDirectGroup12Jets
