    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseLowerFourDirectGroup12_remainder hx)

def computedPhasedBaseLowerFourDirectGroup12TaylorCenterQ : ℚ × ℚ :=
