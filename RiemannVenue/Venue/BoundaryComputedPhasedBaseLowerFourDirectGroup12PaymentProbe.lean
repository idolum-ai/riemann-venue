theorem computedPhasedBaseLowerFourDirectGroup12_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerFourDirectGroup12Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerFourDirectGroup12Interval]

noncomputable def computedPhasedBaseLowerFourDirectGroup12TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerFourDirectGroup12Interval (by norm_num [computedPhasedBaseLowerFourDirectGroup12Interval])
