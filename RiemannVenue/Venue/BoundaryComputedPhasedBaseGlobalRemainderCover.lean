def computedPhasedBaseGlobalRemainderEvaluatorTermQ (i : Fin 13) : ℚ :=
  16 * (Nat.choose 12 i *
    computedTransformIntervalAbsUpper
      (computedTransformBaseTestJetCellInterval 32 4 32 16 i
        computedPhasedBaseGlobalWindow) *
    15 ^ (12 - (i : Nat)))

theorem computedPhasedBaseGlobalRemainderEvaluatorTermQ_eq
    (i : Fin 13) :
    computedPhasedBaseGlobalRemainderEvaluatorTermQ i =
      computedPhasedBaseGlobalRemainderTermQ i := by
  rcases i with ⟨i, hi⟩
  interval_cases i
  · simp only [computedPhasedBaseGlobalRemainderEvaluatorTermQ,
      computedPhasedBaseGlobalRemainderTermQ]
    rw [← computedPhasedBaseGlobalRemainderOrder0Cache_eq]
    norm_num [
      computedPhasedBaseGlobalRemainderOrder0Cache,
      computedTransformIntervalAbsUpper, Nat.choose]
  · simp only [computedPhasedBaseGlobalRemainderEvaluatorTermQ,
      computedPhasedBaseGlobalRemainderTermQ]
    rw [← computedPhasedBaseGlobalRemainderOrder1Cache_eq]
    norm_num [
      computedPhasedBaseGlobalRemainderOrder1Cache,
      computedTransformIntervalAbsUpper, Nat.choose]
  · simp only [computedPhasedBaseGlobalRemainderEvaluatorTermQ,
      computedPhasedBaseGlobalRemainderTermQ]
    rw [← computedPhasedBaseGlobalRemainderOrder2Cache_eq]
    norm_num [
      computedPhasedBaseGlobalRemainderOrder2Cache,
      computedTransformIntervalAbsUpper, Nat.choose]
  · simp only [computedPhasedBaseGlobalRemainderEvaluatorTermQ,
      computedPhasedBaseGlobalRemainderTermQ]
    rw [← computedPhasedBaseGlobalRemainderOrder3Cache_eq]
    norm_num [
      computedPhasedBaseGlobalRemainderOrder3Cache,
      computedTransformIntervalAbsUpper, Nat.choose]
  · simp only [computedPhasedBaseGlobalRemainderEvaluatorTermQ,
      computedPhasedBaseGlobalRemainderTermQ]
    rw [← computedPhasedBaseGlobalRemainderOrder4Cache_eq]
    norm_num [
      computedPhasedBaseGlobalRemainderOrder4Cache,
      computedTransformIntervalAbsUpper, Nat.choose]
  · simp only [computedPhasedBaseGlobalRemainderEvaluatorTermQ,
