def computedPhasedBaseFullFiveDirectGroup1Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveDirectGroup1Group n b g

theorem computedPhasedBaseFullFiveDirectGroup1Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveDirectGroup1Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveCompactCell0Shard2Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveDirectGroup1Group_contains n b g

def computedPhasedBaseFullFiveDirectGroup1SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell0Shard2PointInterval where
  signed := computedPhasedBaseFullFiveDirectGroup1Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell0Shard2Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell0Shard2Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell0Shard2PointInterval, computedPhasedBaseFullFiveCompactCell0Shard2Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup1Signed_contains n b

def computedPhasedBaseFullFiveDirectGroup1BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell0Shard2PointInterval where
  bump := computedPhasedBaseFullFiveDirectGroup1Bump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell0Shard2Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell0Shard2Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell0Shard2PointInterval, computedPhasedBaseFullFiveCompactCell0Shard2Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup1Bump_contains b n

