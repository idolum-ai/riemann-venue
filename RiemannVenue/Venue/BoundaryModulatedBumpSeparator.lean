import RiemannVenue.Venue.BoundaryPaleyWienerGate

/-!
# Real modulation and quantitative spectral separation

Multiplication by a real cosine preserves the smooth compact test core.  Its
Fourier--Laplace transform is the average of two real-frequency translates.
Thus modulation can center a test at a prescribed real frequency, but the
real-test involution necessarily creates the reflected lobe as well.

The final lemmas isolate the exact quantitative condition under which this
two-lobe construction gives a strict modulus gap on an arbitrary competitor
set.  No decay estimate or assertion about the global zeta-zero set is hidden
in that condition.
-/

namespace RiemannVenue.Venue

open MeasureTheory

noncomputable section

namespace SmoothCompletedLogTest

/-- Real cosine modulation.  This shifts spectral mass in both real-frequency
directions, as required by the reflection law for real tests. -/
noncomputable def cosineModulate
    (h : SmoothCompletedLogTest) (omega : ℝ) : SmoothCompletedLogTest := by
  let f : ℝ → ℝ := fun t => Real.cos (omega * t) * h t
  refine ⟨CompletedLogTest.ofWeilTest f ?_ ?_, ?_⟩
  · fun_prop
  · exact h.hasCompactSupport.mul_left
  · change ContDiff ℝ (⊤ : ℕ∞) f
    exact (Real.contDiff_cos.comp
      (contDiff_const.mul contDiff_id)).mul h.2

@[simp] theorem cosineModulate_apply
    (h : SmoothCompletedLogTest) (omega t : ℝ) :
    h.cosineModulate omega t = Real.cos (omega * t) * h t := rfl

end SmoothCompletedLogTest

/-- Cosine modulation gives the exact symmetric two-shift formula. -/
theorem completedFourierLaplaceTransform_cosineModulate
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) :
    completedFourierLaplaceTransform (h.cosineModulate omega) z =
      (completedFourierLaplaceTransform h (z + (omega : ℂ)) +
        completedFourierLaplaceTransform h (z - (omega : ℂ))) / 2 := by
  let Fplus : ℝ → ℂ := fun t =>
    (h t : ℂ) * Complex.exp
      (Complex.I * (z + (omega : ℂ)) * (t : ℂ))
  let Fminus : ℝ → ℂ := fun t =>
    (h t : ℂ) * Complex.exp
      (Complex.I * (z - (omega : ℂ)) * (t : ℂ))
  have hplus : Integrable Fplus :=
    integrable_completedFourierLaplaceTransform h (z + (omega : ℂ))
  have hminus : Integrable Fminus :=
    integrable_completedFourierLaplaceTransform h (z - (omega : ℂ))
  have hint :
      (∫ t : ℝ, (Real.cos (omega * t) * h t : ℂ) *
          Complex.exp (Complex.I * z * (t : ℂ))) =
        ((∫ t : ℝ, Fplus t) + (∫ t : ℝ, Fminus t)) / 2 := by
    rw [← integral_add hplus hminus, ← integral_div]
    apply integral_congr_ae
    filter_upwards [] with t
    have hp :
        Complex.exp (Complex.I * (z + (omega : ℂ)) * (t : ℂ)) =
          Complex.exp (Complex.I * z * (t : ℂ)) *
            Complex.exp (((omega * t : ℝ) : ℂ) * Complex.I) := by
      rw [← Complex.exp_add]
      congr 1
      push_cast
      ring
    have hm :
        Complex.exp (Complex.I * (z - (omega : ℂ)) * (t : ℂ)) =
          Complex.exp (Complex.I * z * (t : ℂ)) *
            Complex.exp (-(((omega * t : ℝ) : ℂ) * Complex.I)) := by
      rw [← Complex.exp_add]
      congr 1
      push_cast
      ring
    simp only [Fplus, Fminus, hp, hm, Complex.ofReal_mul,
      Complex.ofReal_cos, Complex.cos]
    ring_nf
  rw [completedFourierLaplaceTransform,
    completedFourierLaplaceTransform,
    completedFourierLaplaceTransform]
  simp only [SmoothCompletedLogTest.cosineModulate_apply,
    Complex.ofReal_mul]
  change (1 / (2 * Real.pi) : ℂ) *
      (∫ t : ℝ, (Real.cos (omega * t) : ℂ) * (h t : ℂ) *
        Complex.exp (Complex.I * z * (t : ℂ))) = _
  rw [hint]
  ring

/-- The pair of lobes generated by cosine modulation. -/
noncomputable def cosineModulationShiftSum
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) : ℂ :=
  completedFourierLaplaceTransform h (z + (omega : ℂ)) +
    completedFourierLaplaceTransform h (z - (omega : ℂ))

theorem completedFourierLaplaceTransform_cosineModulate_eq_shiftSum
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) :
    completedFourierLaplaceTransform (h.cosineModulate omega) z =
      cosineModulationShiftSum h omega z / 2 := by
  exact completedFourierLaplaceTransform_cosineModulate h omega z

/-- Real modulation cannot distinguish a target from its real-test
reflection.  Their transform norms agree exactly. -/
theorem norm_completedFourierLaplaceTransform_cosineModulate_reflection
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) :
    ‖completedFourierLaplaceTransform (h.cosineModulate omega)
        (-starRingEnd ℂ z)‖ =
      ‖completedFourierLaplaceTransform (h.cosineModulate omega) z‖ := by
  rw [completedFourierLaplaceTransform_neg_conj, Complex.norm_conj]

/-- A strict gap against the reflected copy of the target is impossible for
every real test.  Any valid separator must target the whole reflection orbit
and place only points outside that orbit among its competitors. -/
theorem not_norm_completedFourierLaplaceTransform_cosineModulate_reflection_lt
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) :
    ¬ ‖completedFourierLaplaceTransform (h.cosineModulate omega)
          (-starRingEnd ℂ z)‖ <
        ‖completedFourierLaplaceTransform (h.cosineModulate omega) z‖ := by
  rw [norm_completedFourierLaplaceTransform_cosineModulate_reflection]
  exact lt_irrefl _

/-- Upper two-lobe estimate at any competitor. -/
theorem norm_completedFourierLaplaceTransform_cosineModulate_le
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) :
    ‖completedFourierLaplaceTransform (h.cosineModulate omega) z‖ ≤
      (‖completedFourierLaplaceTransform h (z + (omega : ℂ))‖ +
        ‖completedFourierLaplaceTransform h (z - (omega : ℂ))‖) / 2 := by
  rw [completedFourierLaplaceTransform_cosineModulate, norm_div]
  norm_num
  exact div_le_div_of_nonneg_right (norm_add_le _ _) (by norm_num)

/-- Reverse-triangle lower estimate at a target.  Either shifted lobe may be
chosen as the main lobe; this orientation takes `z - omega` as the main one. -/
theorem sub_norm_le_two_mul_norm_completedFourierLaplaceTransform_cosineModulate
    (h : SmoothCompletedLogTest) (omega : ℝ) (z : ℂ) :
    ‖completedFourierLaplaceTransform h (z - (omega : ℂ))‖ -
        ‖completedFourierLaplaceTransform h (z + (omega : ℂ))‖ ≤
      2 * ‖completedFourierLaplaceTransform (h.cosineModulate omega) z‖ := by
  have hreverse :
      ‖completedFourierLaplaceTransform h (z - (omega : ℂ))‖ -
          ‖completedFourierLaplaceTransform h (z + (omega : ℂ))‖ ≤
        ‖cosineModulationShiftSum h omega z‖ := by
    have htri := norm_sub_norm_le
      (completedFourierLaplaceTransform h (z - (omega : ℂ)))
      (-completedFourierLaplaceTransform h (z + (omega : ℂ)))
    rw [norm_neg, sub_neg_eq_add] at htri
    simpa only [cosineModulationShiftSum, add_comm] using htri
  have heq :
      2 * ‖completedFourierLaplaceTransform (h.cosineModulate omega) z‖ =
        ‖cosineModulationShiftSum h omega z‖ := by
    rw [completedFourierLaplaceTransform_cosineModulate_eq_shiftSum,
      norm_div]
    have hnormtwo : ‖(2 : ℂ)‖ = (2 : ℝ) := by norm_num
    rw [hnormtwo]
    ring
  linarith

/-- The exact quantitative gate for a cosine-modulated strict gap.

The target's main shifted lobe must dominate its reflected contamination and
both shifted lobes at every competitor.  This is the analytic estimate still
needed when `competitors` is the full zeta-zero set. -/
def CosineModulationStrictGapCondition
    (h : SmoothCompletedLogTest) (omega : ℝ) (target : ℂ)
    (competitors : Set ℂ) : Prop :=
  ∀ w ∈ competitors,
    ‖completedFourierLaplaceTransform h (w + (omega : ℂ))‖ +
        ‖completedFourierLaplaceTransform h (w - (omega : ℂ))‖ <
      ‖completedFourierLaplaceTransform h (target - (omega : ℂ))‖ -
        ‖completedFourierLaplaceTransform h (target + (omega : ℂ))‖

/-- The quantitative gate compiles to a strict global modulus gap on the
declared competitor set. -/
theorem cosineModulate_strictGap
    (h : SmoothCompletedLogTest) (omega : ℝ) (target : ℂ)
    (competitors : Set ℂ)
    (hgap : CosineModulationStrictGapCondition h omega target competitors) :
    ∀ w ∈ competitors,
      ‖completedFourierLaplaceTransform (h.cosineModulate omega) w‖ <
        ‖completedFourierLaplaceTransform (h.cosineModulate omega) target‖ := by
  intro w hw
  have hg := hgap w hw
  have hu := norm_completedFourierLaplaceTransform_cosineModulate_le h omega w
  have hl :=
    sub_norm_le_two_mul_norm_completedFourierLaplaceTransform_cosineModulate
      h omega target
  nlinarith

/-- Consequently, the quantitative gap condition itself certifies that the
reflected target was not accidentally included among the competitors. -/
theorem reflection_not_mem_of_cosineModulationStrictGapCondition
    (h : SmoothCompletedLogTest) (omega : ℝ) (target : ℂ)
    (competitors : Set ℂ)
    (hgap : CosineModulationStrictGapCondition h omega target competitors) :
    -starRingEnd ℂ target ∉ competitors := by
  intro hreflect
  have hstrict := cosineModulate_strictGap h omega target competitors hgap
    (-starRingEnd ℂ target) hreflect
  exact
    (not_norm_completedFourierLaplaceTransform_cosineModulate_reflection_lt
      h omega target) hstrict

/-- Centering at the real part of an off-axis target moves the main lobe onto
the imaginary axis and leaves the compulsory mirror lobe at twice the real
part. -/
theorem completedFourierLaplaceTransform_cosineModulate_realCenter
    (h : SmoothCompletedLogTest) (z : ℂ) :
    completedFourierLaplaceTransform (h.cosineModulate z.re) z =
      (completedFourierLaplaceTransform h
          ((2 * z.re : ℝ) + (z.im : ℂ) * Complex.I) +
        completedFourierLaplaceTransform h
          ((z.im : ℂ) * Complex.I)) / 2 := by
  rw [completedFourierLaplaceTransform_cosineModulate]
  congr 2
  · apply congrArg (completedFourierLaplaceTransform h)
    apply Complex.ext
    · simp
      ring
    · simp
  · apply congrArg (completedFourierLaplaceTransform h)
    apply Complex.ext <;> simp

end

end RiemannVenue.Venue
