def computedPhasedBaseLowerFourDirectTailInterval : RationalInterval :=
  ⟨(2683 : ℚ) / 896, (5 : ℚ) / 896⟩

theorem computedPhasedBaseLowerFourDirectTailInterval_center_eq_source :
    computedPhasedBaseLowerFourDirectTailInterval.center = computedPhasedBaseLowerFourTailInterval.center := by
  norm_num [computedPhasedBaseLowerFourDirectTailInterval, computedPhasedBaseLowerFourTailInterval]

def computedPhasedBaseLowerFourDirectTailPaired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseLowerFourDirectTailJets
    computedPhasedBaseLowerFourDirectTailForwardKernel computedPhasedBaseLowerFourDirectTailReflectedKernel n

theorem computedPhasedBaseLowerFourDirectTailPaired_contains (n : Fin 12) :
    (computedPhasedBaseLowerFourDirectTailPaired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerFourDirectTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseLowerFourDirectTailInterval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseLowerFourDirectTailJets
    computedPhasedBaseLowerFourDirectTailForwardKernel computedPhasedBaseLowerFourDirectTailReflectedKernel n
    computedPhasedBaseLowerFourDirectTailForwardKernel_contains computedPhasedBaseLowerFourDirectTailReflectedKernel_contains

theorem computedPhasedBaseLowerFourDirectTail_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerFourDirectTailInterval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerFourDirectTailInterval]

noncomputable def computedPhasedBaseLowerFourDirectTailTaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerFourDirectTailInterval (by norm_num [computedPhasedBaseLowerFourDirectTailInterval])
    computedPhasedBaseLowerFourDirectTailPaired computedPhasedBaseLowerFourDirectTailPaired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseLowerFourDirectTail_remainder hx)

def computedPhasedBaseLowerFourDirectTailTaylorCenterQ : ℚ × ℚ :=
  computedPhasedBaseOuterCachedShardTaylorCenterQ
    computedPhasedBaseLowerFourDirectTailPaired computedPhasedBaseLowerFourDirectTailInterval.radius

theorem computedPhasedBaseLowerFourDirectTailTaylorCell_centerQ :
    computedPhasedBaseLowerFourDirectTailTaylorCell.center =
      rationalPairToComplex computedPhasedBaseLowerFourDirectTailTaylorCenterQ := by
  rw [computedPhasedBaseLowerFourDirectTailTaylorCell,
    computedPhasedBaseOuterCachedShardTaylorCellWithRemainder_center,
    computedPhasedBaseOuterCachedShardTaylorCenter_eq_cast]
