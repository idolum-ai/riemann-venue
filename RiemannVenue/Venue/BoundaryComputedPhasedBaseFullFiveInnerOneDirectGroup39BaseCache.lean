      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell6Shard17Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell6Shard17PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell6Shard17Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
