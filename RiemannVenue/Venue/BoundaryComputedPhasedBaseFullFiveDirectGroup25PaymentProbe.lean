    computedPhasedBaseFullFiveDirectGroup25Interval.center = computedPhasedBaseFullFiveCompactCell4Shard2Interval.center := by
  norm_num [computedPhasedBaseFullFiveDirectGroup25Interval, computedPhasedBaseFullFiveCompactCell4Shard2Interval]

def computedPhasedBaseFullFiveDirectGroup25Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup25Jets
