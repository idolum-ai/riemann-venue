theorem computedPhasedBaseFullFiveDirectGroup25Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup25Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup25Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup25Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup25Jets
    computedPhasedBaseFullFiveDirectGroup25ForwardKernel computedPhasedBaseFullFiveDirectGroup25ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup25ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup25ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup25_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup25Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup25Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup25TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup25Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup25Interval])
    computedPhasedBaseFullFiveDirectGroup25Paired computedPhasedBaseFullFiveDirectGroup25Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup25_remainder hx)

def computedPhasedBaseFullFiveDirectGroup25TaylorCenterQ : ℚ × ℚ :=
