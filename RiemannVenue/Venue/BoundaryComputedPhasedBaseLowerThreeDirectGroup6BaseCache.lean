def computedPhasedBaseLowerThreeDirectGroup6Signed (n : Fin 12) (b : Fin 3) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseLowerThreeDirectGroup6Group n b g

theorem computedPhasedBaseLowerThreeDirectGroup6Signed_contains (n : Fin 12) (b : Fin 3) :
    (computedPhasedBaseLowerThreeDirectGroup6Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseLowerThreeModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseLowerThreeModel.column b g)
          (computedPhasedBaseLowerThreeCompactCell1Shard0Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseLowerThreeDirectGroup6Group_contains n b g

def computedPhasedBaseLowerThreeDirectGroup6SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseLowerThreeModel computedPhasedBaseLowerThreeCompactCell1Shard0PointInterval where
  signed := computedPhasedBaseLowerThreeDirectGroup6Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseLowerThreeCompactCell1Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseLowerThreeCompactCell1Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseLowerThreeCompactCell1Shard0PointInterval, computedPhasedBaseLowerThreeCompactCell1Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseLowerThreeDirectGroup6Signed_contains n b

def computedPhasedBaseLowerThreeDirectGroup6BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseLowerThreeModel computedPhasedBaseLowerThreeCompactCell1Shard0PointInterval where
  bump := computedPhasedBaseLowerThreeDirectGroup6Bump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseLowerThreeCompactCell1Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseLowerThreeCompactCell1Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseLowerThreeCompactCell1Shard0PointInterval, computedPhasedBaseLowerThreeCompactCell1Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseLowerThreeDirectGroup6Bump_contains b n

