def computedPhasedBaseFullFiveDirectGroup3Interval : RationalInterval :=
  ⟨(913 : ℚ) / 448, (3 : ℚ) / 448⟩

theorem computedPhasedBaseFullFiveDirectGroup3Interval_center_eq_source :
    computedPhasedBaseFullFiveDirectGroup3Interval.center = computedPhasedBaseFullFiveCompactCell0Shard8Interval.center := by
  norm_num [computedPhasedBaseFullFiveDirectGroup3Interval, computedPhasedBaseFullFiveCompactCell0Shard8Interval]

def computedPhasedBaseFullFiveDirectGroup3Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup3Jets
    computedPhasedBaseFullFiveDirectGroup3ForwardKernel computedPhasedBaseFullFiveDirectGroup3ReflectedKernel n

theorem computedPhasedBaseFullFiveDirectGroup3Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup3Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup3Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup3Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup3Jets
    computedPhasedBaseFullFiveDirectGroup3ForwardKernel computedPhasedBaseFullFiveDirectGroup3ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup3ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup3ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup3_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup3Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup3Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup3TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup3Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup3Interval])
    computedPhasedBaseFullFiveDirectGroup3Paired computedPhasedBaseFullFiveDirectGroup3Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup3_remainder hx)

def computedPhasedBaseFullFiveDirectGroup3TaylorCenterQ : ℚ × ℚ :=
  computedPhasedBaseOuterCachedShardTaylorCenterQ
    computedPhasedBaseFullFiveDirectGroup3Paired computedPhasedBaseFullFiveDirectGroup3Interval.radius

theorem computedPhasedBaseFullFiveDirectGroup3TaylorCell_centerQ :
    computedPhasedBaseFullFiveDirectGroup3TaylorCell.center =
      rationalPairToComplex computedPhasedBaseFullFiveDirectGroup3TaylorCenterQ := by
  rw [computedPhasedBaseFullFiveDirectGroup3TaylorCell,
    computedPhasedBaseOuterCachedShardTaylorCellWithRemainder_center,
    computedPhasedBaseOuterCachedShardTaylorCenter_eq_cast]
  rfl

