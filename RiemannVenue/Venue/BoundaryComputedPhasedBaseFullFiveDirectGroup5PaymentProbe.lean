def computedPhasedBaseFullFiveDirectGroup5Interval : RationalInterval :=
  ⟨(925 : ℚ) / 448, (3 : ℚ) / 448⟩

theorem computedPhasedBaseFullFiveDirectGroup5Interval_center_eq_source :
    computedPhasedBaseFullFiveDirectGroup5Interval.center = computedPhasedBaseFullFiveCompactCell0Shard14Interval.center := by
  norm_num [computedPhasedBaseFullFiveDirectGroup5Interval, computedPhasedBaseFullFiveCompactCell0Shard14Interval]

def computedPhasedBaseFullFiveDirectGroup5Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup5Jets
    computedPhasedBaseFullFiveDirectGroup5ForwardKernel computedPhasedBaseFullFiveDirectGroup5ReflectedKernel n

theorem computedPhasedBaseFullFiveDirectGroup5Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup5Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup5Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup5Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup5Jets
    computedPhasedBaseFullFiveDirectGroup5ForwardKernel computedPhasedBaseFullFiveDirectGroup5ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup5ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup5ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup5_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup5Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup5Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup5TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup5Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup5Interval])
    computedPhasedBaseFullFiveDirectGroup5Paired computedPhasedBaseFullFiveDirectGroup5Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup5_remainder hx)

def computedPhasedBaseFullFiveDirectGroup5TaylorCenterQ : ℚ × ℚ :=
  computedPhasedBaseOuterCachedShardTaylorCenterQ
    computedPhasedBaseFullFiveDirectGroup5Paired computedPhasedBaseFullFiveDirectGroup5Interval.radius

theorem computedPhasedBaseFullFiveDirectGroup5TaylorCell_centerQ :
    computedPhasedBaseFullFiveDirectGroup5TaylorCell.center =
      rationalPairToComplex computedPhasedBaseFullFiveDirectGroup5TaylorCenterQ := by
  rw [computedPhasedBaseFullFiveDirectGroup5TaylorCell,
    computedPhasedBaseOuterCachedShardTaylorCellWithRemainder_center,
    computedPhasedBaseOuterCachedShardTaylorCenter_eq_cast]
  rfl

