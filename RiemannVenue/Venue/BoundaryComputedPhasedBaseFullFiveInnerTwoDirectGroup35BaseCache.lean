      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell5Shard28Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell5Shard28PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell5Shard28Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
