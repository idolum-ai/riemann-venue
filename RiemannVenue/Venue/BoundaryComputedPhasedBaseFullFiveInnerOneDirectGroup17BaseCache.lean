    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerOneCompactCell2Shard14Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell2Shard14Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell2Shard14PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell2Shard14Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectGroup17Signed_contains n b

