  norm_num [computedPhasedBaseFullFiveDirectGroup36Interval, computedPhasedBaseFullFiveCompactCell6Shard2Interval]

def computedPhasedBaseFullFiveDirectGroup36Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup36Jets
