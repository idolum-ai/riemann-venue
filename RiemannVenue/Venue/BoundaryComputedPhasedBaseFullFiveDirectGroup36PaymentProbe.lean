theorem computedPhasedBaseFullFiveDirectGroup36Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup36Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup36Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup36Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup36Jets
    computedPhasedBaseFullFiveDirectGroup36ForwardKernel computedPhasedBaseFullFiveDirectGroup36ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup36ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup36ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup36_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup36Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup36Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup36TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup36Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup36Interval])
    computedPhasedBaseFullFiveDirectGroup36Paired computedPhasedBaseFullFiveDirectGroup36Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup36_remainder hx)

def computedPhasedBaseFullFiveDirectGroup36TaylorCenterQ : ℚ × ℚ :=
