def computedPhasedBaseLowerFourDirectGroup0Signed (n : Fin 12) (b : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseLowerFourDirectGroup0Group n b g

theorem computedPhasedBaseLowerFourDirectGroup0Signed_contains (n : Fin 12) (b : Fin 4) :
    (computedPhasedBaseLowerFourDirectGroup0Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseLowerFourModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseLowerFourModel.column b g)
          (computedPhasedBaseLowerFourCompactCell0Shard0Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseLowerFourDirectGroup0Group_contains n b g

def computedPhasedBaseLowerFourDirectGroup0SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseLowerFourModel computedPhasedBaseLowerFourCompactCell0Shard0PointInterval where
  signed := computedPhasedBaseLowerFourDirectGroup0Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseLowerFourCompactCell0Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseLowerFourCompactCell0Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseLowerFourCompactCell0Shard0PointInterval, computedPhasedBaseLowerFourCompactCell0Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseLowerFourDirectGroup0Signed_contains n b

def computedPhasedBaseLowerFourDirectGroup0BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseLowerFourModel computedPhasedBaseLowerFourCompactCell0Shard0PointInterval where
  bump := computedPhasedBaseLowerFourDirectGroup0Bump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseLowerFourCompactCell0Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseLowerFourCompactCell0Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseLowerFourCompactCell0Shard0PointInterval, computedPhasedBaseLowerFourCompactCell0Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseLowerFourDirectGroup0Bump_contains b n

