    computedPhasedBaseLowerThreeDirectTailInterval.center = computedPhasedBaseLowerThreeTailInterval.center := by
  norm_num [computedPhasedBaseLowerThreeDirectTailInterval, computedPhasedBaseLowerThreeTailInterval]

def computedPhasedBaseLowerThreeDirectTailPaired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseLowerThreeDirectTailJets
    computedPhasedBaseLowerThreeDirectTailForwardKernel computedPhasedBaseLowerThreeDirectTailReflectedKernel n

theorem computedPhasedBaseLowerThreeDirectTailPaired_contains (n : Fin 12) :
    (computedPhasedBaseLowerThreeDirectTailPaired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerThreeDirectTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseLowerThreeDirectTailInterval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseLowerThreeDirectTailJets
    computedPhasedBaseLowerThreeDirectTailForwardKernel computedPhasedBaseLowerThreeDirectTailReflectedKernel n
    computedPhasedBaseLowerThreeDirectTailForwardKernel_contains computedPhasedBaseLowerThreeDirectTailReflectedKernel_contains

theorem computedPhasedBaseLowerThreeDirectTail_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectTailInterval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectTailInterval]

noncomputable def computedPhasedBaseLowerThreeDirectTailTaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectTailInterval (by norm_num [computedPhasedBaseLowerThreeDirectTailInterval])
    computedPhasedBaseLowerThreeDirectTailPaired computedPhasedBaseLowerThreeDirectTailPaired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseLowerThreeDirectTail_remainder hx)

def computedPhasedBaseLowerThreeDirectTailTaylorCenterQ : ℚ × ℚ :=
