  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerOneCompactCell0Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell0Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell0Shard0PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell0Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectGroup0Signed_contains n b

