theorem computedPhasedBaseFullFiveDirectGroup37Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup37Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup37Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup37Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup37Jets
    computedPhasedBaseFullFiveDirectGroup37ForwardKernel computedPhasedBaseFullFiveDirectGroup37ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup37ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup37ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup37_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup37Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup37Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup37TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup37Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup37Interval])
    computedPhasedBaseFullFiveDirectGroup37Paired computedPhasedBaseFullFiveDirectGroup37Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup37_remainder hx)

def computedPhasedBaseFullFiveDirectGroup37TaylorCenterQ : ℚ × ℚ :=
