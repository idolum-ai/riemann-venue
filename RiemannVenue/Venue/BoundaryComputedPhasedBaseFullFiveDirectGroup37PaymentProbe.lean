    computedPhasedBaseFullFiveDirectGroup37Interval.center = computedPhasedBaseFullFiveCompactCell6Shard7Interval.center := by
  norm_num [computedPhasedBaseFullFiveDirectGroup37Interval, computedPhasedBaseFullFiveCompactCell6Shard7Interval]

def computedPhasedBaseFullFiveDirectGroup37Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup37Jets
