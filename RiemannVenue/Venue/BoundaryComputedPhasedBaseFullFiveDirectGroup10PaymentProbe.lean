theorem computedPhasedBaseFullFiveDirectGroup10_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup10Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup10Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup10TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup10Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup10Interval])
    computedPhasedBaseFullFiveDirectGroup10Paired computedPhasedBaseFullFiveDirectGroup10Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup10_remainder hx)

def computedPhasedBaseFullFiveDirectGroup10TaylorCenterQ : ℚ × ℚ :=
