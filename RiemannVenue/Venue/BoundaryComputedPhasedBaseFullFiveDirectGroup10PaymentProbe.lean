  norm_num [computedPhasedBaseFullFiveDirectGroup10Interval, computedPhasedBaseFullFiveCompactCell1Shard11Interval]

def computedPhasedBaseFullFiveDirectGroup10Paired (n : Fin 12) : RationalRectangle :=
