theorem computedPhasedBaseFullFiveDirectGroup10Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup10Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup10Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup10Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup10Jets
