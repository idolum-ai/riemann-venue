import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder1Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder1Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder1Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder1Shard3Cache

/-! # Exact global base-remainder cache, order 1 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder1Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder1Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder1Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder1Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder1Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder1Shards_0 :
    computedPhasedBaseGlobalRemainderOrder1Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder1Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder1Shards_1 :
    computedPhasedBaseGlobalRemainderOrder1Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder1Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder1Shards_2 :
    computedPhasedBaseGlobalRemainderOrder1Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder1Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder1Shards_3 :
    computedPhasedBaseGlobalRemainderOrder1Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder1Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder1ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 1 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder1Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder1ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder1ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder1Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder1Shard0Group = computedPhasedBaseGlobalRemainderOrder1Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder1Shards_0, computedPhasedBaseGlobalRemainderOrder1Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder1Shard1Group = computedPhasedBaseGlobalRemainderOrder1Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder1Shards_1, computedPhasedBaseGlobalRemainderOrder1Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder1Shard2Group = computedPhasedBaseGlobalRemainderOrder1Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder1Shards_2, computedPhasedBaseGlobalRemainderOrder1Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder1Shard3Group = computedPhasedBaseGlobalRemainderOrder1Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder1Shards_3, computedPhasedBaseGlobalRemainderOrder1Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder1Cache_eq :
    computedPhasedBaseGlobalRemainderOrder1Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 1 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder1Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder1ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder1ShardEvaluator = computedPhasedBaseGlobalRemainderOrder1Shards from funext computedPhasedBaseGlobalRemainderOrder1ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder1Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder1Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder1Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder1Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder1Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder1Shards_0, computedPhasedBaseGlobalRemainderOrder1Shards_1, computedPhasedBaseGlobalRemainderOrder1Shards_2, computedPhasedBaseGlobalRemainderOrder1Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder1Cache, computedPhasedBaseGlobalRemainderOrder1Shard0Cache, computedPhasedBaseGlobalRemainderOrder1Shard1Cache, computedPhasedBaseGlobalRemainderOrder1Shard2Cache, computedPhasedBaseGlobalRemainderOrder1Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
