theorem computedPhasedBaseLowerThreeDirectGroup12_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectGroup12Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectGroup12Interval]

noncomputable def computedPhasedBaseLowerThreeDirectGroup12TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectGroup12Interval (by norm_num [computedPhasedBaseLowerThreeDirectGroup12Interval])
