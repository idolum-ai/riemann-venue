      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell6Shard23Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell6Shard23PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell6Shard23Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
