      have hz : x - (computedPhasedBaseFullFiveInnerThreeCompactCell3Shard2Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerThreeCompactCell3Shard2PointInterval, computedPhasedBaseFullFiveInnerThreeCompactCell3Shard2Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerThreeDirectGroup19Signed_contains n b

