  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerFourCompactCell6Shard7Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerFourCompactCell6Shard7Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourCompactCell6Shard7PointInterval, computedPhasedBaseFullFiveInnerFourCompactCell6Shard7Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerFourDirectGroup37Signed_contains n b

