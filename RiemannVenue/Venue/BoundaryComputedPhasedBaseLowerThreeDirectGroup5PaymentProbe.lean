theorem computedPhasedBaseLowerThreeDirectGroup5_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectGroup5Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectGroup5Interval]

noncomputable def computedPhasedBaseLowerThreeDirectGroup5TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectGroup5Interval (by norm_num [computedPhasedBaseLowerThreeDirectGroup5Interval])
