    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerTwoCompactCell0Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell0Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell0Shard0PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell0Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerTwoDirectGroup0Signed_contains n b

