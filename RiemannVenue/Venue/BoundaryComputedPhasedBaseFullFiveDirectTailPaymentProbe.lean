def computedPhasedBaseFullFiveDirectTailInterval : RationalInterval :=
  ⟨(2235 : ℚ) / 896, (5 : ℚ) / 896⟩

theorem computedPhasedBaseFullFiveDirectTailInterval_center_eq_source :
    computedPhasedBaseFullFiveDirectTailInterval.center = computedPhasedBaseFullFiveTailInterval.center := by
  norm_num [computedPhasedBaseFullFiveDirectTailInterval, computedPhasedBaseFullFiveTailInterval]

def computedPhasedBaseFullFiveDirectTailPaired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectTailJets
    computedPhasedBaseFullFiveDirectTailForwardKernel computedPhasedBaseFullFiveDirectTailReflectedKernel n

theorem computedPhasedBaseFullFiveDirectTailPaired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectTailPaired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectTailInterval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectTailJets
    computedPhasedBaseFullFiveDirectTailForwardKernel computedPhasedBaseFullFiveDirectTailReflectedKernel n
    computedPhasedBaseFullFiveDirectTailForwardKernel_contains computedPhasedBaseFullFiveDirectTailReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectTail_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectTailInterval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectTailInterval]

noncomputable def computedPhasedBaseFullFiveDirectTailTaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectTailInterval (by norm_num [computedPhasedBaseFullFiveDirectTailInterval])
    computedPhasedBaseFullFiveDirectTailPaired computedPhasedBaseFullFiveDirectTailPaired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectTail_remainder hx)

def computedPhasedBaseFullFiveDirectTailTaylorCenterQ : ℚ × ℚ :=
  computedPhasedBaseOuterCachedShardTaylorCenterQ
    computedPhasedBaseFullFiveDirectTailPaired computedPhasedBaseFullFiveDirectTailInterval.radius

theorem computedPhasedBaseFullFiveDirectTailTaylorCell_centerQ :
    computedPhasedBaseFullFiveDirectTailTaylorCell.center =
      rationalPairToComplex computedPhasedBaseFullFiveDirectTailTaylorCenterQ := by
  rw [computedPhasedBaseFullFiveDirectTailTaylorCell,
    computedPhasedBaseOuterCachedShardTaylorCellWithRemainder_center,
    computedPhasedBaseOuterCachedShardTaylorCenter_eq_cast]
  rfl

