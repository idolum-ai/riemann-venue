def computedPhasedBaseFullFiveDirectGroup23Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveDirectGroup23Group n b g

theorem computedPhasedBaseFullFiveDirectGroup23Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveDirectGroup23Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveCompactCell3Shard14Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveDirectGroup23Group_contains n b g

def computedPhasedBaseFullFiveDirectGroup23SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell3Shard14PointInterval where
  signed := computedPhasedBaseFullFiveDirectGroup23Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell3Shard14Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell3Shard14Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell3Shard14PointInterval, computedPhasedBaseFullFiveCompactCell3Shard14Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup23Signed_contains n b

def computedPhasedBaseFullFiveDirectGroup23BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
