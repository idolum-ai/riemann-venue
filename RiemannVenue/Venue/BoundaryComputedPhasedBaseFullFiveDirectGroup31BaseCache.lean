      have hz : x - (computedPhasedBaseFullFiveCompactCell5Shard7Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell5Shard7PointInterval, computedPhasedBaseFullFiveCompactCell5Shard7Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup31Bump_contains b n

