import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder5Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder5Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder5Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder5Shard3Cache

/-! # Exact global base-remainder cache, order 5 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder5Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder5Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder5Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder5Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder5Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder5Shards_0 :
    computedPhasedBaseGlobalRemainderOrder5Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder5Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder5Shards_1 :
    computedPhasedBaseGlobalRemainderOrder5Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder5Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder5Shards_2 :
    computedPhasedBaseGlobalRemainderOrder5Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder5Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder5Shards_3 :
    computedPhasedBaseGlobalRemainderOrder5Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder5Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder5ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 5 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder5Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder5ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder5ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder5Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder5Shard0Group = computedPhasedBaseGlobalRemainderOrder5Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder5Shards_0, computedPhasedBaseGlobalRemainderOrder5Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder5Shard1Group = computedPhasedBaseGlobalRemainderOrder5Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder5Shards_1, computedPhasedBaseGlobalRemainderOrder5Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder5Shard2Group = computedPhasedBaseGlobalRemainderOrder5Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder5Shards_2, computedPhasedBaseGlobalRemainderOrder5Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder5Shard3Group = computedPhasedBaseGlobalRemainderOrder5Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder5Shards_3, computedPhasedBaseGlobalRemainderOrder5Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder5Cache_eq :
    computedPhasedBaseGlobalRemainderOrder5Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 5 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder5Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder5ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder5ShardEvaluator = computedPhasedBaseGlobalRemainderOrder5Shards from funext computedPhasedBaseGlobalRemainderOrder5ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder5Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder5Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder5Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder5Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder5Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder5Shards_0, computedPhasedBaseGlobalRemainderOrder5Shards_1, computedPhasedBaseGlobalRemainderOrder5Shards_2, computedPhasedBaseGlobalRemainderOrder5Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder5Cache, computedPhasedBaseGlobalRemainderOrder5Shard0Cache, computedPhasedBaseGlobalRemainderOrder5Shard1Cache, computedPhasedBaseGlobalRemainderOrder5Shard2Cache, computedPhasedBaseGlobalRemainderOrder5Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
