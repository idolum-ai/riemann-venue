    computedPhasedBaseLowerThreeDirectGroup32ForwardKernel_contains computedPhasedBaseLowerThreeDirectGroup32ReflectedKernel_contains

theorem computedPhasedBaseLowerThreeDirectGroup32_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectGroup32Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectGroup32Interval]

noncomputable def computedPhasedBaseLowerThreeDirectGroup32TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectGroup32Interval (by norm_num [computedPhasedBaseLowerThreeDirectGroup32Interval])
    computedPhasedBaseLowerThreeDirectGroup32Paired computedPhasedBaseLowerThreeDirectGroup32Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseLowerThreeDirectGroup32_remainder hx)

def computedPhasedBaseLowerThreeDirectGroup32TaylorCenterQ : ℚ × ℚ :=
