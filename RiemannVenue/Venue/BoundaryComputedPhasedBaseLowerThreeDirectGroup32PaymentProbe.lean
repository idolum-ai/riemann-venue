    computedPhasedBaseLowerThreeDirectGroup32Interval.center = computedPhasedBaseLowerThreeCompactCell5Shard12Interval.center := by
  norm_num [computedPhasedBaseLowerThreeDirectGroup32Interval, computedPhasedBaseLowerThreeCompactCell5Shard12Interval]

def computedPhasedBaseLowerThreeDirectGroup32Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseLowerThreeDirectGroup32Jets
