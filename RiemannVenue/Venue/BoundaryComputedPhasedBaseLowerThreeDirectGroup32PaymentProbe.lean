theorem computedPhasedBaseLowerThreeDirectGroup32Paired_contains (n : Fin 12) :
    (computedPhasedBaseLowerThreeDirectGroup32Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerThreeDirectGroup32Interval.center : ℝ)) := by
  rw [computedPhasedBaseLowerThreeDirectGroup32Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseLowerThreeDirectGroup32Jets
