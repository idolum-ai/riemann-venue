import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder8Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder8Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder8Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder8Shard3Cache

/-! # Exact global base-remainder cache, order 8 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder8Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder8Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder8Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder8Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder8Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder8Shards_0 :
    computedPhasedBaseGlobalRemainderOrder8Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder8Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder8Shards_1 :
    computedPhasedBaseGlobalRemainderOrder8Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder8Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder8Shards_2 :
    computedPhasedBaseGlobalRemainderOrder8Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder8Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder8Shards_3 :
    computedPhasedBaseGlobalRemainderOrder8Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder8Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder8ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 8 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder8Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder8ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder8ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder8Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder8Shard0Group = computedPhasedBaseGlobalRemainderOrder8Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder8Shards_0, computedPhasedBaseGlobalRemainderOrder8Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder8Shard1Group = computedPhasedBaseGlobalRemainderOrder8Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder8Shards_1, computedPhasedBaseGlobalRemainderOrder8Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder8Shard2Group = computedPhasedBaseGlobalRemainderOrder8Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder8Shards_2, computedPhasedBaseGlobalRemainderOrder8Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder8Shard3Group = computedPhasedBaseGlobalRemainderOrder8Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder8Shards_3, computedPhasedBaseGlobalRemainderOrder8Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder8Cache_eq :
    computedPhasedBaseGlobalRemainderOrder8Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 8 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder8Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder8ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder8ShardEvaluator = computedPhasedBaseGlobalRemainderOrder8Shards from funext computedPhasedBaseGlobalRemainderOrder8ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder8Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder8Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder8Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder8Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder8Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder8Shards_0, computedPhasedBaseGlobalRemainderOrder8Shards_1, computedPhasedBaseGlobalRemainderOrder8Shards_2, computedPhasedBaseGlobalRemainderOrder8Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder8Cache, computedPhasedBaseGlobalRemainderOrder8Shard0Cache, computedPhasedBaseGlobalRemainderOrder8Shard1Cache, computedPhasedBaseGlobalRemainderOrder8Shard2Cache, computedPhasedBaseGlobalRemainderOrder8Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
