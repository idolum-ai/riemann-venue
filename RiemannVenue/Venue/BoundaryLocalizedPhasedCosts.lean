import RiemannVenue.Venue.BoundaryLocalizedWeightedCosts

/-!
# Spatial phases and weighted costs for localized atoms

This module adds real translations to the localized two-lobe construction.
The Fourier--Laplace transform records translation by its exact exponential
character, so finite combinations are represented by a phased evaluation
matrix.  Translation also has an explicit exponential cost in the weighted
derivative majorants used on the completed critical strip.
-/

namespace RiemannVenue.Venue

open MeasureTheory
open scoped BigOperators

noncomputable section

/-- A localized two-lobe atom translated in the completed logarithmic
variable.  With the repository's convention, positive `a` sends `h(t)` to
`h(t + a)`. -/
noncomputable def translatedLocalizedTwoLobeSeed
    (s : ℝ) (hs : 0 < s) (omega a : ℝ) : SmoothCompletedLogTest :=
  (localizedTwoLobeSeed s hs omega).translate a

@[simp] theorem translatedLocalizedTwoLobeSeed_apply
    (s : ℝ) (hs : 0 < s) (omega a t : ℝ) :
    translatedLocalizedTwoLobeSeed s hs omega a t =
      localizedTwoLobeSeed s hs omega (t + a) := rfl

/-- Exact Fourier--Laplace phase generated by spatial translation of one
localized atom. -/
theorem completedFourierLaplaceTransform_translatedLocalizedTwoLobeSeed
    (s : ℝ) (hs : 0 < s) (omega a : ℝ) (z : ℂ) :
    completedFourierLaplaceTransform
        (translatedLocalizedTwoLobeSeed s hs omega a) z =
      Complex.exp (-Complex.I * z * (a : ℂ)) *
        completedFourierLaplaceTransform (localizedTwoLobeSeed s hs omega) z := by
  exact completedFourierLaplaceTransform_translate
    (localizedTwoLobeSeed s hs omega) a z

/-- The translation phase together with the exact two-lobe formula. -/
theorem completedFourierLaplaceTransform_translatedLocalizedTwoLobeSeed_explicit
    (s : ℝ) (hs : 0 < s) (omega a : ℝ) (z : ℂ) :
    completedFourierLaplaceTransform
        (translatedLocalizedTwoLobeSeed s hs omega a) z =
      Complex.exp (-Complex.I * z * (a : ℂ)) * ((s : ℂ) / 2) *
        (completedFourierLaplaceTransform canonicalSmoothBump
            ((s : ℂ) * (z + (omega : ℂ))) +
          completedFourierLaplaceTransform canonicalSmoothBump
            ((s : ℂ) * (z - (omega : ℂ)))) := by
  rw [completedFourierLaplaceTransform_translatedLocalizedTwoLobeSeed,
    completedFourierLaplaceTransform_localizedTwoLobeSeed]
  ring

/-- Rectangular evaluation matrix for localized atoms with independent
scales, carrier frequencies, and spatial phases. -/
noncomputable def localizedTwoLobePhasedEvaluationMatrix
    {rows cols : Type*} (points : rows → ℂ)
    (scales frequencies translations : cols → ℝ)
    (scale_pos : ∀ j, 0 < scales j) : Matrix rows cols ℂ :=
  fun i j => completedFourierLaplaceTransform
    (translatedLocalizedTwoLobeSeed
      (scales j) (scale_pos j) (frequencies j) (translations j))
    (points i)

/-- Finite real combination of independently translated localized atoms. -/
noncomputable def localizedTwoLobePhasedCombination
    {cols : Type*} [Fintype cols]
    (scales frequencies translations coefficients : cols → ℝ)
    (scale_pos : ∀ j, 0 < scales j) : SmoothCompletedLogTest :=
  SmoothCompletedLogTest.finiteRealCombination coefficients fun j =>
    translatedLocalizedTwoLobeSeed
      (scales j) (scale_pos j) (frequencies j) (translations j)

/-- Every phased matrix entry is the corresponding unphased localized entry
multiplied by the exact translation character. -/
theorem localizedTwoLobePhasedEvaluationMatrix_apply_phase
    {rows cols : Type*} (points : rows → ℂ)
    (scales frequencies translations : cols → ℝ)
    (scale_pos : ∀ j, 0 < scales j) (i : rows) (j : cols) :
    localizedTwoLobePhasedEvaluationMatrix points scales frequencies
        translations scale_pos i j =
      Complex.exp
          (-Complex.I * points i * (translations j : ℂ)) *
        localizedTwoLobeEvaluationMatrix
          points scales frequencies scale_pos i j := by
  rw [localizedTwoLobePhasedEvaluationMatrix,
    completedFourierLaplaceTransform_translatedLocalizedTwoLobeSeed]
  rfl

/-- Fully expanded phased matrix entry. -/
theorem localizedTwoLobePhasedEvaluationMatrix_apply
    {rows cols : Type*} (points : rows → ℂ)
    (scales frequencies translations : cols → ℝ)
    (scale_pos : ∀ j, 0 < scales j) (i : rows) (j : cols) :
    localizedTwoLobePhasedEvaluationMatrix points scales frequencies
        translations scale_pos i j =
      Complex.exp
          (-Complex.I * points i * (translations j : ℂ)) *
        ((scales j : ℂ) / 2) *
        (completedFourierLaplaceTransform canonicalSmoothBump
            ((scales j : ℂ) * (points i + (frequencies j : ℂ))) +
          completedFourierLaplaceTransform canonicalSmoothBump
            ((scales j : ℂ) * (points i - (frequencies j : ℂ)))) := by
  rw [localizedTwoLobePhasedEvaluationMatrix_apply_phase,
    localizedTwoLobeEvaluationMatrix_apply]
  ring

/-- Exact transform law for a finite phased combination at an arbitrary
complex frequency. -/
theorem completedFourierLaplaceTransform_localizedTwoLobePhasedCombination
    {cols : Type*} [Fintype cols]
    (scales frequencies translations coefficients : cols → ℝ)
    (scale_pos : ∀ j, 0 < scales j) (z : ℂ) :
    completedFourierLaplaceTransform
        (localizedTwoLobePhasedCombination scales frequencies translations
          coefficients scale_pos) z =
      ∑ j, (coefficients j : ℂ) *
        Complex.exp (-Complex.I * z * (translations j : ℂ)) *
          completedFourierLaplaceTransform
            (localizedTwoLobeSeed
              (scales j) (scale_pos j) (frequencies j)) z := by
  rw [localizedTwoLobePhasedCombination,
    completedFourierLaplaceTransform_finiteRealCombination]
  apply Finset.sum_congr rfl
  intro j _
  rw [completedFourierLaplaceTransform_translatedLocalizedTwoLobeSeed]
  ring

/-- At the sampled points, the finite-combination transform is exactly
matrix multiplication by the phased evaluation matrix. -/
theorem completedFourierLaplaceTransform_localizedTwoLobePhasedCombination_matrix
    {rows cols : Type*} [Fintype cols]
    (points : rows → ℂ)
    (scales frequencies translations coefficients : cols → ℝ)
    (scale_pos : ∀ j, 0 < scales j) (i : rows) :
    completedFourierLaplaceTransform
        (localizedTwoLobePhasedCombination scales frequencies translations
          coefficients scale_pos) (points i) =
      ∑ j, (coefficients j : ℂ) *
        localizedTwoLobePhasedEvaluationMatrix points scales frequencies
          translations scale_pos i j := by
  rw [localizedTwoLobePhasedCombination,
    completedFourierLaplaceTransform_finiteRealCombination]
  rfl

private theorem iterDeriv_translate_apply
    (n : ℕ) (h : SmoothCompletedLogTest) (a t : ℝ) :
    (h.translate a).iterDeriv n t = h.iterDeriv n (t + a) := by
  induction n generalizing t with
  | zero => rfl
  | succ n ih =>
      rw [SmoothCompletedLogTest.iterDeriv_succ,
        SmoothCompletedLogTest.iterDeriv_succ,
        SmoothCompletedLogTest.deriv_apply]
      have hfun : (h.translate a).iterDeriv n =
          fun x : ℝ => h.iterDeriv n (x + a) := by
        funext x
        exact ih x
      rw [hfun, deriv_comp_add_const]
      exact (SmoothCompletedLogTest.deriv_apply (h.iterDeriv n) (t + a)).symm

private theorem integrable_derivativeEnvelope
    (n : ℕ) (h : SmoothCompletedLogTest) :
    Integrable (fun t : ℝ =>
      ‖(h.iterDeriv n t : ℂ)‖ * Real.exp (|t| / 2)) := by
  apply Continuous.integrable_of_hasCompactSupport
  · fun_prop
  · exact (h.iterDeriv n).hasCompactSupport.mono fun t ht hzero =>
      ht (by simpa using hzero)

/-- Translation by `a` increases every weighted derivative majorant by at
most `exp (|a| / 2)`. -/
theorem completedZeroTransformDerivativeMajorant_translate_le
    (n : ℕ) (h : SmoothCompletedLogTest) (a : ℝ) :
    completedZeroTransformDerivativeMajorant n (h.translate a) ≤
      Real.exp (|a| / 2) *
        completedZeroTransformDerivativeMajorant n h := by
  let E : ℝ → ℝ := fun y =>
    ‖(h.iterDeriv n y : ℂ)‖ * Real.exp (|y| / 2)
  have hshift : (∫ t : ℝ, E (t + a)) = ∫ y : ℝ, E y :=
    MeasureTheory.integral_add_right_eq_self E a
  have hEcompact : HasCompactSupport E := by
    apply (h.iterDeriv n).hasCompactSupport.mono
    intro t ht hzero
    apply ht
    simp [E, hzero]
  have hupper : Integrable (fun t : ℝ =>
      Real.exp (|a| / 2) * E (t + a)) := by
    apply Continuous.integrable_of_hasCompactSupport
    · have hEcontinuous : Continuous E := by
        fun_prop
      exact continuous_const.mul
        (hEcontinuous.comp (continuous_id.add continuous_const))
    · have hEshiftCompact : HasCompactSupport (fun t : ℝ => E (t + a)) := by
        change HasCompactSupport (E ∘ Homeomorph.addRight a)
        exact hEcompact.comp_homeomorph (Homeomorph.addRight a)
      exact hEshiftCompact.mul_left
  have hpoint (t : ℝ) :
      ‖((h.translate a).iterDeriv n t : ℂ)‖ * Real.exp (|t| / 2) ≤
        Real.exp (|a| / 2) * E (t + a) := by
    rw [iterDeriv_translate_apply]
    dsimp only [E]
    have habs : |t| ≤ |a| + |t + a| := by
      calc
        |t| = |(t + a) - a| := by ring_nf
        _ ≤ |t + a| + |a| := abs_sub _ _
        _ = |a| + |t + a| := add_comm _ _
    have hexp : Real.exp (|t| / 2) ≤
        Real.exp (|a| / 2) * Real.exp (|t + a| / 2) := by
      rw [← Real.exp_add]
      exact Real.exp_le_exp.mpr (by linarith)
    calc
      ‖(h.iterDeriv n (t + a) : ℂ)‖ * Real.exp (|t| / 2) ≤
          ‖(h.iterDeriv n (t + a) : ℂ)‖ *
            (Real.exp (|a| / 2) * Real.exp (|t + a| / 2)) :=
        mul_le_mul_of_nonneg_left hexp (norm_nonneg _)
      _ = Real.exp (|a| / 2) *
          (‖(h.iterDeriv n (t + a) : ℂ)‖ *
            Real.exp (|t + a| / 2)) := by ring
  have hint :
      (∫ t : ℝ,
        ‖((h.translate a).iterDeriv n t : ℂ)‖ * Real.exp (|t| / 2)) ≤
        Real.exp (|a| / 2) * ∫ y : ℝ, E y := by
    calc
      _ ≤ ∫ t : ℝ, Real.exp (|a| / 2) * E (t + a) :=
        integral_mono
          (integrable_derivativeEnvelope n (h.translate a)) hupper hpoint
      _ = Real.exp (|a| / 2) * ∫ t : ℝ, E (t + a) :=
        integral_const_mul _ _
      _ = Real.exp (|a| / 2) * ∫ y : ℝ, E y := by rw [hshift]
  rw [completedZeroTransformDerivativeMajorant,
    completedZeroTransformDerivativeMajorant]
  calc
    (1 / (2 * Real.pi)) *
        (∫ t : ℝ,
          ‖((h.translate a).iterDeriv n t : ℂ)‖ * Real.exp (|t| / 2)) ≤
      (1 / (2 * Real.pi)) *
        (Real.exp (|a| / 2) * ∫ y : ℝ, E y) :=
      mul_le_mul_of_nonneg_left hint (by positivity)
    _ = Real.exp (|a| / 2) *
        ((1 / (2 * Real.pi)) * ∫ y : ℝ, E y) := by ring

/-- Specialized weighted derivative-cost bound for a translated localized
two-lobe atom. -/
theorem completedZeroTransformDerivativeMajorant_translatedLocalizedTwoLobeSeed_le
    (n : ℕ) (s : ℝ) (hs : 0 < s) (omega a : ℝ) :
    completedZeroTransformDerivativeMajorant n
        (translatedLocalizedTwoLobeSeed s hs omega a) ≤
      Real.exp (|a| / 2) *
        completedZeroTransformDerivativeMajorant n
          (localizedTwoLobeSeed s hs omega) := by
  exact completedZeroTransformDerivativeMajorant_translate_le n
    (localizedTwoLobeSeed s hs omega) a

end

end RiemannVenue.Venue
