def computedPhasedBaseFullFiveDirectGroup28Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveDirectGroup28Group n b g

theorem computedPhasedBaseFullFiveDirectGroup28Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveDirectGroup28Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveCompactCell4Shard11Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveDirectGroup28Group_contains n b g

def computedPhasedBaseFullFiveDirectGroup28SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell4Shard11PointInterval where
  signed := computedPhasedBaseFullFiveDirectGroup28Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell4Shard11Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell4Shard11Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell4Shard11PointInterval, computedPhasedBaseFullFiveCompactCell4Shard11Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup28Signed_contains n b

def computedPhasedBaseFullFiveDirectGroup28BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
