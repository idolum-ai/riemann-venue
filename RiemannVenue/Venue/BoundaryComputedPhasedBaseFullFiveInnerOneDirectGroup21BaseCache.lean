  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerOneCompactCell3Shard8Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell3Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell3Shard8PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell3Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectGroup21Signed_contains n b

