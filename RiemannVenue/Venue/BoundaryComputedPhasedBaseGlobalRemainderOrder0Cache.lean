import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder0Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder0Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder0Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder0Shard3Cache

/-! # Exact global base-remainder cache, order 0 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder0Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder0Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder0Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder0Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder0Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shards_0 :
    computedPhasedBaseGlobalRemainderOrder0Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder0Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shards_1 :
    computedPhasedBaseGlobalRemainderOrder0Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder0Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shards_2 :
    computedPhasedBaseGlobalRemainderOrder0Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder0Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder0Shards_3 :
    computedPhasedBaseGlobalRemainderOrder0Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder0Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder0ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 0 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder0Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder0ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder0ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder0Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder0Shard0Group = computedPhasedBaseGlobalRemainderOrder0Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder0Shards_0, computedPhasedBaseGlobalRemainderOrder0Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder0Shard1Group = computedPhasedBaseGlobalRemainderOrder0Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder0Shards_1, computedPhasedBaseGlobalRemainderOrder0Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder0Shard2Group = computedPhasedBaseGlobalRemainderOrder0Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder0Shards_2, computedPhasedBaseGlobalRemainderOrder0Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder0Shard3Group = computedPhasedBaseGlobalRemainderOrder0Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder0Shards_3, computedPhasedBaseGlobalRemainderOrder0Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder0Cache_eq :
    computedPhasedBaseGlobalRemainderOrder0Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 0 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder0Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder0ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder0ShardEvaluator = computedPhasedBaseGlobalRemainderOrder0Shards from funext computedPhasedBaseGlobalRemainderOrder0ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder0Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder0Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder0Shards_0, computedPhasedBaseGlobalRemainderOrder0Shards_1, computedPhasedBaseGlobalRemainderOrder0Shards_2, computedPhasedBaseGlobalRemainderOrder0Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder0Cache, computedPhasedBaseGlobalRemainderOrder0Shard0Cache, computedPhasedBaseGlobalRemainderOrder0Shard1Cache, computedPhasedBaseGlobalRemainderOrder0Shard2Cache, computedPhasedBaseGlobalRemainderOrder0Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
