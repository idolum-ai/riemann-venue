      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell4Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell4Shard8PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell4Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
