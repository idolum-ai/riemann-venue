theorem computedPhasedBaseLowerThreeDirectGroup3Paired_contains (n : Fin 12) :
    (computedPhasedBaseLowerThreeDirectGroup3Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerThreeDirectGroup3Interval.center : ℝ)) := by
  rw [computedPhasedBaseLowerThreeDirectGroup3Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseLowerThreeDirectGroup3Jets
