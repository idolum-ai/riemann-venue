theorem computedPhasedBaseLowerThreeDirectGroup3_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectGroup3Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectGroup3Interval]

noncomputable def computedPhasedBaseLowerThreeDirectGroup3TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectGroup3Interval (by norm_num [computedPhasedBaseLowerThreeDirectGroup3Interval])
    computedPhasedBaseLowerThreeDirectGroup3Paired computedPhasedBaseLowerThreeDirectGroup3Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseLowerThreeDirectGroup3_remainder hx)

def computedPhasedBaseLowerThreeDirectGroup3TaylorCenterQ : ℚ × ℚ :=
