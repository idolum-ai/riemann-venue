theorem computedPhasedBaseFullFiveDirectGroup7Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup7Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup7Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup7Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup7Jets
