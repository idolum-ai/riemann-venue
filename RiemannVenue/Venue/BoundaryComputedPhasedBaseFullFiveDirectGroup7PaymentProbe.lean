theorem computedPhasedBaseFullFiveDirectGroup7_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup7Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup7Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup7TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup7Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup7Interval])
    computedPhasedBaseFullFiveDirectGroup7Paired computedPhasedBaseFullFiveDirectGroup7Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup7_remainder hx)

def computedPhasedBaseFullFiveDirectGroup7TaylorCenterQ : ℚ × ℚ :=
