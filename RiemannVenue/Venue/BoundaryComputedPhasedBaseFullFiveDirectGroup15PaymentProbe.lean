theorem computedPhasedBaseFullFiveDirectGroup15Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup15Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup15Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup15Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup15Jets
    computedPhasedBaseFullFiveDirectGroup15ForwardKernel computedPhasedBaseFullFiveDirectGroup15ReflectedKernel n
    computedPhasedBaseFullFiveDirectGroup15ForwardKernel_contains computedPhasedBaseFullFiveDirectGroup15ReflectedKernel_contains

theorem computedPhasedBaseFullFiveDirectGroup15_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup15Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup15Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup15TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup15Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup15Interval])
    computedPhasedBaseFullFiveDirectGroup15Paired computedPhasedBaseFullFiveDirectGroup15Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup15_remainder hx)

def computedPhasedBaseFullFiveDirectGroup15TaylorCenterQ : ℚ × ℚ :=
