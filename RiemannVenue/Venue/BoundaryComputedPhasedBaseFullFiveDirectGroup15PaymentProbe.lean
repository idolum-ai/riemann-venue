    computedPhasedBaseFullFiveDirectGroup15Interval.center = computedPhasedBaseFullFiveCompactCell2Shard8Interval.center := by
  norm_num [computedPhasedBaseFullFiveDirectGroup15Interval, computedPhasedBaseFullFiveCompactCell2Shard8Interval]

def computedPhasedBaseFullFiveDirectGroup15Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup15Jets
