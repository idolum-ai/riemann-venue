import RiemannVenue.Venue.BoundarySpectralGlobalGap

/-!
# Canonical multiplicity-expanded zero orbits

The autocorrelation coefficient is even and conjugation-equivariant in its
frequency.  This file packages the complete finite target forced by those two
symmetries without choosing maps between zeta-zero subtypes: start with the
four frequency points `z`, `-z`, `conj z`, and `-conj z`, then retain every
multiplicity-expanded zero index whose frequency is one of those points.

The definition is implemented as a filter of a bounded zero window.  The
window is not an extra restriction: the real part of the spectral frequency
is the ordinate of the underlying zero, so every index over the four-point
orbit automatically lies in the window of radius `‖z‖`.
-/

namespace RiemannVenue.Venue

noncomputable section

local instance canonicalZeroOrbitDecidableEq :
    DecidableEq CompletedZetaZeroIndex := Classical.decEq _

/-- The finite frequency orbit generated by sign and complex conjugation.
Degenerate coincidences are collapsed by the finset. -/
noncomputable def canonicalCompletedFrequencyOrbit (z : ℂ) : Finset ℂ :=
  {z, -z, starRingEnd ℂ z, -(starRingEnd ℂ z)}

@[simp] theorem mem_canonicalCompletedFrequencyOrbit_self (z : ℂ) :
    z ∈ canonicalCompletedFrequencyOrbit z := by
  simp [canonicalCompletedFrequencyOrbit]

theorem canonicalCompletedFrequencyOrbit_neg_mem_iff (z w : ℂ) :
    -w ∈ canonicalCompletedFrequencyOrbit z ↔
      w ∈ canonicalCompletedFrequencyOrbit z := by
  simp only [canonicalCompletedFrequencyOrbit, Finset.mem_insert,
    Finset.mem_singleton]
  constructor <;> intro h
  · rcases h with h | h | h | h
    · exact Or.inr (Or.inl (neg_eq_iff_eq_neg.mp h))
    · exact Or.inl (neg_injective h)
    · exact Or.inr (Or.inr (Or.inr (neg_eq_iff_eq_neg.mp h)))
    · exact Or.inr (Or.inr (Or.inl (neg_injective h)))
  · rcases h with h | h | h | h
    · exact Or.inr (Or.inl (congrArg Neg.neg h))
    · exact Or.inl (neg_eq_iff_eq_neg.mpr h)
    · exact Or.inr (Or.inr (Or.inr (congrArg Neg.neg h)))
    · exact Or.inr (Or.inr (Or.inl (neg_eq_iff_eq_neg.mpr h)))

theorem canonicalCompletedFrequencyOrbit_conj_mem_iff (z w : ℂ) :
    starRingEnd ℂ w ∈ canonicalCompletedFrequencyOrbit z ↔
      w ∈ canonicalCompletedFrequencyOrbit z := by
  simp only [canonicalCompletedFrequencyOrbit, Finset.mem_insert,
    Finset.mem_singleton]
  constructor <;> intro h
  · rcases h with h | h | h | h
    · exact Or.inr (Or.inr (Or.inl (by
        simpa using congrArg (starRingEnd ℂ) h)))
    · exact Or.inr (Or.inr (Or.inr (by
        simpa using congrArg (starRingEnd ℂ) h)))
    · exact Or.inl (by simpa using congrArg (starRingEnd ℂ) h)
    · exact Or.inr (Or.inl (by
        simpa using congrArg (starRingEnd ℂ) h))
  · rcases h with h | h | h | h
    · exact Or.inr (Or.inr (Or.inl (by simp [h])))
    · exact Or.inr (Or.inr (Or.inr (by simp [h])))
    · exact Or.inl (by simp [h])
    · exact Or.inr (Or.inl (by simp [h]))

/-- Every point in the canonical four-frequency orbit has the same norm as
the generating point. -/
theorem norm_eq_of_mem_canonicalCompletedFrequencyOrbit
    {z w : ℂ} (hw : w ∈ canonicalCompletedFrequencyOrbit z) :
    ‖w‖ = ‖z‖ := by
  simp only [canonicalCompletedFrequencyOrbit, Finset.mem_insert,
    Finset.mem_singleton] at hw
  rcases hw with rfl | rfl | rfl | rfl
  · rfl
  · exact norm_neg _
  · exact Complex.norm_conj z
  · rw [norm_neg, Complex.norm_conj]

/-- Every zero whose frequency belongs to the canonical orbit lies in the
bounded-height window used to define the target. -/
theorem completedZetaZeroIndex_mem_window_of_frequency_mem_orbit
    {z : ℂ} (rho : CompletedZetaZeroIndex)
    (hrho : completedZetaZeroFrequency rho.1 ∈
      canonicalCompletedFrequencyOrbit z) :
    rho ∈ completedZetaZeroIndexWindowFinset ‖z‖ := by
  rw [mem_completedZetaZeroIndexWindowFinset]
  rw [← completedZetaZeroFrequency_re]
  calc
    |(completedZetaZeroFrequency rho.1).re| ≤
        ‖completedZetaZeroFrequency rho.1‖ := Complex.abs_re_le_norm _
    _ = ‖z‖ := norm_eq_of_mem_canonicalCompletedFrequencyOrbit hrho

/-- The complete multiplicity-expanded target over the four frequency points
generated by `z`. -/
noncomputable def canonicalCompletedZeroOrbit (z : ℂ) :
    Finset CompletedZetaZeroIndex :=
  (completedZetaZeroIndexWindowFinset ‖z‖).filter fun rho =>
    completedZetaZeroFrequency rho.1 ∈ canonicalCompletedFrequencyOrbit z

/-- Membership is exactly frequency membership.  In particular, the bounded
window used in the implementation does not truncate an orbit. -/
@[simp] theorem mem_canonicalCompletedZeroOrbit_iff
    {z : ℂ} {rho : CompletedZetaZeroIndex} :
    rho ∈ canonicalCompletedZeroOrbit z ↔
      completedZetaZeroFrequency rho.1 ∈
        canonicalCompletedFrequencyOrbit z := by
  rw [canonicalCompletedZeroOrbit, Finset.mem_filter]
  constructor
  · exact And.right
  · intro hrho
    exact ⟨completedZetaZeroIndex_mem_window_of_frequency_mem_orbit rho hrho,
      hrho⟩

/-- Every multiplicity copy of the distinguished zero belongs to the orbit
generated by its frequency. -/
theorem sigma_mem_canonicalCompletedZeroOrbit
    (rho0 : nontrivialRiemannZetaZeros)
    (j : Fin (completedZetaZeroMultiplicity rho0)) :
    Sigma.mk rho0 j ∈
      canonicalCompletedZeroOrbit (completedZetaZeroFrequency rho0) := by
  apply (mem_canonicalCompletedZeroOrbit_iff
    (z := completedZetaZeroFrequency rho0)
    (rho := (⟨rho0, j⟩ : CompletedZetaZeroIndex))).2
  change completedZetaZeroFrequency rho0 ∈
    canonicalCompletedFrequencyOrbit (completedZetaZeroFrequency rho0)
  exact mem_canonicalCompletedFrequencyOrbit_self _

/-- Positivity of analytic multiplicity supplies a distinguished index in
the canonical target. -/
theorem canonicalCompletedZeroOrbit_distinguished_mem
    (rho0 : nontrivialRiemannZetaZeros) :
    ∃ j : Fin (completedZetaZeroMultiplicity rho0),
      Sigma.mk rho0 j ∈
        canonicalCompletedZeroOrbit (completedZetaZeroFrequency rho0) := by
  let j : Fin (completedZetaZeroMultiplicity rho0) :=
    ⟨0, completedZetaZeroMultiplicity_pos rho0⟩
  exact ⟨j, sigma_mem_canonicalCompletedZeroOrbit rho0 j⟩

theorem canonicalCompletedZeroOrbit_nonempty
    (rho0 : nontrivialRiemannZetaZeros) :
    (canonicalCompletedZeroOrbit
      (completedZetaZeroFrequency rho0)).Nonempty := by
  obtain ⟨j, hj⟩ := canonicalCompletedZeroOrbit_distinguished_mem rho0
  exact ⟨Sigma.mk rho0 j, hj⟩

/-- Equal-frequency multiplicity copies cannot escape the canonical target. -/
theorem canonicalCompletedZeroOrbit_complete_of_frequency_eq
    {z : ℂ} {rho sigma : CompletedZetaZeroIndex}
    (hrho : rho ∈ canonicalCompletedZeroOrbit z)
    (hfrequency : completedZetaZeroFrequency sigma.1 =
      completedZetaZeroFrequency rho.1) :
    sigma ∈ canonicalCompletedZeroOrbit z := by
  rw [mem_canonicalCompletedZeroOrbit_iff] at hrho ⊢
  rwa [hfrequency]

/-- The target is complete under every actual sign-reflected frequency that
occurs in the multiplicity-expanded zero index. -/
theorem canonicalCompletedZeroOrbit_complete_of_frequency_eq_neg
    {z : ℂ} {rho sigma : CompletedZetaZeroIndex}
    (hrho : rho ∈ canonicalCompletedZeroOrbit z)
    (hfrequency : completedZetaZeroFrequency sigma.1 =
      -completedZetaZeroFrequency rho.1) :
    sigma ∈ canonicalCompletedZeroOrbit z := by
  rw [mem_canonicalCompletedZeroOrbit_iff] at hrho ⊢
  rw [hfrequency]
  exact (canonicalCompletedFrequencyOrbit_neg_mem_iff z _).2 hrho

/-- The target is complete under every actual conjugate-reflected frequency
that occurs in the multiplicity-expanded zero index. -/
theorem canonicalCompletedZeroOrbit_complete_of_frequency_eq_conj
    {z : ℂ} {rho sigma : CompletedZetaZeroIndex}
    (hrho : rho ∈ canonicalCompletedZeroOrbit z)
    (hfrequency : completedZetaZeroFrequency sigma.1 =
      starRingEnd ℂ (completedZetaZeroFrequency rho.1)) :
    sigma ∈ canonicalCompletedZeroOrbit z := by
  rw [mem_canonicalCompletedZeroOrbit_iff] at hrho ⊢
  rw [hfrequency]
  exact (canonicalCompletedFrequencyOrbit_conj_mem_iff z _).2 hrho

/-- The target is complete under the composite sign-conjugation symmetry. -/
theorem canonicalCompletedZeroOrbit_complete_of_frequency_eq_neg_conj
    {z : ℂ} {rho sigma : CompletedZetaZeroIndex}
    (hrho : rho ∈ canonicalCompletedZeroOrbit z)
    (hfrequency : completedZetaZeroFrequency sigma.1 =
      -(starRingEnd ℂ (completedZetaZeroFrequency rho.1))) :
    sigma ∈ canonicalCompletedZeroOrbit z := by
  rw [mem_canonicalCompletedZeroOrbit_iff] at hrho ⊢
  rw [hfrequency]
  exact (canonicalCompletedFrequencyOrbit_neg_mem_iff z _).2
    ((canonicalCompletedFrequencyOrbit_conj_mem_iff z _).2 hrho)

/-- Prescribing one common coefficient norm compatibly on the four frequency
points gives that norm to every multiplicity-expanded index in the canonical
target. -/
theorem norm_completedZeroAutocorrelationCoefficient_eq_of_orbit_values
    (h : SmoothCompletedLogTest) (z : ℂ) (M : ℝ)
    (hvalues : ∀ w ∈ canonicalCompletedFrequencyOrbit z,
      ‖completedAutocorrelationProduct h w‖ = M)
    (rho : CompletedZetaZeroIndex)
    (hrho : rho ∈ canonicalCompletedZeroOrbit z) :
    ‖completedZeroAutocorrelationCoefficient h rho‖ = M := by
  apply hvalues (completedZetaZeroFrequency rho.1)
  exact (mem_canonicalCompletedZeroOrbit_iff.mp hrho)

/-- In fact the autocorrelation symmetries themselves force equal norms over
the canonical frequency orbit once the value at the generator is fixed. -/
theorem norm_completedAutocorrelationProduct_eq_of_mem_canonicalOrbit
    (h : SmoothCompletedLogTest) {z w : ℂ}
    (hw : w ∈ canonicalCompletedFrequencyOrbit z) :
    ‖completedAutocorrelationProduct h w‖ =
      ‖completedAutocorrelationProduct h z‖ := by
  simp only [canonicalCompletedFrequencyOrbit, Finset.mem_insert,
    Finset.mem_singleton] at hw
  rcases hw with rfl | rfl | rfl | rfl
  · rfl
  · rw [completedAutocorrelationProduct_neg]
  · rw [completedAutocorrelationProduct_conj, Complex.norm_conj]
  · rw [completedAutocorrelationProduct_neg,
      completedAutocorrelationProduct_conj, Complex.norm_conj]

/-- Consequently every multiplicity-expanded target coefficient has the
same norm as the distinguished coefficient, without an additional value
prescription. -/
theorem norm_completedZeroAutocorrelationCoefficient_eq_on_canonicalOrbit
    (h : SmoothCompletedLogTest) (rho0 : nontrivialRiemannZetaZeros)
    (rho : CompletedZetaZeroIndex)
    (hrho : rho ∈ canonicalCompletedZeroOrbit
      (completedZetaZeroFrequency rho0)) :
    ‖completedZeroAutocorrelationCoefficient h rho‖ =
      ‖completedAutocorrelationProduct h
        (completedZetaZeroFrequency rho0)‖ := by
  exact norm_completedAutocorrelationProduct_eq_of_mem_canonicalOrbit h
    (mem_canonicalCompletedZeroOrbit_iff.mp hrho)

end

end RiemannVenue.Venue
