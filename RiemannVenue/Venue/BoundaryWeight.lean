import RiemannVenue.Venue.BoundaryCarrierModelProbes

/-!
# Boundary weights: the first serious weight workbench

The vector/weight probe localized the naive-vector break: finite windows are
honest vector states, but an ordinary all-primes critical vector is blocked
whenever it requires the divergent critical criterion.

This file moves the weight route one layer deeper. A weight candidate is not
accepted merely because vectors break. It must be a renormalized finite-window
system:

* finite windows still restrict to the already-proved vector response;
* the boundary value is obtained by a specified renormalization bridge, not by
  an ambient infinite functional;
* the test ideal is canonical enough not to be chosen from the target Weil
  pairing; and
* the completed explicit-formula identification remains explicit debt.

No completed weight is constructed here, and no Weil positivity theorem is
claimed.
-/

universe u

namespace RiemannVenue.Venue

/-- A finite prime window. Finite windows are where the vector-state picture
is already honest. -/
abbrev PrimeWindow := Finset Nat.Primes

/-- A finite-window system for a boundary weight candidate.

The `windowWeight` values are allowed to depend on a finite prime window. The
important constraints are compatibility and contact with the finite response
surface already proved in `Response.lean`; these remain Prop-valued until a
concrete candidate supplies the actual restriction maps. -/
structure BoundaryFiniteWindowWeightSystem
    (C : BoundaryCarrierCandidate.{u}) where
  /-- The finite-window value assigned to an observable. -/
  windowWeight : PrimeWindow → C.observable → ENNReal
  /-- Restrict a boundary observable to a finite prime window. -/
  restrictObservable : PrimeWindow → C.observable → C.observable
  /-- The empty-window value is normalized. This is a placeholder for the
  eventual normalization convention, not a theorem about a constructed
  object. -/
  emptyWindowNormalized : Prop
  /-- Restricting from a larger finite window to a smaller one is compatible
  with direct restriction. -/
  projectiveCompatibility : Prop
  /-- Each finite window is finite on squares generated by admissible tests. -/
  finiteOnWindowSquares : Prop
  /-- Finite windows retain the known vector-state response contact. -/
  finiteVectorResponseContact : BoundaryCarrierFiniteWindowContact

/-- The finite-window system is anchored when it uses the response contact
already proved in this repository. -/
def BoundaryFiniteWindowWeightSystem.anchoredInKnownResponse
    {C : BoundaryCarrierCandidate.{u}}
    (W : BoundaryFiniteWindowWeightSystem C) : Prop :=
  W.finiteVectorResponseContact = knownFiniteWindowContact

/-- The renormalization bridge from finite windows to a boundary weight. -/
structure BoundaryWeightRenormalization
    (C : BoundaryCarrierCandidate.{u}) where
  /-- The boundary value assigned to an observable after renormalization. -/
  boundaryWeight : C.observable → ENNReal
  /-- The finite-window system being renormalized. -/
  finiteWindows : BoundaryFiniteWindowWeightSystem C
  /-- The renormalization is specified before the completed Weil pairing is
  identified. -/
  upstreamRenormalization : Prop
  /-- The bridge explains why the raw vector limit fails but the
  renormalized weight value remains meaningful on the test ideal. -/
  absorbsCriticalDivergence : Prop
  /-- The bridge is not allowed to manufacture values by inspecting the final
  completed quadratic form. -/
  notTargetPairingDefined : Prop
  /-- Boundary values are finite on the square observables generated by the
  carrier's named test ideal. -/
  finiteOnBoundaryTestSquares : Prop

/-- A renormalized boundary weight candidate after the first charges.

This structure deliberately contains both survival data and debt data. The
weight path is useful only if it survives the vector obstruction while still
keeping completion and no-leak identification as work to do. -/
structure RenormalizedBoundaryWeightCandidate where
  /-- The underlying weight-like model probe. -/
  probe : BoundaryWeightProbe
  /-- The finite-window system whose local face is the known vector response. -/
  finiteWindows : BoundaryFiniteWindowWeightSystem probe.carrier
  /-- The bridge from finite windows to boundary weight values. -/
  renormalization : BoundaryWeightRenormalization probe.carrier
  /-- The test ideal is defined without using the target completed pairing. -/
  canonicalTestIdeal : Prop
  /-- The boundary weight remains non-ambient: finite through the named test
  ideal, not arbitrary or everywhere infinite. -/
  nonAmbientBoundaryWeight : Prop
  /-- The candidate still owes the completed explicit-formula identification. -/
  explicitFormulaIdentificationDebt : Prop
  /-- The candidate still owes no-leak mode semantics. -/
  noLeakIdentificationDebt : Prop

/-- The survival charges a renormalized boundary weight must satisfy before
it is worth comparing with the completed explicit-formula target. -/
def RenormalizedBoundaryWeightCandidate.survivesWeightCharges
    (W : RenormalizedBoundaryWeightCandidate) : Prop :=
  W.probe.minimumSurvivalSurface ∧
  W.finiteWindows.projectiveCompatibility ∧
  W.finiteWindows.finiteOnWindowSquares ∧
  W.finiteWindows.anchoredInKnownResponse ∧
  W.renormalization.upstreamRenormalization ∧
  W.renormalization.absorbsCriticalDivergence ∧
  W.renormalization.notTargetPairingDefined ∧
  W.renormalization.finiteOnBoundaryTestSquares ∧
  W.canonicalTestIdeal ∧
  W.nonAmbientBoundaryWeight

/-- The work still owed after a renormalized boundary weight survives the
weight-specific charges. -/
def RenormalizedBoundaryWeightCandidate.remainingDebt
    (W : RenormalizedBoundaryWeightCandidate) : Prop :=
  W.explicitFormulaIdentificationDebt ∧
  W.noLeakIdentificationDebt ∧
  W.probe.remainingIdentificationDebt

/-- Surviving the weight charges supplies the earlier minimum weight-survival
surface. This is only bookkeeping, but it keeps the hierarchy explicit. -/
theorem RenormalizedBoundaryWeightCandidate.minimumSurvivalSurface
    {W : RenormalizedBoundaryWeightCandidate}
    (hW : W.survivesWeightCharges) :
    W.probe.minimumSurvivalSurface :=
  hW.1

/-- Even a charged renormalized boundary weight has not identified the
completed boundary type unless the remaining debt is supplied separately. -/
theorem RenormalizedBoundaryWeightCandidate.minimumSurface_of_fullWeight
    {W : RenormalizedBoundaryWeightCandidate}
    (hW : W.survivesWeightCharges ∧ W.remainingDebt) :
    W.probe.minimumSurvivalSurface :=
  W.minimumSurvivalSurface hW.1

end RiemannVenue.Venue
