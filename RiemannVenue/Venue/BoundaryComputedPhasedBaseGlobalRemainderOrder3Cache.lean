import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder3Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder3Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder3Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder3Shard3Cache

/-! # Exact global base-remainder cache, order 3 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder3Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder3Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder3Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder3Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder3Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder3Shards_0 :
    computedPhasedBaseGlobalRemainderOrder3Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder3Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder3Shards_1 :
    computedPhasedBaseGlobalRemainderOrder3Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder3Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder3Shards_2 :
    computedPhasedBaseGlobalRemainderOrder3Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder3Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder3Shards_3 :
    computedPhasedBaseGlobalRemainderOrder3Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder3Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder3ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 3 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder3Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder3ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder3ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder3Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder3Shard0Group = computedPhasedBaseGlobalRemainderOrder3Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder3Shards_0, computedPhasedBaseGlobalRemainderOrder3Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder3Shard1Group = computedPhasedBaseGlobalRemainderOrder3Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder3Shards_1, computedPhasedBaseGlobalRemainderOrder3Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder3Shard2Group = computedPhasedBaseGlobalRemainderOrder3Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder3Shards_2, computedPhasedBaseGlobalRemainderOrder3Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder3Shard3Group = computedPhasedBaseGlobalRemainderOrder3Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder3Shards_3, computedPhasedBaseGlobalRemainderOrder3Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder3Cache_eq :
    computedPhasedBaseGlobalRemainderOrder3Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 3 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder3Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder3ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder3ShardEvaluator = computedPhasedBaseGlobalRemainderOrder3Shards from funext computedPhasedBaseGlobalRemainderOrder3ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder3Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder3Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder3Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder3Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder3Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder3Shards_0, computedPhasedBaseGlobalRemainderOrder3Shards_1, computedPhasedBaseGlobalRemainderOrder3Shards_2, computedPhasedBaseGlobalRemainderOrder3Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder3Cache, computedPhasedBaseGlobalRemainderOrder3Shard0Cache, computedPhasedBaseGlobalRemainderOrder3Shard1Cache, computedPhasedBaseGlobalRemainderOrder3Shard2Cache, computedPhasedBaseGlobalRemainderOrder3Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
