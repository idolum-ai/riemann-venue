theorem computedPhasedBaseLowerFourDirectGroup3Paired_contains (n : Fin 12) :
    (computedPhasedBaseLowerFourDirectGroup3Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerFourDirectGroup3Interval.center : ℝ)) := by
  rw [computedPhasedBaseLowerFourDirectGroup3Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseLowerFourDirectGroup3Jets
