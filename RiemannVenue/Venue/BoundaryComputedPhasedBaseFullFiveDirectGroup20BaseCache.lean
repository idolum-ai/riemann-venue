  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell3Shard5Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell3Shard5Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell3Shard5PointInterval, computedPhasedBaseFullFiveCompactCell3Shard5Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup20Bump_contains b n

