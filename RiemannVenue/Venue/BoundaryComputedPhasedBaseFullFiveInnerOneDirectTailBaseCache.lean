def computedPhasedBaseFullFiveInnerOneDirectTailSigned (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerOneDirectTailGroup n b g

theorem computedPhasedBaseFullFiveInnerOneDirectTailSigned_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerOneDirectTailSigned n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerOneTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerOneDirectTailGroup_contains n b g

def computedPhasedBaseFullFiveInnerOneDirectTailSignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerOneTailPointInterval where
  signed := computedPhasedBaseFullFiveInnerOneDirectTailSigned
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerOneTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerOneTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneTailPointInterval, computedPhasedBaseFullFiveInnerOneTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectTailSigned_contains n b

def computedPhasedBaseFullFiveInnerOneDirectTailBumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerOneTailPointInterval where
  bump := computedPhasedBaseFullFiveInnerOneDirectTailBump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerOneTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerOneTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneTailPointInterval, computedPhasedBaseFullFiveInnerOneTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectTailBump_contains b n

