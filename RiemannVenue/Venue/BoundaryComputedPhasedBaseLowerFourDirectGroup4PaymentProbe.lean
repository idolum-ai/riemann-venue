theorem computedPhasedBaseLowerFourDirectGroup4_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerFourDirectGroup4Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerFourDirectGroup4Interval]

noncomputable def computedPhasedBaseLowerFourDirectGroup4TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerFourDirectGroup4Interval (by norm_num [computedPhasedBaseLowerFourDirectGroup4Interval])
