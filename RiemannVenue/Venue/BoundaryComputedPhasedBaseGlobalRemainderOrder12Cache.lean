import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder12Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder12Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder12Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder12Shard3Cache

/-! # Exact global base-remainder cache, order 12 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder12Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder12Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder12Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder12Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder12Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder12Shards_0 :
    computedPhasedBaseGlobalRemainderOrder12Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder12Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder12Shards_1 :
    computedPhasedBaseGlobalRemainderOrder12Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder12Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder12Shards_2 :
    computedPhasedBaseGlobalRemainderOrder12Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder12Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder12Shards_3 :
    computedPhasedBaseGlobalRemainderOrder12Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder12Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder12ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 12 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder12Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder12ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder12ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder12Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder12Shard0Group = computedPhasedBaseGlobalRemainderOrder12Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder12Shards_0, computedPhasedBaseGlobalRemainderOrder12Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder12Shard1Group = computedPhasedBaseGlobalRemainderOrder12Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder12Shards_1, computedPhasedBaseGlobalRemainderOrder12Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder12Shard2Group = computedPhasedBaseGlobalRemainderOrder12Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder12Shards_2, computedPhasedBaseGlobalRemainderOrder12Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder12Shard3Group = computedPhasedBaseGlobalRemainderOrder12Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder12Shards_3, computedPhasedBaseGlobalRemainderOrder12Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder12Cache_eq :
    computedPhasedBaseGlobalRemainderOrder12Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 12 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder12Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder12ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder12ShardEvaluator = computedPhasedBaseGlobalRemainderOrder12Shards from funext computedPhasedBaseGlobalRemainderOrder12ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder12Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder12Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder12Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder12Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder12Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder12Shards_0, computedPhasedBaseGlobalRemainderOrder12Shards_1, computedPhasedBaseGlobalRemainderOrder12Shards_2, computedPhasedBaseGlobalRemainderOrder12Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder12Cache, computedPhasedBaseGlobalRemainderOrder12Shard0Cache, computedPhasedBaseGlobalRemainderOrder12Shard1Cache, computedPhasedBaseGlobalRemainderOrder12Shard2Cache, computedPhasedBaseGlobalRemainderOrder12Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
