import RiemannVenue.Venue.BoundaryPaleyWienerGate

/-!
# Exact localized target correction

Two complex atoms whose real and imaginary parts are linearly independent
span `ℂ` over `ℝ`.  This file records the corresponding explicit Cramer solve
and the four target values forced by the even real completed transform.
-/

namespace RiemannVenue.Venue

noncomputable section

/-- The completed even transform is additive on the smooth compact core. -/
theorem completedZeroTestTransform_add
    (h k : SmoothCompletedLogTest) (z : ℂ) :
    completedZeroTestTransform (h.add k) z =
      completedZeroTestTransform h z + completedZeroTestTransform k z := by
  simp only [completedZeroTestTransform_eq_evenFourierLaplace,
    completedFourierLaplaceTransform_add]
  ring

/-- Real scaling commutes with the completed even transform. -/
theorem completedZeroTestTransform_realScale
    (a : ℝ) (h : SmoothCompletedLogTest) (z : ℂ) :
    completedZeroTestTransform (h.realScale a) z =
      (a : ℂ) * completedZeroTestTransform h z := by
  simp only [completedZeroTestTransform_eq_evenFourierLaplace,
    completedFourierLaplaceTransform_realScale]
  ring

/-- The real determinant of two complex correction atoms. -/
def complexCorrectionDeterminant (atom0 atom1 : ℂ) : ℝ :=
  atom0.re * atom1.im - atom1.re * atom0.im

/-- The first real Cramer coefficient correcting `base` to `target`. -/
def exactTargetCorrection0
    (base atom0 atom1 target : ℂ) : ℝ :=
  ((target - base).re * atom1.im - atom1.re * (target - base).im) /
    complexCorrectionDeterminant atom0 atom1

/-- The second real Cramer coefficient correcting `base` to `target`. -/
def exactTargetCorrection1
    (base atom0 atom1 target : ℂ) : ℝ :=
  (atom0.re * (target - base).im - (target - base).re * atom0.im) /
    complexCorrectionDeterminant atom0 atom1

/-- Cramer's rule gives an exact complex target correction using real
coefficients whenever the two correction atoms are real-linearly
independent. -/
theorem exactTargetCorrection_eq
    (base atom0 atom1 target : ℂ)
    (hdet : complexCorrectionDeterminant atom0 atom1 ≠ 0) :
    base +
        (exactTargetCorrection0 base atom0 atom1 target : ℂ) * atom0 +
      (exactTargetCorrection1 base atom0 atom1 target : ℂ) * atom1 =
    target := by
  apply Complex.ext <;>
    simp only [Complex.add_re, Complex.add_im, Complex.mul_re, Complex.mul_im,
      Complex.sub_re, Complex.sub_im, Complex.ofReal_re, Complex.ofReal_im,
      zero_mul, sub_zero, exactTargetCorrection0, exactTargetCorrection1]
  · simp only [complexCorrectionDeterminant] at hdet ⊢
    have hdet' : atom1.im * atom0.re - atom1.re * atom0.im ≠ 0 := by
      simpa [mul_comm] using hdet
    field_simp [hdet']
    ring
  · simp only [complexCorrectionDeterminant] at hdet ⊢
    have hdet' : atom1.im * atom0.re - atom1.re * atom0.im ≠ 0 := by
      simpa [mul_comm] using hdet
    field_simp [hdet']
    ring

/-- One value of the even completed transform determines its values on the
four-point orbit generated by sign and conjugation.  Evenness supplies the
sign-reflected value, while real Fourier--Laplace reflection supplies the two
conjugate-reflected values. -/
theorem completedZeroTestTransform_four_orbit_values
    (h : SmoothCompletedLogTest) (z target : ℂ)
    (htarget : completedZeroTestTransform h z = target) :
    completedZeroTestTransform h z = target ∧
      completedZeroTestTransform h (-z) = target ∧
      completedZeroTestTransform h (starRingEnd ℂ z) =
        starRingEnd ℂ target ∧
      completedZeroTestTransform h (-(starRingEnd ℂ z)) =
        starRingEnd ℂ target := by
  have hconj : completedZeroTestTransform h (starRingEnd ℂ z) =
      starRingEnd ℂ (completedZeroTestTransform h z) := by
    rw [completedZeroTestTransform_eq_evenFourierLaplace,
      completedZeroTestTransform_eq_evenFourierLaplace]
    have hplus := completedFourierLaplaceTransform_neg_conj h (-z)
    have hminus := completedFourierLaplaceTransform_neg_conj h z
    simp only [map_neg, neg_neg] at hplus
    rw [hplus, hminus, map_div₀, map_add]
    have htwo : starRingEnd ℂ (2 : ℂ) = 2 := by
      apply Complex.ext <;> norm_num
    rw [htwo]
    ring
  refine ⟨htarget, ?_, ?_, ?_⟩
  · rw [completedZeroTestTransform_neg, htarget]
  · rw [hconj, htarget]
  · rw [completedZeroTestTransform_neg, hconj, htarget]

end

end RiemannVenue.Venue
