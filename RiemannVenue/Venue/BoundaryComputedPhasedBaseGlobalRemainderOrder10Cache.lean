import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder10Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder10Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder10Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder10Shard3Cache

/-! # Exact global base-remainder cache, order 10 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder10Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder10Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder10Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder10Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder10Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder10Shards_0 :
    computedPhasedBaseGlobalRemainderOrder10Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder10Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder10Shards_1 :
    computedPhasedBaseGlobalRemainderOrder10Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder10Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder10Shards_2 :
    computedPhasedBaseGlobalRemainderOrder10Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder10Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder10Shards_3 :
    computedPhasedBaseGlobalRemainderOrder10Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder10Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder10ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 10 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder10Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder10ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder10ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder10Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder10Shard0Group = computedPhasedBaseGlobalRemainderOrder10Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder10Shards_0, computedPhasedBaseGlobalRemainderOrder10Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder10Shard1Group = computedPhasedBaseGlobalRemainderOrder10Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder10Shards_1, computedPhasedBaseGlobalRemainderOrder10Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder10Shard2Group = computedPhasedBaseGlobalRemainderOrder10Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder10Shards_2, computedPhasedBaseGlobalRemainderOrder10Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder10Shard3Group = computedPhasedBaseGlobalRemainderOrder10Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder10Shards_3, computedPhasedBaseGlobalRemainderOrder10Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder10Cache_eq :
    computedPhasedBaseGlobalRemainderOrder10Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 10 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder10Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder10ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder10ShardEvaluator = computedPhasedBaseGlobalRemainderOrder10Shards from funext computedPhasedBaseGlobalRemainderOrder10ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder10Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder10Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder10Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder10Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder10Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder10Shards_0, computedPhasedBaseGlobalRemainderOrder10Shards_1, computedPhasedBaseGlobalRemainderOrder10Shards_2, computedPhasedBaseGlobalRemainderOrder10Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder10Cache, computedPhasedBaseGlobalRemainderOrder10Shard0Cache, computedPhasedBaseGlobalRemainderOrder10Shard1Cache, computedPhasedBaseGlobalRemainderOrder10Shard2Cache, computedPhasedBaseGlobalRemainderOrder10Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
