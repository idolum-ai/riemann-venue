import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder7Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder7Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder7Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder7Shard3Cache

/-! # Exact global base-remainder cache, order 7 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder7Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder7Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder7Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder7Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder7Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder7Shards_0 :
    computedPhasedBaseGlobalRemainderOrder7Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder7Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder7Shards_1 :
    computedPhasedBaseGlobalRemainderOrder7Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder7Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder7Shards_2 :
    computedPhasedBaseGlobalRemainderOrder7Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder7Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder7Shards_3 :
    computedPhasedBaseGlobalRemainderOrder7Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder7Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder7ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 7 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder7Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder7ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder7ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder7Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder7Shard0Group = computedPhasedBaseGlobalRemainderOrder7Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder7Shards_0, computedPhasedBaseGlobalRemainderOrder7Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder7Shard1Group = computedPhasedBaseGlobalRemainderOrder7Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder7Shards_1, computedPhasedBaseGlobalRemainderOrder7Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder7Shard2Group = computedPhasedBaseGlobalRemainderOrder7Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder7Shards_2, computedPhasedBaseGlobalRemainderOrder7Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder7Shard3Group = computedPhasedBaseGlobalRemainderOrder7Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder7Shards_3, computedPhasedBaseGlobalRemainderOrder7Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder7Cache_eq :
    computedPhasedBaseGlobalRemainderOrder7Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 7 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder7Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder7ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder7ShardEvaluator = computedPhasedBaseGlobalRemainderOrder7Shards from funext computedPhasedBaseGlobalRemainderOrder7ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder7Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder7Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder7Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder7Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder7Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder7Shards_0, computedPhasedBaseGlobalRemainderOrder7Shards_1, computedPhasedBaseGlobalRemainderOrder7Shards_2, computedPhasedBaseGlobalRemainderOrder7Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder7Cache, computedPhasedBaseGlobalRemainderOrder7Shard0Cache, computedPhasedBaseGlobalRemainderOrder7Shard1Cache, computedPhasedBaseGlobalRemainderOrder7Shard2Cache, computedPhasedBaseGlobalRemainderOrder7Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
