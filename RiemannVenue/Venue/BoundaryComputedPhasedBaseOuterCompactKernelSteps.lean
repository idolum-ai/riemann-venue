theorem computedPhasedBaseOuterCompactKernel_add (z : ℂ) (t d : ℝ) :
    Complex.exp (Complex.I * z * ((t + d : ℝ) : ℂ)) =
      Complex.exp (Complex.I * z * (t : ℂ)) *
        Complex.exp (Complex.I * z * (d : ℂ)) := by
  rw [← Complex.exp_add]
  congr 1
  push_cast
  ring

