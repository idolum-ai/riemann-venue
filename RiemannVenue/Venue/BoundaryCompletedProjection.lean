import RiemannVenue.Venue.BoundaryArchimedeanScore
import RiemannVenue.Venue.BoundaryType

/-!
# Projection contract for the completed Weil functional

This is the early contract that separated finite score, Gamma, pole, and
no-leak obligations while the completed test domain was still open. Those
surfaces are now constructed and identified downstream in
`BoundaryCompletedCauchyDatum` and `BoundaryCompletedJetIdentification`.
The contract remains as a record of the excavation boundary and maps into the
older `BoundaryTypeCandidate` interface.

No candidate is instantiated here.  In particular, the decomposition and
projection laws are not replaced by a tautological pairing.
-/

namespace RiemannVenue.Venue

noncomputable section

/-- A frequency-indexed paired boundary jet. -/
abbrev EnergyScoreBoundaryField :=
  ℝ → BoundaryChannelFirstJet PoissonBoundaryChannel ℝ

/-- Concrete finite-window field supplied by the Poisson scale family. -/
noncomputable def finiteEnergyScoreBoundaryField
    (S : PrimeWindow) (R : ℕ) : EnergyScoreBoundaryField :=
  fun u => finiteEnergyScoreBoundaryJet S R u

/-- Candidate projection of the typed boundary field to completed
explicit-formula data.  Function-valued place components are explicit; the
remaining propositions are exactly the unproved completion laws. -/
structure CompletedEnergyScoreProjectionCandidate where
  /-- Candidate limiting paired finite-place field. -/
  boundaryField : EnergyScoreBoundaryField
  /-- The completed explicit-formula pairing to be recovered. -/
  data : Weil.ExplicitFormulaData
  /-- Finite-place contribution on log-scale tests. -/
  finitePlacePairing : (ℝ → ℝ) → ℝ
  /-- Archimedean contribution on log-scale tests. -/
  archimedeanPairing : (ℝ → ℝ) → ℝ
  /-- Pole and trivial-zero contribution on log-scale tests. -/
  polePairing : (ℝ → ℝ) → ℝ
  /-- The completed pairing decomposes into the three named places. -/
  decomposes : ∀ h, data.pairing h =
    finitePlacePairing h + archimedeanPairing h + polePairing h
  /-- Finite Hellinger fields converge to the energy channel of
  `boundaryField` on the chosen completed test topology. -/
  energyBoundaryLimit : Prop
  /-- The score channel projects to the completed prime-power distribution. -/
  finiteScoreProjection : Prop
  /-- `archimedeanPairing` is generated by `archimedeanGammaBoundaryScore`
  with the chosen Fourier and normalization conventions. -/
  archimedeanScoreProjection : Prop
  /-- `polePairing` contains the completed pole and trivial-zero terms. -/
  poleProjection : Prop
  /-- The resulting completed object has the no-leak spectral semantics. -/
  noLeakSemantics : Prop

/-- All non-positivity obligations for the energy/score projection. -/
def CompletedEnergyScoreProjectionCandidate.ready
    (C : CompletedEnergyScoreProjectionCandidate) : Prop :=
  C.energyBoundaryLimit ∧
  C.finiteScoreProjection ∧
  C.archimedeanScoreProjection ∧
  C.poleProjection ∧
  C.noLeakSemantics

/-- Forget the concrete channel-indexed source while preserving each
obligation in the repository's stable boundary-type contract. -/
def CompletedEnergyScoreProjectionCandidate.toBoundaryTypeCandidate
    (C : CompletedEnergyScoreProjectionCandidate) : BoundaryTypeCandidate where
  data := C.data
  finitePlacePrimePower := C.finiteScoreProjection
  renormalizedResponseLimit := C.energyBoundaryLimit
  logDerivativePrimePowerBridge := C.finiteScoreProjection
  archimedeanGammaTerm := C.archimedeanScoreProjection
  poleAndTrivialZeroTerms := C.poleProjection
  noLeakSemantics := C.noLeakSemantics

/-- A ready typed projection discharges all non-positivity obligations of the
existing boundary-type contract.  Positivity remains separate and
RH-strength for the correct completed object. -/
theorem CompletedEnergyScoreProjectionCandidate.identifiesCompletedObject
    {C : CompletedEnergyScoreProjectionCandidate} (hC : C.ready) :
    C.toBoundaryTypeCandidate.identifiesCompletedObject := by
  rcases hC with ⟨henergy, hfinite, harch, hpole, hnoleak⟩
  exact ⟨hfinite, henergy, hfinite, harch, hpole, hnoleak⟩

/-- Positivity of a ready typed projection is exactly the remaining locked
gate in `BoundaryTypeExcavated`; it is not supplied by the carrier shape. -/
theorem CompletedEnergyScoreProjectionCandidate.excavated_iff
    {C : CompletedEnergyScoreProjectionCandidate} (hC : C.ready) :
    BoundaryTypeExcavated C.toBoundaryTypeCandidate ↔
      Weil.WeilPositivity C.data := by
  constructor
  · intro h
    exact h.2
  · intro h
    exact ⟨C.identifiesCompletedObject hC, h⟩

end

end RiemannVenue.Venue
