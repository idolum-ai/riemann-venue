      have hz : x - (computedPhasedBaseFullFiveCompactCell4Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell4Shard8PointInterval, computedPhasedBaseFullFiveCompactCell4Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup27Bump_contains b n

