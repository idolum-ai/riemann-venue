import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder6Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder6Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder6Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder6Shard3Cache

/-! # Exact global base-remainder cache, order 6 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder6Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder6Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder6Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder6Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder6Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder6Shards_0 :
    computedPhasedBaseGlobalRemainderOrder6Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder6Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder6Shards_1 :
    computedPhasedBaseGlobalRemainderOrder6Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder6Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder6Shards_2 :
    computedPhasedBaseGlobalRemainderOrder6Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder6Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder6Shards_3 :
    computedPhasedBaseGlobalRemainderOrder6Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder6Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder6ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 6 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder6Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder6ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder6ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder6Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder6Shard0Group = computedPhasedBaseGlobalRemainderOrder6Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder6Shards_0, computedPhasedBaseGlobalRemainderOrder6Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder6Shard1Group = computedPhasedBaseGlobalRemainderOrder6Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder6Shards_1, computedPhasedBaseGlobalRemainderOrder6Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder6Shard2Group = computedPhasedBaseGlobalRemainderOrder6Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder6Shards_2, computedPhasedBaseGlobalRemainderOrder6Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder6Shard3Group = computedPhasedBaseGlobalRemainderOrder6Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder6Shards_3, computedPhasedBaseGlobalRemainderOrder6Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder6Cache_eq :
    computedPhasedBaseGlobalRemainderOrder6Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 6 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder6Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder6ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder6ShardEvaluator = computedPhasedBaseGlobalRemainderOrder6Shards from funext computedPhasedBaseGlobalRemainderOrder6ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder6Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder6Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder6Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder6Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder6Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder6Shards_0, computedPhasedBaseGlobalRemainderOrder6Shards_1, computedPhasedBaseGlobalRemainderOrder6Shards_2, computedPhasedBaseGlobalRemainderOrder6Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder6Cache, computedPhasedBaseGlobalRemainderOrder6Shard0Cache, computedPhasedBaseGlobalRemainderOrder6Shard1Cache, computedPhasedBaseGlobalRemainderOrder6Shard2Cache, computedPhasedBaseGlobalRemainderOrder6Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
