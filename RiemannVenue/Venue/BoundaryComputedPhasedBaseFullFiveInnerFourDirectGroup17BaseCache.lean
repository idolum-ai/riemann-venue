      have hz : x - (computedPhasedBaseFullFiveInnerFourCompactCell2Shard14Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourCompactCell2Shard14PointInterval, computedPhasedBaseFullFiveInnerFourCompactCell2Shard14Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
