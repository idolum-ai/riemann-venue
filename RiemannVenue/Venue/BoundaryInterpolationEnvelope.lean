import RiemannVenue.Venue.BoundaryFiniteInterpolationCompiler
import RiemannVenue.Venue.BoundarySpectralOrbit

/-!
# Quantitative envelopes for translated-seed interpolation

Finite interpolation is useful globally only when the cost of its real
coefficients and translations remains visible.  This module records that
cost at three resolutions: coefficient `L1` mass, an `L1` translation radius
which dominates every individual translation, and the exact exponential
envelope seen by the Fourier--Laplace transform.
-/

namespace RiemannVenue.Venue

open scoped BigOperators

noncomputable section

/-- The `L1` mass of a finite vector of real interpolation coefficients. -/
def realCoefficientL1Mass {ι : Type*} [Fintype ι] (c : ι → ℝ) : ℝ :=
  ∑ i, |c i|

/-- An unconditional translation radius.  Using the `L1` radius rather than
a maximum keeps the definition meaningful for the empty index type, while
still dominating every individual translation. -/
def translationL1Radius {ι : Type*} [Fintype ι]
    (translations : ι → ℝ) : ℝ :=
  ∑ i, |translations i|

/-- The exact coefficient/translation envelope generated by the modulus of
the translation character at `z`. -/
noncomputable def translatedInterpolationEnvelope {ι : Type*} [Fintype ι]
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ) : ℝ :=
  ∑ i, |c i| * Real.exp (z.im * translations i)

theorem translatedInterpolationEnvelope_nonneg {ι : Type*} [Fintype ι]
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ) :
    0 ≤ translatedInterpolationEnvelope translations c z := by
  exact Finset.sum_nonneg fun _ _ =>
    mul_nonneg (abs_nonneg _) (Real.exp_pos _).le

theorem realCoefficientL1Mass_nonneg {ι : Type*} [Fintype ι]
    (c : ι → ℝ) :
    0 ≤ realCoefficientL1Mass c := by
  exact Finset.sum_nonneg fun _ _ => abs_nonneg _

theorem translationL1Radius_nonneg {ι : Type*} [Fintype ι]
    (translations : ι → ℝ) :
    0 ≤ translationL1Radius translations := by
  exact Finset.sum_nonneg fun _ _ => abs_nonneg _

theorem abs_translation_le_translationL1Radius
    {ι : Type*} [Fintype ι] (translations : ι → ℝ) (i : ι) :
    |translations i| ≤ translationL1Radius translations := by
  rw [translationL1Radius]
  exact Finset.single_le_sum
    (fun j _ => abs_nonneg (translations j)) (Finset.mem_univ i)

/-- Exact magnitude of the Fourier--Laplace translation character. -/
theorem norm_completedTranslationCharacter (z : ℂ) (a : ℝ) :
    ‖Complex.exp (-Complex.I * z * (a : ℂ))‖ =
      Real.exp (z.im * a) := by
  rw [Complex.norm_exp]
  congr 1
  simp [Complex.mul_re]

/-- Triangle inequality for arbitrary finite real combinations of smooth
completed tests. -/
theorem norm_completedFourierLaplaceTransform_finiteRealCombination_le
    {ι : Type*} [Fintype ι] (c : ι → ℝ)
    (f : ι → SmoothCompletedLogTest) (z : ℂ) :
    ‖completedFourierLaplaceTransform
        (SmoothCompletedLogTest.finiteRealCombination c f) z‖ ≤
      ∑ i, |c i| * ‖completedFourierLaplaceTransform (f i) z‖ := by
  rw [completedFourierLaplaceTransform_finiteRealCombination]
  calc
    ‖∑ i, (c i : ℂ) * completedFourierLaplaceTransform (f i) z‖ ≤
        ∑ i, ‖(c i : ℂ) * completedFourierLaplaceTransform (f i) z‖ :=
      norm_sum_le _ _
    _ = ∑ i, |c i| * ‖completedFourierLaplaceTransform (f i) z‖ := by
      apply Finset.sum_congr rfl
      intro i _
      rw [norm_mul, Complex.norm_real, Real.norm_eq_abs]

/-- The exact translated-seed envelope. -/
theorem norm_completedFourierLaplaceTransform_seedTranslatedCombination_le
    {ι : Type*} [Fintype ι] (seed : SmoothCompletedLogTest)
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ) :
    ‖completedFourierLaplaceTransform
        (seedTranslatedCombination seed translations c) z‖ ≤
      translatedInterpolationEnvelope translations c z *
        ‖completedFourierLaplaceTransform seed z‖ := by
  rw [seedTranslatedCombination]
  calc
    ‖completedFourierLaplaceTransform
        (SmoothCompletedLogTest.finiteRealCombination c
          (fun i => seed.translate (translations i))) z‖ ≤
        ∑ i, |c i| *
          ‖completedFourierLaplaceTransform
            (seed.translate (translations i)) z‖ :=
      norm_completedFourierLaplaceTransform_finiteRealCombination_le c _ z
    _ = ∑ i, |c i| *
          (Real.exp (z.im * translations i) *
            ‖completedFourierLaplaceTransform seed z‖) := by
      apply Finset.sum_congr rfl
      intro i _
      rw [completedFourierLaplaceTransform_translate, norm_mul,
        norm_completedTranslationCharacter]
    _ = translatedInterpolationEnvelope translations c z *
          ‖completedFourierLaplaceTransform seed z‖ := by
      rw [translatedInterpolationEnvelope, Finset.sum_mul]
      apply Finset.sum_congr rfl
      intro i _
      ring

/-- The exact envelope is controlled by coefficient mass and translation
radius. -/
theorem translatedInterpolationEnvelope_le_mass_mul_exp_radius
    {ι : Type*} [Fintype ι] (translations : ι → ℝ)
    (c : ι → ℝ) (z : ℂ) :
    translatedInterpolationEnvelope translations c z ≤
      realCoefficientL1Mass c *
        Real.exp (|z.im| * translationL1Radius translations) := by
  rw [translatedInterpolationEnvelope, realCoefficientL1Mass,
    Finset.sum_mul]
  apply Finset.sum_le_sum
  intro i _
  apply mul_le_mul_of_nonneg_left _ (abs_nonneg _)
  apply Real.exp_le_exp.mpr
  calc
    z.im * translations i ≤ |z.im| * |translations i| :=
      (le_abs_self (z.im * translations i)).trans_eq (abs_mul _ _)
    _ ≤ |z.im| * translationL1Radius translations := by
      gcongr
      exact abs_translation_le_translationL1Radius translations i

/-- Coarse global transform bound exposing only coefficient mass and
translation radius. -/
theorem norm_completedFourierLaplaceTransform_seedTranslatedCombination_le_mass
    {ι : Type*} [Fintype ι] (seed : SmoothCompletedLogTest)
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ) :
    ‖completedFourierLaplaceTransform
        (seedTranslatedCombination seed translations c) z‖ ≤
      realCoefficientL1Mass c *
        Real.exp (|z.im| * translationL1Radius translations) *
          ‖completedFourierLaplaceTransform seed z‖ := by
  exact (norm_completedFourierLaplaceTransform_seedTranslatedCombination_le
    seed translations c z).trans (mul_le_mul_of_nonneg_right
      (translatedInterpolationEnvelope_le_mass_mul_exp_radius
        translations c z) (norm_nonneg _))

/-- Exact-envelope bound for the autocorrelation product. -/
theorem norm_completedAutocorrelationProduct_seedTranslatedCombination_le
    {ι : Type*} [Fintype ι] (seed : SmoothCompletedLogTest)
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ) :
    ‖completedAutocorrelationProduct
        (seedTranslatedCombination seed translations c) z‖ ≤
      (2 * Real.pi) *
        (translatedInterpolationEnvelope translations c z *
          translatedInterpolationEnvelope translations c (-z)) *
      (‖completedFourierLaplaceTransform seed z‖ *
          ‖completedFourierLaplaceTransform seed (-z)‖) := by
  have hnorm : ‖(2 * Real.pi : ℂ)‖ = 2 * Real.pi := by
    norm_num [norm_mul, Complex.norm_real, Real.norm_eq_abs,
      abs_of_pos Real.pi_pos]
  rw [completedAutocorrelationProduct, norm_mul, norm_mul, hnorm]
  have hz := norm_completedFourierLaplaceTransform_seedTranslatedCombination_le
    seed translations c z
  have hnz := norm_completedFourierLaplaceTransform_seedTranslatedCombination_le
    seed translations c (-z)
  have hmul := mul_le_mul hz hnz (norm_nonneg _)
    (mul_nonneg (translatedInterpolationEnvelope_nonneg translations c z)
      (norm_nonneg _))
  calc
    (2 * Real.pi) *
        ‖completedFourierLaplaceTransform
          (seedTranslatedCombination seed translations c) z‖ *
        ‖completedFourierLaplaceTransform
          (seedTranslatedCombination seed translations c) (-z)‖ =
      (2 * Real.pi) *
        (‖completedFourierLaplaceTransform
          (seedTranslatedCombination seed translations c) z‖ *
        ‖completedFourierLaplaceTransform
          (seedTranslatedCombination seed translations c) (-z)‖) := by ring
    _ ≤ (2 * Real.pi) *
        ((translatedInterpolationEnvelope translations c z *
            ‖completedFourierLaplaceTransform seed z‖) *
          (translatedInterpolationEnvelope translations c (-z) *
            ‖completedFourierLaplaceTransform seed (-z)‖)) :=
      mul_le_mul_of_nonneg_left hmul
        (mul_nonneg (by norm_num) Real.pi_pos.le)
    _ = (2 * Real.pi) *
        (translatedInterpolationEnvelope translations c z *
          translatedInterpolationEnvelope translations c (-z)) *
        (‖completedFourierLaplaceTransform seed z‖ *
          ‖completedFourierLaplaceTransform seed (-z)‖) := by ring

/-- Coarse autocorrelation bound with all interpolation cost explicit. -/
theorem norm_completedAutocorrelationProduct_seedTranslatedCombination_le_mass
    {ι : Type*} [Fintype ι] (seed : SmoothCompletedLogTest)
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ) :
    ‖completedAutocorrelationProduct
        (seedTranslatedCombination seed translations c) z‖ ≤
      (2 * Real.pi) * realCoefficientL1Mass c ^ 2 *
        Real.exp (2 * |z.im| * translationL1Radius translations) *
      (‖completedFourierLaplaceTransform seed z‖ *
          ‖completedFourierLaplaceTransform seed (-z)‖) := by
  have hnorm : ‖(2 * Real.pi : ℂ)‖ = 2 * Real.pi := by
    norm_num [norm_mul, Complex.norm_real, Real.norm_eq_abs,
      abs_of_pos Real.pi_pos]
  rw [completedAutocorrelationProduct, norm_mul, norm_mul, hnorm]
  have hz := norm_completedFourierLaplaceTransform_seedTranslatedCombination_le_mass
    seed translations c z
  have hnz := norm_completedFourierLaplaceTransform_seedTranslatedCombination_le_mass
    seed translations c (-z)
  simp only [Complex.neg_im, abs_neg] at hnz
  have hmul := mul_le_mul hz hnz (norm_nonneg _)
    (mul_nonneg
      (mul_nonneg (realCoefficientL1Mass_nonneg c) (Real.exp_pos _).le)
      (norm_nonneg _))
  calc
    (2 * Real.pi) *
        ‖completedFourierLaplaceTransform
          (seedTranslatedCombination seed translations c) z‖ *
        ‖completedFourierLaplaceTransform
          (seedTranslatedCombination seed translations c) (-z)‖ ≤
      (2 * Real.pi) *
        ((realCoefficientL1Mass c *
            Real.exp (|z.im| * translationL1Radius translations) *
              ‖completedFourierLaplaceTransform seed z‖) *
          (realCoefficientL1Mass c *
            Real.exp (|z.im| * translationL1Radius translations) *
              ‖completedFourierLaplaceTransform seed (-z)‖)) := by
      rw [mul_assoc]
      exact mul_le_mul_of_nonneg_left hmul
        (mul_nonneg (by norm_num) Real.pi_pos.le)
    _ = (2 * Real.pi) * realCoefficientL1Mass c ^ 2 *
        Real.exp (2 * |z.im| * translationL1Radius translations) *
        (‖completedFourierLaplaceTransform seed z‖ *
          ‖completedFourierLaplaceTransform seed (-z)‖) := by
      have hexp :
          Real.exp (2 * |z.im| * translationL1Radius translations) =
            Real.exp (|z.im| * translationL1Radius translations) *
              Real.exp (|z.im| * translationL1Radius translations) := by
        rw [← Real.exp_add]
        congr 1
        ring
      rw [hexp]
      ring

/-- On the zeta strip, translations cost at most one exponential of the
explicit radius in the autocorrelation product. -/
theorem norm_completedAutocorrelationProduct_seedTranslatedCombination_le_zetaStrip
    {ι : Type*} [Fintype ι] (seed : SmoothCompletedLogTest)
    (translations : ι → ℝ) (c : ι → ℝ) (z : ℂ)
    (hz : |z.im| ≤ (1 / 2 : ℝ)) :
    ‖completedAutocorrelationProduct
        (seedTranslatedCombination seed translations c) z‖ ≤
      (2 * Real.pi) * realCoefficientL1Mass c ^ 2 *
        Real.exp (translationL1Radius translations) *
        (‖completedFourierLaplaceTransform seed z‖ *
          ‖completedFourierLaplaceTransform seed (-z)‖) := by
  refine (norm_completedAutocorrelationProduct_seedTranslatedCombination_le_mass
    seed translations c z).trans ?_
  gcongr
  have hr := translationL1Radius_nonneg translations
  nlinarith

end

end RiemannVenue.Venue
