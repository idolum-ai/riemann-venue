import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder2Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder2Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder2Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder2Shard3Cache

/-! # Exact global base-remainder cache, order 2 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder2Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder2Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder2Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder2Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder2Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shards_0 :
    computedPhasedBaseGlobalRemainderOrder2Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder2Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shards_1 :
    computedPhasedBaseGlobalRemainderOrder2Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder2Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shards_2 :
    computedPhasedBaseGlobalRemainderOrder2Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder2Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shards_3 :
    computedPhasedBaseGlobalRemainderOrder2Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder2Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder2ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 2 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder2Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder2ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder2ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder2Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder2Shard0Group = computedPhasedBaseGlobalRemainderOrder2Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder2Shards_0, computedPhasedBaseGlobalRemainderOrder2Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder2Shard1Group = computedPhasedBaseGlobalRemainderOrder2Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder2Shards_1, computedPhasedBaseGlobalRemainderOrder2Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder2Shard2Group = computedPhasedBaseGlobalRemainderOrder2Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder2Shards_2, computedPhasedBaseGlobalRemainderOrder2Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder2Shard3Group = computedPhasedBaseGlobalRemainderOrder2Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder2Shards_3, computedPhasedBaseGlobalRemainderOrder2Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder2Cache_eq :
    computedPhasedBaseGlobalRemainderOrder2Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 2 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder2Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder2ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder2ShardEvaluator = computedPhasedBaseGlobalRemainderOrder2Shards from funext computedPhasedBaseGlobalRemainderOrder2ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder2Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder2Shards_0, computedPhasedBaseGlobalRemainderOrder2Shards_1, computedPhasedBaseGlobalRemainderOrder2Shards_2, computedPhasedBaseGlobalRemainderOrder2Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder2Cache, computedPhasedBaseGlobalRemainderOrder2Shard0Cache, computedPhasedBaseGlobalRemainderOrder2Shard1Cache, computedPhasedBaseGlobalRemainderOrder2Shard2Cache, computedPhasedBaseGlobalRemainderOrder2Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
