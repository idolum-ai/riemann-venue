    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerTwoCompactCell4Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell4Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell4Shard0PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell4Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerTwoDirectGroup24Signed_contains n b

