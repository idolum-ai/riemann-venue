theorem computedPhasedBaseLowerThreeDirectGroup15_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerThreeDirectGroup15Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerThreeDirectGroup15Interval]

noncomputable def computedPhasedBaseLowerThreeDirectGroup15TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerThreeDirectGroup15Interval (by norm_num [computedPhasedBaseLowerThreeDirectGroup15Interval])
    computedPhasedBaseLowerThreeDirectGroup15Paired computedPhasedBaseLowerThreeDirectGroup15Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseLowerThreeDirectGroup15_remainder hx)

def computedPhasedBaseLowerThreeDirectGroup15TaylorCenterQ : ℚ × ℚ :=
