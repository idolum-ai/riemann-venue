theorem computedPhasedBaseLowerThreeDirectGroup15Paired_contains (n : Fin 12) :
    (computedPhasedBaseLowerThreeDirectGroup15Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseLowerThreeDirectGroup15Interval.center : ℝ)) := by
  rw [computedPhasedBaseLowerThreeDirectGroup15Interval_center_eq_source]
