def computedPhasedBaseFullFiveInnerTwoDirectTailSigned (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerTwoDirectTailGroup n b g

theorem computedPhasedBaseFullFiveInnerTwoDirectTailSigned_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerTwoDirectTailSigned n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerTwoTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerTwoDirectTailGroup_contains n b g

def computedPhasedBaseFullFiveInnerTwoDirectTailSignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerTwoTailPointInterval where
  signed := computedPhasedBaseFullFiveInnerTwoDirectTailSigned
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerTwoTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerTwoTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoTailPointInterval, computedPhasedBaseFullFiveInnerTwoTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerTwoDirectTailSigned_contains n b

def computedPhasedBaseFullFiveInnerTwoDirectTailBumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerTwoTailPointInterval where
  bump := computedPhasedBaseFullFiveInnerTwoDirectTailBump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerTwoTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerTwoTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoTailPointInterval, computedPhasedBaseFullFiveInnerTwoTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerTwoDirectTailBump_contains b n

