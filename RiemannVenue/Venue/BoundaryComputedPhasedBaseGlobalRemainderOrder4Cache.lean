import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder4Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder4Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder4Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder4Shard3Cache

/-! # Exact global base-remainder cache, order 4 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder4Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder4Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder4Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder4Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder4Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder4Shards_0 :
    computedPhasedBaseGlobalRemainderOrder4Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder4Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder4Shards_1 :
    computedPhasedBaseGlobalRemainderOrder4Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder4Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder4Shards_2 :
    computedPhasedBaseGlobalRemainderOrder4Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder4Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder4Shards_3 :
    computedPhasedBaseGlobalRemainderOrder4Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder4Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder4ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 4 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder4Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder4ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder4ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder4Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder4Shard0Group = computedPhasedBaseGlobalRemainderOrder4Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder4Shards_0, computedPhasedBaseGlobalRemainderOrder4Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder4Shard1Group = computedPhasedBaseGlobalRemainderOrder4Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder4Shards_1, computedPhasedBaseGlobalRemainderOrder4Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder4Shard2Group = computedPhasedBaseGlobalRemainderOrder4Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder4Shards_2, computedPhasedBaseGlobalRemainderOrder4Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder4Shard3Group = computedPhasedBaseGlobalRemainderOrder4Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder4Shards_3, computedPhasedBaseGlobalRemainderOrder4Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder4Cache_eq :
    computedPhasedBaseGlobalRemainderOrder4Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 4 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder4Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder4ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder4ShardEvaluator = computedPhasedBaseGlobalRemainderOrder4Shards from funext computedPhasedBaseGlobalRemainderOrder4ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder4Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder4Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder4Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder4Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder4Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder4Shards_0, computedPhasedBaseGlobalRemainderOrder4Shards_1, computedPhasedBaseGlobalRemainderOrder4Shards_2, computedPhasedBaseGlobalRemainderOrder4Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder4Cache, computedPhasedBaseGlobalRemainderOrder4Shard0Cache, computedPhasedBaseGlobalRemainderOrder4Shard1Cache, computedPhasedBaseGlobalRemainderOrder4Shard2Cache, computedPhasedBaseGlobalRemainderOrder4Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
