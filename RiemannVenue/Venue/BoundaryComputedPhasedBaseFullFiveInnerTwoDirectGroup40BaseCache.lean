  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerTwoDirectGroup40Group n b g

theorem computedPhasedBaseFullFiveInnerTwoDirectGroup40Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerTwoDirectGroup40Signed n b).Contains
