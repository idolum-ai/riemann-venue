def computedPhasedBaseFullFiveDirectGroup24Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveDirectGroup24Group n b g

theorem computedPhasedBaseFullFiveDirectGroup24Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveDirectGroup24Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveCompactCell4Shard0Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveDirectGroup24Group_contains n b g

def computedPhasedBaseFullFiveDirectGroup24SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell4Shard0PointInterval where
  signed := computedPhasedBaseFullFiveDirectGroup24Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell4Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell4Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell4Shard0PointInterval, computedPhasedBaseFullFiveCompactCell4Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup24Signed_contains n b

def computedPhasedBaseFullFiveDirectGroup24BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell4Shard0PointInterval where
  bump := computedPhasedBaseFullFiveDirectGroup24Bump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell4Shard0Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell4Shard0Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell4Shard0PointInterval, computedPhasedBaseFullFiveCompactCell4Shard0Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup24Bump_contains b n

