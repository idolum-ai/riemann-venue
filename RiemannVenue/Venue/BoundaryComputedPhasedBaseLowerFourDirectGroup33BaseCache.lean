      have hz : x - (computedPhasedBaseLowerFourCompactCell5Shard17Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseLowerFourCompactCell5Shard17PointInterval, computedPhasedBaseLowerFourCompactCell5Shard17Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseLowerFourDirectGroup33Bump_contains b n

