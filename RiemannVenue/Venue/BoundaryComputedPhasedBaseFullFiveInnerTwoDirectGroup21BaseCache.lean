    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerTwoCompactCell3Shard8Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell3Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell3Shard8PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell3Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerTwoDirectGroup21Signed_contains n b

