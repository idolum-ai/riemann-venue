      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell1Shard11Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell1Shard11PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell1Shard11Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
