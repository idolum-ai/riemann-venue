      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup2Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup2Interval_center_eq_source]
