theorem computedPhasedBaseFullFiveDirectGroup2_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup2Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup2Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup2TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup2Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup2Interval])
