def computedPhasedBaseFullFiveInnerThreeDirectTailSigned (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerThreeDirectTailGroup n b g

theorem computedPhasedBaseFullFiveInnerThreeDirectTailSigned_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerThreeDirectTailSigned n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerThreeTailInterval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerThreeDirectTailGroup_contains n b g

def computedPhasedBaseFullFiveInnerThreeDirectTailSignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerThreeTailPointInterval where
  signed := computedPhasedBaseFullFiveInnerThreeDirectTailSigned
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerThreeTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerThreeTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerThreeTailPointInterval, computedPhasedBaseFullFiveInnerThreeTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerThreeDirectTailSigned_contains n b

def computedPhasedBaseFullFiveInnerThreeDirectTailBumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerThreeTailPointInterval where
  bump := computedPhasedBaseFullFiveInnerThreeDirectTailBump
  bump_contains := by
    intro b n x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerThreeTailInterval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerThreeTailInterval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerThreeTailPointInterval, computedPhasedBaseFullFiveInnerThreeTailInterval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerThreeDirectTailBump_contains b n

