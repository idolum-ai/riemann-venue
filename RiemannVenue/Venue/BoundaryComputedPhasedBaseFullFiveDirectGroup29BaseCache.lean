def computedPhasedBaseFullFiveDirectGroup29Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveDirectGroup29Group n b g

theorem computedPhasedBaseFullFiveDirectGroup29Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveDirectGroup29Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveCompactCell4Shard14Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveDirectGroup29Group_contains n b g

def computedPhasedBaseFullFiveDirectGroup29SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell4Shard14PointInterval where
  signed := computedPhasedBaseFullFiveDirectGroup29Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell4Shard14Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell4Shard14Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell4Shard14PointInterval, computedPhasedBaseFullFiveCompactCell4Shard14Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup29Signed_contains n b

