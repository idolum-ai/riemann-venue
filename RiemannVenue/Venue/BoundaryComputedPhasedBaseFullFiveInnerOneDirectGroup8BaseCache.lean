def computedPhasedBaseFullFiveInnerOneDirectGroup8Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerOneDirectGroup8Group n b g

theorem computedPhasedBaseFullFiveInnerOneDirectGroup8Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerOneDirectGroup8Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerOneCompactCell1Shard5Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerOneDirectGroup8Group_contains n b g

def computedPhasedBaseFullFiveInnerOneDirectGroup8SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerOneCompactCell1Shard5PointInterval where
  signed := computedPhasedBaseFullFiveInnerOneDirectGroup8Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerOneCompactCell1Shard5Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell1Shard5Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell1Shard5PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell1Shard5Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectGroup8Signed_contains n b

def computedPhasedBaseFullFiveInnerOneDirectGroup8BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
