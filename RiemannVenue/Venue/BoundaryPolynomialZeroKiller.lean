import RiemannVenue.Venue.BoundaryDifferentialSeparator
import RiemannVenue.Venue.BoundaryCanonicalZeroOrbit

/-!
# Polynomial zero killers

This file constructs a differential-operator correction which kills any
finite set of competitor frequencies while preserving the complete
sign/conjugation orbit of a target.  Each competitor contributes a
real even quartic, so no Lagrange denominator between competitors appears.
Off the coordinate axes the product is normalized by a real affine polynomial
in `X²`.  On either axis the real-even competitor product already evaluates
to a real number, so a real constant normalizer suffices.  Thus the only
algebraic obstruction is an actual intersection between a competitor orbit
and the target orbit.
-/

namespace RiemannVenue.Venue

open Polynomial

noncomputable section

private def differentialFrequency (z : ℂ) : ℂ := -Complex.I * z

/-- The real even quartic whose complex roots are the differential-frequency
orbit generated by `w`. -/
noncomputable def differentialOrbitQuartic (w : ℂ) : ℝ[X] :=
  let y := differentialFrequency w
  X ^ 4 - C (2 * (y ^ 2).re) * X ^ 2 + C (Complex.normSq (y ^ 2))

theorem natDegree_differentialOrbitQuartic_le (w : ℂ) :
    (differentialOrbitQuartic w).natDegree ≤ 4 := by
  simp only [differentialOrbitQuartic]
  exact Polynomial.natDegree_add_le_of_degree_le
    (Polynomial.natDegree_sub_le_of_le
      (Polynomial.natDegree_X_pow_le (R := ℝ) 4)
      ((Polynomial.natDegree_C_mul_X_pow_le
        (2 * (differentialFrequency w ^ 2).re) 2).trans
          (show 2 ≤ 4 by norm_num)))
    (by rw [Polynomial.natDegree_C]; norm_num)

theorem eval₂_differentialOrbitQuartic (w x : ℂ) :
    (differentialOrbitQuartic w).eval₂ Complex.ofRealHom x =
      (x ^ 2 - differentialFrequency w ^ 2) *
        (x ^ 2 - starRingEnd ℂ (differentialFrequency w) ^ 2) := by
  rw [differentialOrbitQuartic]
  simp only [Polynomial.eval₂_add, Polynomial.eval₂_sub,
    Polynomial.eval₂_mul, Polynomial.eval₂_pow, Polynomial.eval₂_X,
    Polynomial.eval₂_C, Polynomial.eval₂_ofNat, map_mul, map_ofNat]
  have hre : (((differentialFrequency w ^ 2).re : ℝ) : ℂ) =
      ((differentialFrequency w ^ 2) +
        starRingEnd ℂ (differentialFrequency w ^ 2)) / 2 := by
    exact Complex.re_eq_add_conj _
  have hnorm : ((Complex.normSq (differentialFrequency w ^ 2) : ℝ) : ℂ) =
      (differentialFrequency w ^ 2) *
        starRingEnd ℂ (differentialFrequency w ^ 2) := by
    rw [Complex.normSq_eq_conj_mul_self]
    ring
  change x ^ 4 - (2 : ℂ) * ((differentialFrequency w ^ 2).re : ℂ) *
      x ^ 2 + (Complex.normSq (differentialFrequency w ^ 2) : ℂ) = _
  rw [hre, hnorm, map_pow]
  ring

@[simp] theorem eval₂_differentialOrbitQuartic_self (w : ℂ) :
    (differentialOrbitQuartic w).eval₂ Complex.ofRealHom
      (differentialFrequency w) = 0 := by
  rw [eval₂_differentialOrbitQuartic]
  ring

/-- Product of the orbit quartics. It kills every listed competitor and all
of the sign/conjugation companions forced by real even coefficients. -/
noncomputable def differentialCompetitorKiller
    (competitors : Finset ℂ) : ℝ[X] :=
  ∏ w ∈ competitors, differentialOrbitQuartic w

theorem natDegree_differentialCompetitorKiller_le
    (competitors : Finset ℂ) :
    (differentialCompetitorKiller competitors).natDegree ≤
      4 * competitors.card := by
  rw [differentialCompetitorKiller]
  calc
    (∏ w ∈ competitors, differentialOrbitQuartic w).natDegree ≤
        ∑ w ∈ competitors, (differentialOrbitQuartic w).natDegree :=
      Polynomial.natDegree_prod_le
        competitors (fun w => differentialOrbitQuartic w)
    _ ≤ ∑ _w ∈ competitors, 4 := by
      exact Finset.sum_le_sum fun w _ => natDegree_differentialOrbitQuartic_le w
    _ = 4 * competitors.card := by simp [Nat.mul_comm]

theorem eval₂_differentialCompetitorKiller_eq_prod
    (competitors : Finset ℂ) (x : ℂ) :
    (differentialCompetitorKiller competitors).eval₂ Complex.ofRealHom x =
      ∏ w ∈ competitors,
        ((x ^ 2 - differentialFrequency w ^ 2) *
          (x ^ 2 - starRingEnd ℂ (differentialFrequency w) ^ 2)) := by
  rw [differentialCompetitorKiller]
  simp only [Polynomial.eval₂_finsetProd, eval₂_differentialOrbitQuartic]

theorem eval₂_differentialCompetitorKiller_competitor
    {competitors : Finset ℂ} {w : ℂ} (hw : w ∈ competitors) :
    (differentialCompetitorKiller competitors).eval₂ Complex.ofRealHom
      (differentialFrequency w) = 0 := by
  rw [eval₂_differentialCompetitorKiller_eq_prod]
  apply Finset.prod_eq_zero hw
  ring

private theorem differentialFrequency_injective :
    Function.Injective differentialFrequency := by
  intro z w h
  dsimp [differentialFrequency] at h
  have hi : Complex.I ≠ 0 := Complex.I_ne_zero
  apply (mul_left_cancel₀ hi)
  simpa only [neg_mul, neg_inj] using congrArg Neg.neg h

private theorem differentialFrequency_neg (z : ℂ) :
    differentialFrequency (-z) = -differentialFrequency z := by
  simp [differentialFrequency]

private theorem differentialFrequency_conj (z : ℂ) :
    differentialFrequency (starRingEnd ℂ z) =
      -starRingEnd ℂ (differentialFrequency z) := by
  simp [differentialFrequency]

theorem eval₂_differentialOrbitQuartic_ne_zero_of_not_mem_orbit
    {z w : ℂ} (hw : w ∉ canonicalCompletedFrequencyOrbit z) :
    (differentialOrbitQuartic w).eval₂ Complex.ofRealHom
      (differentialFrequency z) ≠ 0 := by
  rw [eval₂_differentialOrbitQuartic]
  intro hzero
  rcases mul_eq_zero.mp hzero with h | h
  · have hsquare : differentialFrequency z = differentialFrequency w ∨
        differentialFrequency z = -differentialFrequency w :=
      (sq_eq_sq_iff_eq_or_eq_neg).mp (sub_eq_zero.mp h)
    rcases hsquare with heq | heq
    · exact hw (by
        have : z = w := differentialFrequency_injective heq
        simp [this, canonicalCompletedFrequencyOrbit])
    · exact hw (by
        have : z = -w := differentialFrequency_injective (by
          rw [differentialFrequency_neg]
          exact heq)
        simp [this, canonicalCompletedFrequencyOrbit])
  · have hsquare : differentialFrequency z =
          starRingEnd ℂ (differentialFrequency w) ∨
        differentialFrequency z =
          -starRingEnd ℂ (differentialFrequency w) :=
      (sq_eq_sq_iff_eq_or_eq_neg).mp (sub_eq_zero.mp h)
    rcases hsquare with heq | heq
    · exact hw (by
        have : z = -starRingEnd ℂ w := differentialFrequency_injective (by
          rw [differentialFrequency_neg, differentialFrequency_conj]
          simp only [neg_neg]
          exact heq)
        simp [this, canonicalCompletedFrequencyOrbit])
    · exact hw (by
        have : z = starRingEnd ℂ w := differentialFrequency_injective (by
          rw [differentialFrequency_conj]
          exact heq)
        simp [this, canonicalCompletedFrequencyOrbit])

theorem eval₂_differentialCompetitorKiller_ne_zero
    {competitors : Finset ℂ} {z : ℂ}
    (hdisjoint : ∀ w ∈ competitors,
      w ∉ canonicalCompletedFrequencyOrbit z) :
    (differentialCompetitorKiller competitors).eval₂ Complex.ofRealHom
      (differentialFrequency z) ≠ 0 := by
  rw [eval₂_differentialCompetitorKiller_eq_prod]
  apply Finset.prod_ne_zero_iff.mpr
  intro w hw
  rw [← eval₂_differentialOrbitQuartic]
  exact eval₂_differentialOrbitQuartic_ne_zero_of_not_mem_orbit
    (hdisjoint w hw)

/-- On either coordinate axis, every real-even competitor quartic evaluates
to a real number. -/
theorem eval₂_differentialOrbitQuartic_im_eq_zero_of_sq_im_eq_zero
    (w x : ℂ) (hx : (x ^ 2).im = 0) :
    ((differentialOrbitQuartic w).eval₂ Complex.ofRealHom x).im = 0 := by
  rw [eval₂_differentialOrbitQuartic]
  have hxsq : starRingEnd ℂ (x ^ 2) = x ^ 2 := by
    exact (Complex.conj_eq_iff_im).2 hx
  have hsecond :
      x ^ 2 - starRingEnd ℂ (differentialFrequency w) ^ 2 =
        starRingEnd ℂ (x ^ 2 - differentialFrequency w ^ 2) := by
    rw [map_sub, ← map_pow, hxsq, map_pow]
  rw [hsecond, Complex.mul_conj]
  simp

/-- Consequently the complete finite competitor product is real on either
coordinate axis. -/
theorem eval₂_differentialCompetitorKiller_im_eq_zero_of_sq_im_eq_zero
    (competitors : Finset ℂ) (x : ℂ) (hx : (x ^ 2).im = 0) :
    ((differentialCompetitorKiller competitors).eval₂
      Complex.ofRealHom x).im = 0 := by
  induction competitors using Finset.induction_on with
  | empty => simp [differentialCompetitorKiller]
  | @insert w competitors hw ih =>
      rw [differentialCompetitorKiller, Finset.prod_insert hw,
        Polynomial.eval₂_mul, Complex.mul_im,
        eval₂_differentialOrbitQuartic_im_eq_zero_of_sq_im_eq_zero w x hx]
      have ih' := ih
      rw [differentialCompetitorKiller] at ih'
      rw [ih']
      ring

/-- A real affine polynomial in `X²` taking the prescribed complex value at
`x`, provided `x²` is not real. -/
noncomputable def realEvenAffineNormalizer (x value : ℂ) : ℝ[X] :=
  let b : ℝ := value.im / (x ^ 2).im
  let a : ℝ := value.re - b * (x ^ 2).re
  C a + C b * X ^ 2

theorem natDegree_realEvenAffineNormalizer_le (x value : ℂ) :
    (realEvenAffineNormalizer x value).natDegree ≤ 2 := by
  rw [realEvenAffineNormalizer]
  exact Polynomial.natDegree_add_le_of_degree_le
    ((Polynomial.natDegree_C _).le.trans (by omega))
    (Polynomial.natDegree_C_mul_X_pow_le _ 2)

theorem eval₂_realEvenAffineNormalizer
    {x value : ℂ} (hx : (x ^ 2).im ≠ 0) :
    (realEvenAffineNormalizer x value).eval₂ Complex.ofRealHom x = value := by
  rw [realEvenAffineNormalizer]
  simp only [Polynomial.eval₂_add, Polynomial.eval₂_mul,
    Polynomial.eval₂_pow, Polynomial.eval₂_X, Polynomial.eval₂_C]
  apply Complex.ext
  · simp
  · simp
    field_simp

/-- A real-even normalizer which uses two real coefficients off-axis and the
available real constant normalization on-axis. -/
noncomputable def realEvenNormalizer (x value : ℂ) : ℝ[X] :=
  if (x ^ 2).im = 0 then C value.re else realEvenAffineNormalizer x value

theorem natDegree_realEvenNormalizer_le (x value : ℂ) :
    (realEvenNormalizer x value).natDegree ≤ 2 := by
  by_cases hx : (x ^ 2).im = 0
  · rw [realEvenNormalizer, if_pos hx, Polynomial.natDegree_C]
    omega
  · rw [realEvenNormalizer, if_neg hx]
    exact natDegree_realEvenAffineNormalizer_le x value

theorem eval₂_realEvenNormalizer
    {x value : ℂ} (hreal : (x ^ 2).im = 0 → value.im = 0) :
    (realEvenNormalizer x value).eval₂ Complex.ofRealHom x = value := by
  by_cases hx : (x ^ 2).im = 0
  · rw [realEvenNormalizer, if_pos hx, Polynomial.eval₂_C]
    apply Complex.ext
    · simp
    · simp [hreal hx]
  · rw [realEvenNormalizer, if_neg hx]
    exact eval₂_realEvenAffineNormalizer hx

private theorem eval₂_realEvenNormalizer_neg
    (x value y : ℂ) :
    (realEvenNormalizer x value).eval₂ Complex.ofRealHom (-y) =
      (realEvenNormalizer x value).eval₂ Complex.ofRealHom y := by
  by_cases hx : (x ^ 2).im = 0
  · simp [realEvenNormalizer, hx]
  · simp [realEvenNormalizer, hx, realEvenAffineNormalizer]

/-- The explicit real even polynomial zero killer, normalized to one at the
target differential frequency. -/
noncomputable def normalizedDifferentialZeroKiller
    (competitors : Finset ℂ) (z : ℂ) : ℝ[X] :=
  let Q := differentialCompetitorKiller competitors
  let x := differentialFrequency z
  Q * realEvenNormalizer x
    ((Q.eval₂ Complex.ofRealHom x)⁻¹)

theorem natDegree_normalizedDifferentialZeroKiller_le
    (competitors : Finset ℂ) (z : ℂ) :
    (normalizedDifferentialZeroKiller competitors z).natDegree ≤
      4 * competitors.card + 2 := by
  rw [normalizedDifferentialZeroKiller]
  exact Polynomial.natDegree_mul_le_of_le
    (natDegree_differentialCompetitorKiller_le competitors)
    (natDegree_realEvenNormalizer_le _ _)

/-- Normalization at the target requires only that the finite competitor
product does not vanish there. -/
theorem eval₂_normalizedDifferentialZeroKiller_target_of_ne
    {competitors : Finset ℂ} {z : ℂ}
    (hne : (differentialCompetitorKiller competitors).eval₂
      Complex.ofRealHom (differentialFrequency z) ≠ 0) :
    (normalizedDifferentialZeroKiller competitors z).eval₂
      Complex.ofRealHom (differentialFrequency z) = 1 := by
  let x := differentialFrequency z
  let q := (differentialCompetitorKiller competitors).eval₂
    Complex.ofRealHom x
  have hqreal : (x ^ 2).im = 0 → (q⁻¹).im = 0 := by
    intro hx
    rw [Complex.inv_im,
      eval₂_differentialCompetitorKiller_im_eq_zero_of_sq_im_eq_zero
        competitors x hx]
    simp
  rw [normalizedDifferentialZeroKiller, Polynomial.eval₂_mul,
    eval₂_realEvenNormalizer hqreal]
  exact mul_inv_cancel₀ hne

theorem eval₂_normalizedDifferentialZeroKiller_target
    {competitors : Finset ℂ} {z : ℂ}
    (hdisjoint : ∀ w ∈ competitors,
      w ∉ canonicalCompletedFrequencyOrbit z) :
    (normalizedDifferentialZeroKiller competitors z).eval₂
      Complex.ofRealHom (differentialFrequency z) = 1 := by
  exact eval₂_normalizedDifferentialZeroKiller_target_of_ne
    (eval₂_differentialCompetitorKiller_ne_zero hdisjoint)

theorem eval₂_normalizedDifferentialZeroKiller_competitor
    {competitors : Finset ℂ} {z w : ℂ} (hw : w ∈ competitors) :
    (normalizedDifferentialZeroKiller competitors z).eval₂
      Complex.ofRealHom (differentialFrequency w) = 0 := by
  rw [normalizedDifferentialZeroKiller, Polynomial.eval₂_mul,
    eval₂_differentialCompetitorKiller_competitor hw, zero_mul]

private theorem eval₂_realPolynomial_conj (p : ℝ[X]) (x : ℂ) :
    p.eval₂ Complex.ofRealHom (starRingEnd ℂ x) =
      starRingEnd ℂ (p.eval₂ Complex.ofRealHom x) := by
  induction p using Polynomial.induction_on' with
  | add p q hp hq => simp only [Polynomial.eval₂_add, map_add, hp, hq]
  | monomial n a =>
      simp only [Polynomial.eval₂_monomial, map_mul, map_pow]
      change (a : ℂ) * (starRingEnd ℂ x) ^ n =
        starRingEnd ℂ (a : ℂ) * (starRingEnd ℂ x) ^ n
      rw [Complex.conj_ofReal]

private theorem normalizedDifferentialZeroKiller_even
    (competitors : Finset ℂ) (z : ℂ) (x : ℂ) :
    (normalizedDifferentialZeroKiller competitors z).eval₂
        Complex.ofRealHom (-x) =
      (normalizedDifferentialZeroKiller competitors z).eval₂
        Complex.ofRealHom x := by
  rw [normalizedDifferentialZeroKiller, Polynomial.eval₂_mul,
    Polynomial.eval₂_mul]
  congr 1
  · rw [eval₂_differentialCompetitorKiller_eq_prod,
      eval₂_differentialCompetitorKiller_eq_prod]
    apply Finset.prod_congr rfl
    intro w hw
    ring
  · exact eval₂_realEvenNormalizer_neg _ _ _

theorem eval₂_normalizedDifferentialZeroKiller_target_orbit
    {competitors : Finset ℂ} {z w : ℂ}
    (hdisjoint : ∀ v ∈ competitors,
      v ∉ canonicalCompletedFrequencyOrbit z)
    (hw : w ∈ canonicalCompletedFrequencyOrbit z) :
    (normalizedDifferentialZeroKiller competitors z).eval₂
      Complex.ofRealHom (differentialFrequency w) = 1 := by
  simp only [canonicalCompletedFrequencyOrbit, Finset.mem_insert,
    Finset.mem_singleton] at hw
  rcases hw with rfl | rfl | rfl | rfl
  · exact eval₂_normalizedDifferentialZeroKiller_target hdisjoint
  · rw [differentialFrequency_neg,
      normalizedDifferentialZeroKiller_even]
    exact eval₂_normalizedDifferentialZeroKiller_target hdisjoint
  · rw [differentialFrequency_conj,
      normalizedDifferentialZeroKiller_even,
      eval₂_realPolynomial_conj,
      eval₂_normalizedDifferentialZeroKiller_target hdisjoint]
    simp
  · rw [differentialFrequency_neg, differentialFrequency_conj]
    simp only [neg_neg]
    rw [eval₂_realPolynomial_conj,
      eval₂_normalizedDifferentialZeroKiller_target hdisjoint]
    simp

/-- Applying the normalized polynomial differential operator preserves the
transform on the full target orbit and kills every listed competitor. -/
theorem exists_polynomialDifferentialOperator_target_preserving_competitor_killing
    (h : SmoothCompletedLogTest) (competitors : Finset ℂ) (z : ℂ)
    (hdisjoint : ∀ w ∈ competitors,
      w ∉ canonicalCompletedFrequencyOrbit z) :
    ∃ k : SmoothCompletedLogTest,
      (∀ w ∈ canonicalCompletedFrequencyOrbit z,
        completedFourierLaplaceTransform k w =
          completedFourierLaplaceTransform h w) ∧
      (∀ w ∈ competitors,
        completedFourierLaplaceTransform k w = 0) := by
  let p := normalizedDifferentialZeroKiller competitors z
  refine ⟨h.polynomialDifferentialOperator p, ?_, ?_⟩
  · intro w hw
    rw [completedFourierLaplaceTransform_polynomialDifferentialOperator,
      show -Complex.I * w = differentialFrequency w by rfl,
      show p = normalizedDifferentialZeroKiller competitors z by rfl,
      eval₂_normalizedDifferentialZeroKiller_target_orbit
        hdisjoint hw, one_mul]
  · intro w hw
    rw [completedFourierLaplaceTransform_polynomialDifferentialOperator,
      show -Complex.I * w = differentialFrequency w by rfl,
      show p = normalizedDifferentialZeroKiller competitors z by rfl,
      eval₂_normalizedDifferentialZeroKiller_competitor hw, zero_mul]

end

end RiemannVenue.Venue
