  norm_num [computedPhasedBaseFullFiveDirectGroup12Interval, computedPhasedBaseFullFiveCompactCell2Shard0Interval]

def computedPhasedBaseFullFiveDirectGroup12Paired (n : Fin 12) : RationalRectangle :=
  computedPhasedBaseOuterPairedInterval computedPhasedBaseFullFiveDirectGroup12Jets
