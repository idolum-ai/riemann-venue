theorem computedPhasedBaseFullFiveDirectGroup12_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup12Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup12Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup12TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseFullFiveDirectGroup12Interval (by norm_num [computedPhasedBaseFullFiveDirectGroup12Interval])
    computedPhasedBaseFullFiveDirectGroup12Paired computedPhasedBaseFullFiveDirectGroup12Paired_contains
    computedPhasedBaseGlobalPairedTwelveRemainderBound
    computedPhasedBaseGlobalPairedTwelveRemainderBound_nonneg
    (fun x hx => computedPhasedBaseFullFiveDirectGroup12_remainder hx)

def computedPhasedBaseFullFiveDirectGroup12TaylorCenterQ : ℚ × ℚ :=
