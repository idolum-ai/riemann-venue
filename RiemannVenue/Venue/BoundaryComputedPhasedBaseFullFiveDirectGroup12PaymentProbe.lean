theorem computedPhasedBaseFullFiveDirectGroup12Paired_contains (n : Fin 12) :
    (computedPhasedBaseFullFiveDirectGroup12Paired n).Contains
      (computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint n
        (computedPhasedBaseFullFiveDirectGroup12Interval.center : ℝ)) := by
  rw [computedPhasedBaseFullFiveDirectGroup12Interval_center_eq_source]
  exact computedPhasedBaseOuterPairedInterval_contains computedPhasedBaseFullFiveDirectGroup12Jets
