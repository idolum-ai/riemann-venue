  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerThreeCompactCell3Shard8Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerThreeCompactCell3Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerThreeCompactCell3Shard8PointInterval, computedPhasedBaseFullFiveInnerThreeCompactCell3Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerThreeDirectGroup21Signed_contains n b

