import RiemannVenue.Venue.BoundaryCarrier
import RiemannVenue.Kernels.Response

/-!
# Boundary carrier discipline: the first anti-fake traps made explicit

`BoundaryCarrier.lean` names the trap matrix as Prop-valued obligations. This
file starts hardening the cheapest traps into reusable interfaces:

* observable maps must satisfy actual algebraic/scale laws;
* weights must be finite on a named test ideal, not merely positive in
  prose; and
* any boundary carrier must restrict to the finite-place vector response
  already proved in `RiemannVenue.Kernels.Response`.

These interfaces still do not construct the completed carrier and still do
not prove Weil positivity. They only make three escape hatches narrower.
-/

universe u

namespace RiemannVenue.Venue

/-- Translate a log-scale test function. This is the test-side shadow of the
scale action a carrier is expected to implement. -/
def logTranslate (t : ℝ) (h : ℝ → ℝ) : ℝ → ℝ :=
  fun x => h (x + t)

/-- The observable discipline for a proposed boundary carrier.

The fields use explicit operations rather than typeclasses because this is a
workbench interface: future candidates may instantiate observables as
operators, forms, affiliated operators, or distributional proxies. The laws
are the important part. -/
structure BoundaryCarrierObservableDiscipline
    (C : BoundaryCarrierCandidate.{u}) where
  /-- The zero observable. -/
  zero : C.observable
  /-- Addition of observables. -/
  add : C.observable → C.observable → C.observable
  /-- Scalar multiplication of observables. -/
  smul : ℝ → C.observable → C.observable
  /-- The carrier's log-scale action on observables. -/
  scaleAction : ℝ → C.observable → C.observable
  /-- Zero tests map to the zero observable. -/
  map_zero : C.toObservable (0 : ℝ → ℝ) = zero
  /-- The observable map is additive. -/
  map_add : ∀ h g : ℝ → ℝ,
    C.toObservable (fun x => h x + g x) =
      add (C.toObservable h) (C.toObservable g)
  /-- The observable map is homogeneous. -/
  map_smul : ∀ (c : ℝ) (h : ℝ → ℝ),
    C.toObservable (fun x => c * h x) = smul c (C.toObservable h)
  /-- Translating a log-scale test is implemented by the carrier's scale
  action. -/
  map_translate : ∀ (t : ℝ) (h : ℝ → ℝ),
    C.toObservable (logTranslate t h) = scaleAction t (C.toObservable h)

/-- A named test ideal for a boundary carrier. The ideal must at least contain
the compactly supported continuous tests used by Weil positivity. -/
structure BoundaryTestIdeal where
  /-- Membership in the carrier's admissible test domain. -/
  admissible : (ℝ → ℝ) → Prop
  /-- All Weil tests lie in the domain. -/
  contains_weil_tests :
    ∀ h : ℝ → ℝ, Continuous h → HasCompactSupport h → admissible h

/-- The weight/domain discipline for a carrier.

The weight value is allowed to be `∞` on arbitrary observables. The trap is
that it must be finite on the square observables generated by the admitted
test ideal. -/
structure BoundaryCarrierWeightDiscipline
    (C : BoundaryCarrierCandidate.{u}) where
  /-- The carrier's admissible test ideal. -/
  testIdeal : BoundaryTestIdeal
  /-- The positive square attached to an observable. In a star-algebra model
  this would be `star a * a`; for a vector model it can be read as a norm
  square proxy. -/
  square : C.observable → C.observable
  /-- The positive weight/trace/state value. It may be infinite away from the
  test ideal. -/
  weightValue : C.observable → ENNReal
  /-- The weight is finite on squares generated by admissible tests. -/
  finite_on_admissible_squares :
    ∀ h : ℝ → ℝ, testIdeal.admissible h →
      weightValue (square (C.toObservable h)) ≠ ⊤

/-- Compactly supported continuous tests are finite for a disciplined
boundary weight. -/
theorem BoundaryCarrierWeightDiscipline.finite_on_weil_squares
    {C : BoundaryCarrierCandidate.{u}}
    (W : BoundaryCarrierWeightDiscipline C)
    (h : ℝ → ℝ) (hc : Continuous h) (hcs : HasCompactSupport h) :
    W.weightValue (W.square (C.toObservable h)) ≠ ⊤ :=
  W.finite_on_admissible_squares h
    (W.testIdeal.contains_weil_tests h hc hcs)

/-- The known finite local vector response, phrased as a reusable contact
surface for boundary carriers. -/
def FiniteLocalVectorResponseContact : Prop :=
  ∀ {a : ℝ}, 0 < a → a < 1 → ∀ θ : ℝ,
    HasSum (fun k : ℤ =>
        (starRingEnd ℂ) ((Real.sqrt a ^ k.natAbs : ℝ) : ℂ) *
          (Complex.exp (k * θ * Complex.I) *
            ((Real.sqrt a ^ k.natAbs : ℝ) : ℂ)))
      (((1 - a ^ 2) /
          Complex.normSq (1 - a * Complex.exp (θ * Complex.I)) : ℝ) : ℂ)

/-- The repository already proves the local vector response contact. -/
theorem finiteLocalVectorResponseContact_holds :
    FiniteLocalVectorResponseContact := by
  intro a ha₀ ha₁ θ
  exact RiemannVenue.Kernels.response_eq_poisson ha₀ ha₁ θ

/-- The known finite prime-shadow response, phrased as a reusable contact
surface for boundary carriers. -/
def FinitePrimeShadowContact : Prop :=
  ∀ {p : ℕ}, p.Prime → ∀ {α : ℝ}, 0 < α → ∀ u : ℝ,
    HasSum
      (fun k : ℤ => ((((p : ℝ) ^ (-α) : ℝ) : ℂ)) ^ k.natAbs *
        Complex.exp (k * ((u * Real.log p : ℝ) : ℂ) * Complex.I))
      (((1 - ((p : ℝ) ^ (-α)) ^ 2) /
          Complex.normSq (1 - (((p : ℝ) ^ (-α) : ℝ) : ℂ) *
            Complex.exp (((u * Real.log p : ℝ) : ℂ) * Complex.I)) : ℝ) : ℂ)

/-- The repository already proves the prime-shadow contact. -/
theorem finitePrimeShadowContact_holds :
    FinitePrimeShadowContact := by
  intro p hp α hα u
  exact RiemannVenue.Kernels.hasSum_primeShadow hp hα u

/-- The finite-window contact any boundary carrier must match before it can
claim to extend the finite-place vector-state picture. -/
structure BoundaryCarrierFiniteWindowContact where
  /-- Local response as a vector-state matrix coefficient. -/
  localVectorResponse : FiniteLocalVectorResponseContact
  /-- Prime-shadow response as the same vector-state picture at
  `θ = u log p`. -/
  primeShadowResponse : FinitePrimeShadowContact

/-- The finite-window contact already available from the existing response
module. A future boundary carrier should restrict to this contact surface,
not replace it. -/
theorem knownFiniteWindowContact : BoundaryCarrierFiniteWindowContact where
  localVectorResponse := finiteLocalVectorResponseContact_holds
  primeShadowResponse := finitePrimeShadowContact_holds

/-- The first hardened trap batch for a boundary carrier: actual observable
laws, a finite weight domain on Weil tests, and contact with the proved
finite-place vector response. -/
structure BoundaryCarrierHardenedTrapBatch
    (C : BoundaryCarrierCandidate.{u}) where
  /-- Observable discipline, replacing the bare `observableLinearity` slogan
  by equations. -/
  observableDiscipline : BoundaryCarrierObservableDiscipline C
  /-- Weight-domain discipline, replacing the bare `finiteWeightDomain`
  slogan by a test ideal and finiteness theorem. -/
  weightDiscipline : BoundaryCarrierWeightDiscipline C
  /-- Finite-place contact with the already-proved vector response. -/
  finiteWindowContact : BoundaryCarrierFiniteWindowContact

end RiemannVenue.Venue
