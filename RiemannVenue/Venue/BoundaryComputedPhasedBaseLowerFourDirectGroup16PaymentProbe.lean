theorem computedPhasedBaseLowerFourDirectGroup16_remainder {x : ℝ}
    (hx : computedPhasedBaseLowerFourDirectGroup16Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseLowerFourDirectGroup16Interval]

noncomputable def computedPhasedBaseLowerFourDirectGroup16TaylorCell :=
  computedPhasedBaseOuterCachedShardTaylorCellWithRemainder
    computedPhasedBaseLowerFourDirectGroup16Interval (by norm_num [computedPhasedBaseLowerFourDirectGroup16Interval])
