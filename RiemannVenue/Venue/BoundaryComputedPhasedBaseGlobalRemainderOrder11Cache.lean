import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder11Shard0Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder11Shard1Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder11Shard2Cache
import RiemannVenue.Venue.BoundaryComputedPhasedBaseGlobalRemainderOrder11Shard3Cache

/-! # Exact global base-remainder cache, order 11 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000

def computedPhasedBaseGlobalRemainderOrder11Shards : Fin 4 → RationalInterval := ![
  computedPhasedBaseGlobalRemainderOrder11Shard0Cache,
  computedPhasedBaseGlobalRemainderOrder11Shard1Cache,
  computedPhasedBaseGlobalRemainderOrder11Shard2Cache,
  computedPhasedBaseGlobalRemainderOrder11Shard3Cache
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder11Shards_0 :
    computedPhasedBaseGlobalRemainderOrder11Shards (0 : Fin 4) = computedPhasedBaseGlobalRemainderOrder11Shard0Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder11Shards_1 :
    computedPhasedBaseGlobalRemainderOrder11Shards (1 : Fin 4) = computedPhasedBaseGlobalRemainderOrder11Shard1Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder11Shards_2 :
    computedPhasedBaseGlobalRemainderOrder11Shards (2 : Fin 4) = computedPhasedBaseGlobalRemainderOrder11Shard2Cache := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder11Shards_3 :
    computedPhasedBaseGlobalRemainderOrder11Shards (3 : Fin 4) = computedPhasedBaseGlobalRemainderOrder11Shard3Cache := rfl

def computedPhasedBaseGlobalRemainderOrder11ShardEvaluator (s : Fin 4) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 5 ↦
    RationalInterval.finSum fun k : Fin 5 ↦
      let outer : Fin 20 := finProdFinEquiv (s, g)
      let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
      RationalInterval.scale (computedPhasedBaseCoefficientQ j)
        (computedTransformAtomJetCellIntervalUpTo12
          32 4 32 16 11 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder11Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder11ShardEvaluator_eq (s : Fin 4) :
    computedPhasedBaseGlobalRemainderOrder11ShardEvaluator s = computedPhasedBaseGlobalRemainderOrder11Shards s := by
  fin_cases s
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder11Shard0Group = computedPhasedBaseGlobalRemainderOrder11Shards (0 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder11Shards_0, computedPhasedBaseGlobalRemainderOrder11Shard0Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder11Shard1Group = computedPhasedBaseGlobalRemainderOrder11Shards (1 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder11Shards_1, computedPhasedBaseGlobalRemainderOrder11Shard1Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder11Shard2Group = computedPhasedBaseGlobalRemainderOrder11Shards (2 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder11Shards_2, computedPhasedBaseGlobalRemainderOrder11Shard2Cache_eq]
  · change RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder11Shard3Group = computedPhasedBaseGlobalRemainderOrder11Shards (3 : Fin 4)
    rw [computedPhasedBaseGlobalRemainderOrder11Shards_3, computedPhasedBaseGlobalRemainderOrder11Shard3Cache_eq]

theorem computedPhasedBaseGlobalRemainderOrder11Cache_eq :
    computedPhasedBaseGlobalRemainderOrder11Cache = computedTransformBaseTestJetCellInterval
      32 4 32 16 11 computedPhasedBaseGlobalWindow := by
  rw [computedTransformBaseTestJetCellInterval,
    RationalInterval.finSum_finProd (m := 20) (n := 5)]
  conv_rhs =>
    rw [RationalInterval.finSum_finProd (m := 4) (n := 5)]
  change computedPhasedBaseGlobalRemainderOrder11Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder11ShardEvaluator
  rw [show computedPhasedBaseGlobalRemainderOrder11ShardEvaluator = computedPhasedBaseGlobalRemainderOrder11Shards from funext computedPhasedBaseGlobalRemainderOrder11ShardEvaluator_eq]
  change computedPhasedBaseGlobalRemainderOrder11Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder11Shards (0 : Fin 4))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder11Shards (1 : Fin 4))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder11Shards (2 : Fin 4))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder11Shards (3 : Fin 4))
            RationalInterval.zero)))
  rw [computedPhasedBaseGlobalRemainderOrder11Shards_0, computedPhasedBaseGlobalRemainderOrder11Shards_1, computedPhasedBaseGlobalRemainderOrder11Shards_2, computedPhasedBaseGlobalRemainderOrder11Shards_3]
  norm_num [computedPhasedBaseGlobalRemainderOrder11Cache, computedPhasedBaseGlobalRemainderOrder11Shard0Cache, computedPhasedBaseGlobalRemainderOrder11Shard1Cache, computedPhasedBaseGlobalRemainderOrder11Shard2Cache, computedPhasedBaseGlobalRemainderOrder11Shard3Cache,
    RationalInterval.add, RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
