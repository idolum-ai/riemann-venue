      have hz : x - (computedPhasedBaseFullFiveInnerOneCompactCell1Shard14Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerOneCompactCell1Shard14PointInterval, computedPhasedBaseFullFiveInnerOneCompactCell1Shard14Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerOneDirectGroup11Signed_contains n b

