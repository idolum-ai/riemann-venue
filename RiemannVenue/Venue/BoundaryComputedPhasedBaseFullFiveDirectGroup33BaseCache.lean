def computedPhasedBaseFullFiveDirectGroup33Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveDirectGroup33Group n b g

theorem computedPhasedBaseFullFiveDirectGroup33Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveDirectGroup33Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveCompactCell5Shard17Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveDirectGroup33Group_contains n b g

def computedPhasedBaseFullFiveDirectGroup33SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveCompactCell5Shard17PointInterval where
  signed := computedPhasedBaseFullFiveDirectGroup33Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveCompactCell5Shard17Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveCompactCell5Shard17Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveCompactCell5Shard17PointInterval, computedPhasedBaseFullFiveCompactCell5Shard17Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveDirectGroup33Signed_contains n b

def computedPhasedBaseFullFiveDirectGroup33BumpCache : ComputedPhasedBaseActiveBlockPointBumpCache
