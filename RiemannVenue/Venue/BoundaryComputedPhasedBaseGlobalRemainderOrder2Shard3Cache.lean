import RiemannVenue.Venue.BoundaryComputedPhasedBaseOuterCompactVariationCore

/-! # Global base-remainder cache, order 2, shard 3 -/

namespace RiemannVenue.Venue
noncomputable section
set_option maxRecDepth 100000
set_option maxHeartbeats 4000000

def computedPhasedBaseGlobalRemainderOrder2Shard3Group (g : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun k : Fin 5 ↦
    let outer : Fin 20 := finProdFinEquiv ((3 : Fin 4), g)
    let j : ComputedPhasedColumn := finProdFinEquiv (outer, k)
    RationalInterval.scale (computedPhasedBaseCoefficientQ j)
      (computedTransformAtomJetCellIntervalUpTo12
        32 4 32 16 2 j computedPhasedBaseGlobalWindow)

def computedPhasedBaseGlobalRemainderOrder2Shard3Groups : Fin 5 → RationalInterval := ![
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩,
  ⟨0, ( /  : ℚ)⟩
]

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shard3Groups_0 :
    computedPhasedBaseGlobalRemainderOrder2Shard3Groups (0 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shard3Groups_1 :
    computedPhasedBaseGlobalRemainderOrder2Shard3Groups (1 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shard3Groups_2 :
    computedPhasedBaseGlobalRemainderOrder2Shard3Groups (2 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shard3Groups_3 :
    computedPhasedBaseGlobalRemainderOrder2Shard3Groups (3 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

@[simp] theorem computedPhasedBaseGlobalRemainderOrder2Shard3Groups_4 :
    computedPhasedBaseGlobalRemainderOrder2Shard3Groups (4 : Fin 5) = ⟨0, ( /  : ℚ)⟩ := rfl

def computedPhasedBaseGlobalRemainderOrder2Shard3Cache : RationalInterval :=
  ⟨0, ( /  : ℚ)⟩

theorem computedPhasedBaseGlobalRemainderOrder2Shard3Group_eq (g : Fin 5) :
    computedPhasedBaseGlobalRemainderOrder2Shard3Group g = computedPhasedBaseGlobalRemainderOrder2Shard3Groups g := by
  fin_cases g <;>
    norm_num (config := { maxSteps := 4000000 })
      [computedPhasedBaseGlobalRemainderOrder2Shard3Group, computedPhasedBaseGlobalRemainderOrder2Shard3Groups, computedPhasedBaseGlobalWindow,
        computedTransformAtomJetCellIntervalUpTo12,
        computedTransformCosineJetCellInterval,
        computedTransformAtomTrigCellInterval,
        rationalCosineJetInterval,
        computedTransformBumpJetCellIntervalUpTo12,
        computedTransformBumpCoordinateInterval,
        computedTransformBumpGlobalBoundUpTo12,
        explicitBumpGapInterval,
        computedPhasedBaseCoefficientQ,
        computedPhasedFrequencyQ, computedPhasedTranslationQ,
        rationalTrigInterval, RationalTrigInterval.expand,
        RationalTrigInterval.reconstruct, RationalTrigInterval.taylor,
        RationalTrigInterval.double, rationalCisTaylor,
        rationalCisMonomial, RationalComplex.mulArgI,
        RationalComplex.add, RationalComplex.scale,
        RationalComplex.zero, RationalComplex.one,
        rationalExpRemainder,
        RationalInterval.expand, RationalInterval.finSum,
        RationalInterval.scale, RationalInterval.pow,
        RationalInterval.mul, RationalInterval.sub,
        RationalInterval.add, RationalInterval.neg,
        RationalInterval.one, RationalInterval.zero,
        RationalInterval.singleton, RationalInterval.lower,
        RationalInterval.upper, finProdFinEquiv, Nat.choose]

theorem computedPhasedBaseGlobalRemainderOrder2Shard3Cache_eq :
    computedPhasedBaseGlobalRemainderOrder2Shard3Cache = RationalInterval.finSum computedPhasedBaseGlobalRemainderOrder2Shard3Group := by
  rw [show computedPhasedBaseGlobalRemainderOrder2Shard3Group = computedPhasedBaseGlobalRemainderOrder2Shard3Groups from funext computedPhasedBaseGlobalRemainderOrder2Shard3Group_eq]
  change computedPhasedBaseGlobalRemainderOrder2Shard3Cache =
    RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shard3Groups (0 : Fin 5))
      (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shard3Groups (1 : Fin 5))
        (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shard3Groups (2 : Fin 5))
          (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shard3Groups (3 : Fin 5))
            (RationalInterval.add (computedPhasedBaseGlobalRemainderOrder2Shard3Groups (4 : Fin 5))
              RationalInterval.zero))))
  rw [computedPhasedBaseGlobalRemainderOrder2Shard3Groups_0, computedPhasedBaseGlobalRemainderOrder2Shard3Groups_1, computedPhasedBaseGlobalRemainderOrder2Shard3Groups_2, computedPhasedBaseGlobalRemainderOrder2Shard3Groups_3, computedPhasedBaseGlobalRemainderOrder2Shard3Groups_4]
  norm_num (config := { maxSteps := 4000000 })
    [computedPhasedBaseGlobalRemainderOrder2Shard3Cache, RationalInterval.add,
      RationalInterval.zero, RationalInterval.singleton]

end
end RiemannVenue.Venue
