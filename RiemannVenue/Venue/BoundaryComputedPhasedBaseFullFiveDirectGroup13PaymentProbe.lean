theorem computedPhasedBaseFullFiveDirectGroup13_remainder {x : ℝ}
    (hx : computedPhasedBaseFullFiveDirectGroup13Interval.Contains x) :
    ‖computedPhasedBasePairedRawJet computedPhasedBenchmarkPoint 12 x‖ ≤
      (computedPhasedBaseGlobalPairedTwelveRemainderBound : ℝ) := by
  apply norm_computedPhasedBasePairedRawJet_twelve_le_globalBound
  apply (RationalInterval.abs_le_abs_center_add_radius hx).trans
  norm_num [computedPhasedBaseFullFiveDirectGroup13Interval]

noncomputable def computedPhasedBaseFullFiveDirectGroup13TaylorCell :=
