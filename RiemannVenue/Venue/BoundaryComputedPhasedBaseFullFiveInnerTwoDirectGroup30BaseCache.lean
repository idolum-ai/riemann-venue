      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell5Shard2Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell5Shard2PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell5Shard2Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
