      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell2Shard14Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell2Shard14PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell2Shard14Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
