      have hz : x - (computedPhasedBaseFullFiveInnerTwoCompactCell5Shard22Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerTwoCompactCell5Shard22PointInterval, computedPhasedBaseFullFiveInnerTwoCompactCell5Shard22Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
