def computedPhasedBaseFullFiveInnerFourDirectGroup9Signed (n : Fin 12) (b : Fin 5) : RationalInterval :=
  RationalInterval.finSum fun g : Fin 4 => computedPhasedBaseFullFiveInnerFourDirectGroup9Group n b g

theorem computedPhasedBaseFullFiveInnerFourDirectGroup9Signed_contains (n : Fin 12) (b : Fin 5) :
    (computedPhasedBaseFullFiveInnerFourDirectGroup9Signed n b).Contains
      (∑ g : Fin 20, computedPhasedBaseCoefficient (computedPhasedBaseFullFiveModel.column b g) *
        computedPhasedCosineJet n (computedPhasedBaseFullFiveModel.column b g)
          (computedPhasedBaseFullFiveInnerFourCompactCell1Shard8Interval.center : ℝ)) := by
  rw [computedPhasedBaseActiveBlock_signedCosine_eq_groups]
  exact RationalInterval.contains_finSum fun g => computedPhasedBaseFullFiveInnerFourDirectGroup9Group_contains n b g

def computedPhasedBaseFullFiveInnerFourDirectGroup9SignedCache : ComputedPhasedBaseActiveBlockPointSignedCache
    computedPhasedBaseFullFiveModel computedPhasedBaseFullFiveInnerFourCompactCell1Shard8PointInterval where
  signed := computedPhasedBaseFullFiveInnerFourDirectGroup9Signed
  signed_contains := by
    intro n b x hx
    have hx' : x = (computedPhasedBaseFullFiveInnerFourCompactCell1Shard8Interval.center : ℝ) := by
      have hz : x - (computedPhasedBaseFullFiveInnerFourCompactCell1Shard8Interval.center : ℝ) = 0 := by
        simpa [computedPhasedBaseFullFiveInnerFourCompactCell1Shard8PointInterval, computedPhasedBaseFullFiveInnerFourCompactCell1Shard8Interval,
          RationalInterval.singleton, RationalInterval.Contains] using hx
      linarith
    subst x
    exact computedPhasedBaseFullFiveInnerFourDirectGroup9Signed_contains n b

